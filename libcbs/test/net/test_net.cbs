// Always enable asserts.
#ifdef NDEBUG
#undef NDEBUG
#endif

#include <assert.h>
#include "net.hbs"

void test1() {
    struct Ipv4Addr ip1 = struct Ipv4Addr::new(192, 168, 0, 1);
    uint32_t bits1 = ip1.to_bits();
    assert(bits1 == 0xc0a80001);

    struct Ipv4Addr ip2 = struct Ipv4Addr::new(127, 0, 0, 1);
    uint32_t bits2 = ip2.to_bits();
    assert(bits2 == 0x7f000001);
}

int main() {
    test1();
    return 0;
}