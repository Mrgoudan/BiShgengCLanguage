#include "src/string/string.hbs"

void test1() {
	String s1 = String::new();
	size_t l = s1.length();
	s1.set(0, 'h');
	s1.set(1, 'e');
	s1.set(2, 'l');
	s1.set(3, 'l');
	s1.set(4, 'o');
	s1.set(5, '\0');
	s2 = String::with_capacity(7);
	safe_swap(&mut s1, &mut s2);
}

int main() {
    test1();
    return 0;
}