#include "bishengc_safety.hbs"
#include <stdio.h>
#include "vec.hbs"


struct Matrix<T> {
    size_t rows;
    size_t cols;
    Vec<Vec<T>> data;
};

static _Safe Matrix<T>* _Owned create_matrix<T>(size_t rows, size_t cols) {
    Vec<Vec<T>> vec = Vec<Vec<T>>::with_capacity(rows);
    Matrix<T> m = {rows, cols, vec};
    Matrix<T>* _Owned mat = safe_malloc(m);
    _Unsafe {
        if (mat == NULL) {
            printf("Error: Failed to allocate memory for matrix.\n");
            exit(1);
        }
    }
    return mat;
}

int main() {
    Matrix<int>* _Owned A = create_matrix<int>(10, 10);
    safe_free((void *_Owned)A);
    return 0;
}

