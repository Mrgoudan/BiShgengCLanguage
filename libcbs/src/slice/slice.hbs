/// Get the underlying mutable raw pointer of the slice.
///
/// This function returns a mutable pointer to the underlying pointer,
/// which allows both read and write access to the slice's elements.
_Unsafe T *_Nonnull SliceMut<T>::as_mut_ptr(This this) {
    return (T *_Nonnull)this.ptr;
}

#endif
