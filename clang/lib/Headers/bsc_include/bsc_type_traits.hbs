// Define BSC type trait functions
#ifndef BSC_TYPE_TRAITS_HBS
#define BSC_TYPE_TRAITS_HBS
#include <stdbool.h>
#include <stddef.h>

// Unary Type Traits
_Safe constexpr bool is_integral<T>(void) {
    return __is_integral(T);
}

_Safe constexpr bool is_floating_point<T>(void) {
    return __is_floating_point(T);
}

_Safe constexpr bool is_signed<T>(void) {
    return __is_signed(T);
}

_Safe constexpr bool is_unsigned<T>(void) {
    return __is_unsigned(T);
}

_Safe constexpr bool is_pointer<T>(void) {
    return __is_pointer(T);
}

_Safe constexpr bool is_function<T>(void) {
    return __is_function(T);
}

_Safe constexpr bool is_array<T>(void) {
    return __is_array(T);
}

_Safe constexpr bool is_struct<T>(void) {
    return __is_struct(T);
}

_Safe constexpr bool is_union<T>(void) {
    return __is_union(T);
}

_Safe constexpr bool is_enum<T>(void) {
    return __is_enum(T);
}

_Safe constexpr bool is_const<T>(void) {
    return __is_const(T);
}

_Safe constexpr bool is_volatile<T>(void) {
    return __is_volatile(T);
}

_Safe constexpr bool is_move_semantic<T>(void) {
    return __is_move_semantic(T);
}

_Safe constexpr bool is_owned_pointer<T>(void) {
    return __is_owned_pointer(T);
}

_Safe constexpr bool is_owned_struct<T>(void) {
    return __is_owned_struct(T);
}

_Safe constexpr bool is_borrow<T>(void) {
    return __is_borrow(T);
}

typedef __remove_pointer<T> = __typeof(*(T)nullptr);

_Safe constexpr bool is_immut_borrow<T>(void) {
    if constexpr(!is_borrow<T>()) {
        return false;
    } else {
        return is_const<__remove_pointer<T>>();
    }
}

_Safe constexpr bool is_mut_borrow<T>(void) {
    if constexpr(!is_borrow<T>()) {
        return false;
    } else {
        return !is_const<__remove_pointer<T>>();
    }
}

_Safe constexpr bool is_void<T>(void) {
    return __is_void(T);
}

// Trivial Type Trait
_Safe constexpr bool is_trivial_data<T>(void) {
    return __is_trivial_data(T);
}

// Binary Type Traits
_Safe constexpr bool is_same<T1, T2>(void) {
    return __is_same(T1, T2);
}

_Safe constexpr bool is_convertible<From, To>(void) {
    return __is_convertible(From, To);
}

// Array Type Traits
_Safe constexpr size_t rank<T>(void) {
    return __array_rank(T);
}

_Safe constexpr size_t extent<T, size_t N>(void) {
    return __array_extent(T, N);
}
#endif /* BSC_TYPE_TRAITS_HBS */



