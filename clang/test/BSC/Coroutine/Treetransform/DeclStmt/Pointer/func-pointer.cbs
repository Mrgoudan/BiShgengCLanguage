// expected-no-diagnostics

#include "../../../async-func-read.hbs"

int max(int x, int y)
{
    return x > y ? x : y;
}

async int f(int start) {
  int (* p)(int, int) = & max; 
  int a = 1, b = 2, c = 3, d;
 
  d = p(p(a, b), c); 
 
  int result = await read(1);
  return d;
}

int main() {
  struct _Futuref this = {}; 
  struct _Futuref::poll(&this);
  return 0;
}