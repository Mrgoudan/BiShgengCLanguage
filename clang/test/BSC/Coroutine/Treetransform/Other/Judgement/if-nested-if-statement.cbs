// RUN: %clang %s -o %test.output
// RUN: %test.output
// expected-no-diagnostics

#include "../../../async-func-read.hbs"

async int f(int start) {
  int x = 3;
  int result;
  if (x < 20) {
    if (x > 0)
        result = await read(1);
  } else result = x;
  return result;
}

int main() {
  struct _Futuref this = {}; 
  struct _Futuref::poll(&this);
  return 0;
}