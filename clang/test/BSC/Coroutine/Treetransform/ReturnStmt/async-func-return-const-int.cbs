// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

#include "../../async-func-read.hbs"

async const int f(int start) {
    int a = await read(1);  
    int b = 2;

    if(a == 1) {
        if (b == 3)
            return -1;
        return 2;
    }


    return -1;
}

int main() {
  struct _Futuref this = {}; 
  struct _Futuref::poll(&this);
  return 0;
}