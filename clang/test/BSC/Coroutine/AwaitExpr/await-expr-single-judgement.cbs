// RUN: %clang %s -o %test.output
// RUN: %test.output
// expected-no-diagnostics

#include "../async-func-read.hbs"

async int f(int start) {
    int a = 3;
    if (a == 3) 
        for(int i=0;i<1; i++)
            a = await read(1);
    else if (a == 4) {
        if (a == 4)
            a = await read(1);
    }
    else 
        a = await read(1);

    while (a<3)
        a = await read(1);

    return start;
}

int main() {
  struct _Futuref this = {}; 
  struct _Futuref::poll(&this);
  return 0;
}