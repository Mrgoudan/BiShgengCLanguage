// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR struct field access via pointer (deref + field projection).

struct Point {
    int x;
    int y;
};

// CHECK-LABEL: fn set_point
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   (*_1).x = copy(_2)
// CHECK-NEXT:   (*_1).y = copy(_3)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void set_point(struct Point *p, int x, int y) {
    p->x = x;
    p->y = y;
}
