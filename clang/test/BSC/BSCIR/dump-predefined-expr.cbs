// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test that PredefinedExpr (__func__) produces a string constant, not a nop.

_Safe void use_str(const char *_Borrow s);

// CHECK-LABEL: fn test_predefined
// CHECK:      bb0: {
// CHECK-NEXT:   StorageLive(_1) [safe]
// CHECK-NEXT:   _2 = const "test_predefined" [safe]
// CHECK-NEXT:   _3 = &_Const _2[0] <'r1> [safe]
// CHECK-NEXT:   _4 = copy(_3) [safe]
// CHECK-NEXT:   _5 = &_Const _4 (reborrow) <'r2> [safe]
// CHECK-NEXT:   _1 = copy(_5) [safe]
// CHECK-NOT:    nop
_Safe void test_predefined(void) {
    const char *_Borrow name = __func__;
    use_str(name);
}
