// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of pre/post increment and decrement.

// Each decomposes into BinOp(+/-) and write-back assignment.

// CHECK-LABEL: fn test_preinc
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = BinOp(+, copy(_1), const 1)
// CHECK-NEXT:   _1 = copy(_2)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_preinc(int x) { ++x; }

// CHECK-LABEL: fn test_predec
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = BinOp(-, copy(_1), const 1)
// CHECK-NEXT:   _1 = copy(_2)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_predec(int x) { --x; }

// CHECK-LABEL: fn test_postinc
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = copy(_1)
// CHECK-NEXT:   _3 = BinOp(+, copy(_1), const 1)
// CHECK-NEXT:   _1 = copy(_3)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_postinc(int x) { x++; }

// CHECK-LABEL: fn test_postdec
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = copy(_1)
// CHECK-NEXT:   _3 = BinOp(-, copy(_1), const 1)
// CHECK-NEXT:   _1 = copy(_3)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_postdec(int x) { x--; }
