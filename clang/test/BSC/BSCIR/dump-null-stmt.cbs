// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test that NullStmt (bare semicolons) produces no nop in the IR.

_Safe void use_int(int x);

// CHECK-LABEL: fn test_null_stmt
// CHECK:      bb0: {
// CHECK-NEXT:   StorageLive(_1) [safe]
// CHECK-NEXT:   _1 = const 0 [safe]
// CHECK-NEXT:   _2 = call use_int(copy(_1)) -> bb1 [safe]
// CHECK-NOT:    nop
_Safe void test_null_stmt(void) {
    int x = 0;
    ;
    ;
    use_int(x);
}
