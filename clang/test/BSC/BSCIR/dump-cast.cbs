// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of explicit casts: int<->double, pointer casts.


// CHECK-LABEL: fn test_int_to_double
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = Cast(copy(_1) as double)
// CHECK-NEXT:   _0 = copy(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
double test_int_to_double(int x) {
    return (double)x;
}

// CHECK-LABEL: fn test_double_to_int
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = Cast(copy(_1) as int)
// CHECK-NEXT:   _0 = copy(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_double_to_int(double d) {
    return (int)d;
}

// CHECK-LABEL: fn test_ptr_cast
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = Cast(copy(_1) as void *)
// CHECK-NEXT:   _0 = copy(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
void *test_ptr_cast(int *p) {
    return (void *)p;
}
