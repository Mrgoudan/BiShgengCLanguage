// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of bitwise operators: &, |, ^, <<, >>, ~.


// CHECK-LABEL: fn test_bitnot
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = UnaryOp(~, copy(_1))
// CHECK-NEXT:   _0 = copy(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_bitnot(int x) { return ~x; }

// CHECK-LABEL: fn test_bitand
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(&, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_bitand(int a, int b) { return a & b; }

// CHECK-LABEL: fn test_bitor
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(|, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_bitor(int a, int b) { return a | b; }

// CHECK-LABEL: fn test_bitxor
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(^, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_bitxor(int a, int b) { return a ^ b; }

// CHECK-LABEL: fn test_shl
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(<<, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_shl(int a, int b) { return a << b; }

// CHECK-LABEL: fn test_shr
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(>>, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_shr(int a, int b) { return a >> b; }
