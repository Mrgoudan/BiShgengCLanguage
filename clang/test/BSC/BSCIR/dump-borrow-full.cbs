// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of borrows: &_Mut, &_Const, reborrow, and C-style &.


// CHECK-LABEL: fn test_mut_borrow
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1) [safe]
// CHECK-NEXT:   _1 = const 1 [safe]
// CHECK-NEXT:   StorageLive(_2) [safe]
// CHECK-NEXT:   _3 = &_Mut _1 [safe]
// CHECK-NEXT:   _2 = copy(_3) [safe]
// CHECK-NEXT:   StorageDead(_2) [safe]
// CHECK-NEXT:   StorageDead(_1) [safe]
// CHECK-NEXT:   return [safe]
// CHECK-NEXT: }
_Safe void test_mut_borrow(void) {
    int x = 1;
    int *_Borrow p = &_Mut x;
}

// CHECK-LABEL: fn test_const_borrow
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1) [safe]
// CHECK-NEXT:   _1 = const 1 [safe]
// CHECK-NEXT:   StorageLive(_2) [safe]
// CHECK-NEXT:   _3 = &_Const _1 [safe]
// CHECK-NEXT:   _2 = copy(_3) [safe]
// CHECK-NEXT:   StorageDead(_2) [safe]
// CHECK-NEXT:   StorageDead(_1) [safe]
// CHECK-NEXT:   return [safe]
// CHECK-NEXT: }
_Safe void test_const_borrow(void) {
    int x = 1;
    const int *_Borrow p = &_Const x;
}

// CHECK-LABEL: fn test_reborrow
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1) [safe]
// CHECK-NEXT:   _1 = const 1 [safe]
// CHECK-NEXT:   StorageLive(_2) [safe]
// CHECK-NEXT:   _3 = &_Mut _1 [safe]
// CHECK-NEXT:   _2 = copy(_3) [safe]
// CHECK-NEXT:   StorageLive(_4) [safe]
// CHECK-NEXT:   _5 = &_Mut _2 (reborrow) [safe]
// CHECK-NEXT:   _4 = copy(_5) [safe]
// CHECK-NEXT:   StorageDead(_4) [safe]
// CHECK-NEXT:   StorageDead(_2) [safe]
// CHECK-NEXT:   StorageDead(_1) [safe]
// CHECK-NEXT:   return [safe]
// CHECK-NEXT: }
_Safe void test_reborrow(void) {
    int x = 1;
    int *_Borrow p = &_Mut x;
    int *_Borrow q = &_Mut *p;
}

// CHECK-LABEL: fn test_c_addr
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1)
// CHECK-NEXT:   _1 = const 1
// CHECK-NEXT:   StorageLive(_2)
// CHECK-NEXT:   _3 = &_1
// CHECK-NEXT:   _2 = copy(_3)
// CHECK-NEXT:   StorageDead(_2)
// CHECK-NEXT:   StorageDead(_1)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_c_addr(void) {
    int x = 1;
    int *p = &x;
}
