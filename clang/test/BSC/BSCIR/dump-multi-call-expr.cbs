// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of multiple function calls combined with arithmetic:

// foo(x) + bar(x). Each call is a block terminator; the BinOp is a statement
// in the successor block after both calls complete.
int foo(int x);
int bar(int x);

// CHECK-LABEL: fn test_multi_call_expr
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = call foo(copy(_1)) -> bb2
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _3 = call bar(copy(_1)) -> bb3
// CHECK-NEXT: }
// CHECK:      bb3: {{[{]}}
// CHECK-NEXT:   _4 = BinOp(+, copy(_2), copy(_3))
// CHECK-NEXT:   _0 = copy(_4)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_multi_call_expr(int x) {
    return foo(x) + bar(x);
}
