// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of 3-level nested calls: foo(bar(foo(x))).

// Each call must be in a separate block. The innermost call completes first,
// its result feeds the middle call, which feeds the outer call.
int foo(int x);
int bar(int x);
//
// Inner: foo(x)
//
// Middle: bar(result_of_foo)
//
// Outer: foo(result_of_bar)
//
// Final result assigned to return slot.

// CHECK-LABEL: fn test_triple_nested
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = call foo(copy(_1)) -> bb2
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _3 = call bar(copy(_2)) -> bb3
// CHECK-NEXT: }
// CHECK:      bb3: {{[{]}}
// CHECK-NEXT:   _4 = call foo(copy(_3)) -> bb4
// CHECK-NEXT: }
// CHECK:      bb4: {{[{]}}
// CHECK-NEXT:   _0 = copy(_4)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_triple_nested(int x) {
    return foo(bar(foo(x)));
}
