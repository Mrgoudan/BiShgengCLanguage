// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of all comparison operators: <, <=, >=, !=.

// (> and == already tested in dump-arith.cbs)

// CHECK-LABEL: fn test_lt
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(<, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_lt(int a, int b) { return a < b; }

// CHECK-LABEL: fn test_le
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(<=, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_le(int a, int b) { return a <= b; }

// CHECK-LABEL: fn test_ge
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(>=, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_ge(int a, int b) { return a >= b; }

// CHECK-LABEL: fn test_ne
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(!=, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_ne(int a, int b) { return a != b; }
