// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of multiple return paths with nested if chains.


// CHECK-LABEL: fn test_multi_return
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = BinOp(<, copy(_1), const 0)
// CHECK-NEXT:   switchInt(copy(_2)) -> [1: bb2, otherwise: bb3]
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _3 = UnaryOp(-, const 1)
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb3: {{[{]}}
// CHECK-NEXT:   _4 = BinOp(==, copy(_1), const 0)
// CHECK-NEXT:   switchInt(copy(_4)) -> [1: bb4, otherwise: bb5]
// CHECK-NEXT: }
// CHECK:      bb4: {{[{]}}
// CHECK-NEXT:   _0 = const 0
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb5: {{[{]}}
// CHECK-NEXT:   _0 = const 1
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_multi_return(int x) {
    if (x < 0)
        return -1;
    if (x == 0)
        return 0;
    return 1;
}
