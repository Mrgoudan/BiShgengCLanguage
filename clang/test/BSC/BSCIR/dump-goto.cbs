// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of goto statement with label target.


// CHECK-LABEL: fn test_goto
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = BinOp(>, copy(_1), const 0)
// CHECK-NEXT:   switchInt(copy(_2)) -> [0: bb2, otherwise: bb3]
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _3 = UnaryOp(-, copy(_1))
// CHECK-NEXT:   _1 = copy(_3)
// CHECK-NEXT:   goto -> bb3
// CHECK-NEXT: }
// CHECK:      bb3: {{[{]}}
// CHECK-NEXT:   _0 = copy(_1)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_goto(int x) {
    if (x > 0)
        goto done;
    x = -x;
done:
    return x;
}
