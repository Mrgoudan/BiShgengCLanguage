// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of deeply nested place expressions (chained deref +

// field projections): c->bp->a.val.
struct A { int val; };
struct B { struct A a; };
struct C { struct B *bp; };

// CHECK-LABEL: fn test_deep_place
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _0 = copy((*(*_1).bp).a.val)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_deep_place(struct C *c) {
    return c->bp->a.val;
}
