// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test that AtomicExpr (__atomic_load_n etc.) is modeled as a Call terminator,
// not a nop + const(void).

_Safe void use_int(int x);

// CHECK-LABEL: fn test_atomic_load
// CHECK:      _3 = &_1 [unsafe]
// CHECK-NEXT: _4 = call __atomic_load_n(copy(_3), const 5) -> bb1 [unsafe]
// CHECK:      bb1: {
// CHECK-NEXT: _2 = copy(_4) [unsafe]
// CHECK-NOT:  nop
_Safe void test_atomic_load(void) {
    int x = 0;
    int val;
    _Unsafe {
        val = __atomic_load_n(&x, __ATOMIC_SEQ_CST);
    }
    use_int(val);
}
