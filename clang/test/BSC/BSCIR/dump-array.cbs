// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of array subscript: constant and runtime index.


// CHECK-LABEL: fn test_constant_index
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1)
// CHECK-NEXT:   _1[0] = const 42
// CHECK-NEXT:   _0 = copy(_1[0])
// CHECK-NEXT:   StorageDead(_1)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_constant_index(void) {
    int arr[5];
    arr[0] = 42;
    return arr[0];
}

// CHECK-LABEL: fn test_runtime_index
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_2)
// CHECK-NEXT:   _3 = copy(_1)
// CHECK-NEXT:   _2[_3] = const 99
// CHECK-NEXT:   _4 = copy(_1)
// CHECK-NEXT:   _0 = copy(_2[_4])
// CHECK-NEXT:   StorageDead(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_runtime_index(int i) {
    int arr[10];
    arr[i] = 99;
    return arr[i];
}
