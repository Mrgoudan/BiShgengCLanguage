// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of address-of array element (&arr[i]).


// CHECK-LABEL: fn test_addr_array_elem
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1)
// CHECK-NEXT:   StorageLive(_2)
// CHECK-NEXT:   _3 = &_1[3]
// CHECK-NEXT:   _2 = copy(_3)
// CHECK-NEXT:   StorageDead(_2)
// CHECK-NEXT:   StorageDead(_1)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_addr_array_elem(void) {
    int arr[10];
    int *p = &arr[3];
}
