// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of simple and compound assignments.


// CHECK-LABEL: fn test_simple_assign
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1)
// CHECK-NEXT:   _1 = const 1
// CHECK-NEXT:   StorageLive(_2)
// CHECK-NEXT:   _2 = copy(_1)
// CHECK-NEXT:   StorageDead(_2)
// CHECK-NEXT:   StorageDead(_1)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_simple_assign(void) {
    int x = 1;
    int y;
    y = x;
}

// CHECK-LABEL: fn test_compound_assign
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1)
// CHECK-NEXT:   _1 = const 10
// CHECK-NEXT:   _2 = BinOp(+, copy(_1), const 5)
// CHECK-NEXT:   _1 = copy(_2)
// CHECK-NEXT:   _3 = BinOp(-, copy(_1), const 3)
// CHECK-NEXT:   _1 = copy(_3)
// CHECK-NEXT:   _4 = BinOp(*, copy(_1), const 2)
// CHECK-NEXT:   _1 = copy(_4)
// CHECK-NEXT:   StorageDead(_1)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_compound_assign(void) {
    int x = 10;
    x += 5;
    x -= 3;
    x *= 2;
}
