// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of nested struct aggregate initialization.

struct Inner { int a; int b; };
struct Outer { struct Inner i; int c; };

// CHECK-LABEL: fn test_nested_agg
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_4)
// CHECK-NEXT:   _5 = Aggregate(Inner, {{[{]}}copy(_1), copy(_2){{[}]}})
// CHECK-NEXT:   _6 = Aggregate(Outer, {{[{]}}copy(_5), copy(_3){{[}]}})
// CHECK-NEXT:   _4 = copy(_6)
// CHECK-NEXT:   _0 = copy(_4)
// CHECK-NEXT:   StorageDead(_4)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
struct Outer test_nested_agg(int x, int y, int z) {
    struct Outer o = {{x, y}, z};
    return o;
}
