// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR move vs copy semantics: _Owned uses move(), non-owned uses copy().

void sink(int *_Owned p);

// CHECK-LABEL: fn test_owned_move
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_2)
// CHECK-NEXT:   _2 = move(_1)
// CHECK-NEXT:   _3 = call sink(move(_2)) -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   StorageDead(_2)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_owned_move(int *_Owned p) {
    int *_Owned q = p;
    sink(q);
}

// CHECK-LABEL: fn test_copy_semantics
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1)
// CHECK-NEXT:   _1 = const 1
// CHECK-NEXT:   StorageLive(_2)
// CHECK-NEXT:   _2 = copy(_1)
// CHECK-NEXT:   StorageDead(_2)
// CHECK-NEXT:   StorageDead(_1)
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_copy_semantics(void) {
    int x = 1;
    int y = x;
}
