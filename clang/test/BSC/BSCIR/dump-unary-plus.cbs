// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of unary plus operator.


// CHECK-LABEL: fn test_unary_plus
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = UnaryOp(+, copy(_1))
// CHECK-NEXT:   _0 = copy(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_unary_plus(int x) { return +x; }
