// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of borrowing the result of a function call.

// The call must complete (as a terminator), its result stored in a local,
// and then the borrow (&_Mut) takes a reference to that local.
_Safe int get_val(void);

// CHECK-LABEL: fn test_borrow_call_result
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1) [safe]
// CHECK-NEXT:   _2 = call get_val() -> bb1 [safe]
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   _1 = copy(_2) [safe]
// CHECK-NEXT:   StorageLive(_3) [safe]
// CHECK-NEXT:   _4 = &_Mut _1 <'r{{[0-9]+}}> [safe]
// CHECK-NEXT:   _3 = copy(_4) [safe]
// CHECK-NEXT:   StorageDead(_3) [safe]
// CHECK-NEXT:   StorageDead(_1) [safe]
// CHECK-NEXT:   return [safe]
// CHECK-NEXT: }
_Safe void test_borrow_call_result(void) {
    int x = get_val();
    int *_Borrow p = &_Mut x;
}
