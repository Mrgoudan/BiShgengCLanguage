// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of function calls: simple, multi-arg, and nested.

int foo(int x);
int bar(int x, int y);

// CHECK-LABEL: fn test_simple_call
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = call foo(copy(_1)) -> bb2
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _0 = copy(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_simple_call(int a) {
    return foo(a);
}

// CHECK-LABEL: fn test_multi_arg
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = call bar(copy(_1), copy(_2)) -> bb2
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_multi_arg(int a, int b) {
    return bar(a, b);
}

// CHECK-LABEL: fn test_nested_calls
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = call foo(copy(_1)) -> bb2
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _3 = call foo(copy(_2)) -> bb3
// CHECK-NEXT: }
// CHECK:      bb3: {{[{]}}
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_nested_calls(int a) {
    return foo(foo(a));
}
