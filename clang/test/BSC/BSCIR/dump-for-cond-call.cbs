// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of for-loop with function call in condition.

// Per BSCIR design: the condition call must be re-evaluated every iteration.
// The loop back-edge must go to the block containing the call, not past it.
int check_limit(int i);
//
// The condition call is a terminator in its own block.
//
// The call result feeds into switchInt for the branch decision.
//
// The increment block eventually jumps back to re-evaluate the condition call.

// CHECK-LABEL: fn test_for_cond_call
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_1)
// CHECK-NEXT:   _1 = const 0
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   _2 = call check_limit(copy(_1)) -> bb4
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _3 = copy(_1)
// CHECK-NEXT:   _4 = BinOp(+, copy(_1), const 1)
// CHECK-NEXT:   _1 = copy(_4)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb3: {{[{]}}
// CHECK-NEXT:   StorageDead(_1)
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb4: {{[{]}}
// CHECK-NEXT:   switchInt(copy(_2)) -> [0: bb3, otherwise: bb2]
// CHECK-NEXT: }
void test_for_cond_call(void) {
    for (int i = 0; check_limit(i); i++) {
        // body
    }
}
