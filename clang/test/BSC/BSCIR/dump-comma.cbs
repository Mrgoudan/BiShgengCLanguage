// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of comma operator.


// CHECK-LABEL: fn test_comma
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = copy(_1)
// CHECK-NEXT:   _4 = BinOp(+, copy(_1), const 1)
// CHECK-NEXT:   _1 = copy(_4)
// CHECK-NEXT:   _0 = copy(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_comma(int a, int b) {
    return (a++, b);
}
