// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of return statements: with expr and void.


// CHECK-LABEL: fn test_return_expr
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = BinOp(+, copy(_1), const 1)
// CHECK-NEXT:   _0 = copy(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_return_expr(int x) {
    return x + 1;
}

// CHECK-LABEL: fn test_void_return
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
void test_void_return(void) {
    return;
}
