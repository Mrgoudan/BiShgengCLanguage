// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of struct field access: dot, arrow, and nested.

struct Point { int x; int y; };
struct Nested { struct Point p; int z; };

// CHECK-LABEL: fn test_dot_access
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _0 = copy(_1.x)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_dot_access(struct Point s) {
    return s.x;
}

// CHECK-LABEL: fn test_arrow_access
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _0 = copy((*_1).x)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_arrow_access(struct Point *p) {
    return p->x;
}

// CHECK-LABEL: fn test_nested_access
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _0 = copy((*_1).p.x)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int test_nested_access(struct Nested *n) {
    return n->p.x;
}
