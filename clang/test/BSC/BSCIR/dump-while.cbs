// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of while loops with condition check and back-edge.


// CHECK-LABEL: fn test_while
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   StorageLive(_2)
// CHECK-NEXT:   _2 = const 0
// CHECK-NEXT:   goto -> bb2
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(>, copy(_1), const 0)
// CHECK-NEXT:   switchInt(copy(_3)) -> [0: bb4, otherwise: bb3]
// CHECK-NEXT: }
// CHECK:      bb3: {{[{]}}
// CHECK-NEXT:   _4 = BinOp(+, copy(_2), copy(_1))
// CHECK-NEXT:   _2 = copy(_4)
// CHECK-NEXT:   _5 = BinOp(-, copy(_1), const 1)
// CHECK-NEXT:   _1 = copy(_5)
// CHECK-NEXT:   goto -> bb2
// CHECK-NEXT: }
// CHECK:      bb4: {{[{]}}
// CHECK-NEXT:   _0 = copy(_2)
// CHECK-NEXT:   StorageDead(_2)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_while(int n) {
    int sum = 0;
    while (n > 0) {
        sum += n;
        n -= 1;
    }
    return sum;
}
