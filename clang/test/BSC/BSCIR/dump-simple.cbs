// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test basic BSCIR structure: locals, assignments, arithmetic.


// CHECK-LABEL: fn add
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = BinOp(+, copy(_1), copy(_2))
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
int add(int a, int b) {
    return a + b;
}
