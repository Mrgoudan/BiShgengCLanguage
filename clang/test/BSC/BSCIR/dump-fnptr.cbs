// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of function pointer call (indirect call via operand).

typedef int (*fn_ptr)(int);

// CHECK-LABEL: fn test_fnptr
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _3 = call copy(_1)(copy(_2)) -> bb2
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_fnptr(fn_ptr f, int x) {
    return f(x);
}
