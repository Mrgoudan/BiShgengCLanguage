// RUN: %clang_cc1 -fsyntax-only -dump-bscir %s 2>&1 | FileCheck %s

// Test BSCIR lowering of if/else to switchInt terminator.


// CHECK-LABEL: fn test_simple_if
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = BinOp(>, copy(_1), const 0)
// CHECK-NEXT:   switchInt(copy(_2)) -> [1: bb2, otherwise: bb3]
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _0 = const 1
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb3: {{[{]}}
// CHECK-NEXT:   _0 = const 0
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_simple_if(int x) {
    if (x > 0)
        return 1;
    return 0;
}

// CHECK-LABEL: fn test_if_else
// CHECK:      bb0: {{[{]}}
// CHECK-NEXT:   _2 = BinOp(>, copy(_1), const 0)
// CHECK-NEXT:   switchInt(copy(_2)) -> [1: bb2, otherwise: bb3]
// CHECK-NEXT: }
// CHECK:      bb1: {{[{]}}
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK:      bb2: {{[{]}}
// CHECK-NEXT:   _0 = const 1
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
// CHECK:      bb3: {{[{]}}
// CHECK-NEXT:   _3 = UnaryOp(-, const 1)
// CHECK-NEXT:   _0 = copy(_3)
// CHECK-NEXT:   goto -> bb1
// CHECK-NEXT: }
int test_if_else(int x) {
    if (x > 0)
        return 1;
    else
        return -1;
}
