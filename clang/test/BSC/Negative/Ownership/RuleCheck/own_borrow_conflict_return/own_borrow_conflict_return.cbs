// RUN: %clang_cc1 -verify %s

int *owned _Borrow get_resource() { //#1
    static int resource = 42;
    return (int *owned _Borrow)&resource; // expected-error {{cannot combine 'owned' and '_Borrow' qualifiers on the same type}}
}

