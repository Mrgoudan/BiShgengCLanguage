// RUN: %clang_cc1 -verify %s

int *_Owned _Borrow get_resource() { //#1
    static int resource = 42;
    return (int *_Owned _Borrow)&resource; // expected-error {{cannot combine '_Owned' and '_Borrow' qualifiers on the same type}}
}

