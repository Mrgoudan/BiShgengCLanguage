void func3(int n) {
    int num = 5;
    int * owned a;
    switch (n) {
        case 0:
            if (num > 0) {
                a = (int * owned)&num;
            }
            break;
        case 1:
            break;
        case 4:
            break;
        case 5:
            break;
        default:
            break;
    }
}  // expected-error {{a's memory will leak at the end of scope}}

void func4(int n) {
    int num = 5;
    int * owned a;
    switch (n) {
        case 0:
            if (num > 0) {
                a = (int * owned)&num;
            }
            break;
        case 1: {
            a = (int * owned)&num;
            break;
        }
        case 2:
            a = (int * owned)&num;
        case 4: {
            a = (int * owned)&num; // expected-error {{cannot assign a because its type is owned}}
        }
            break;
        case 5:
            break;
        default:
            break;
    }
    int * b = (int *)a; // expected-error {{a cannot be accessed, because it is uninitialized or moved}}
}

void func5(int n) {
    int num = 5;
    int * owned a;
    switch (n) {
        case 0:
            for (int i = 0; i < 10; i++) {
                if (n > 4) {
                    a = (int * owned)&num;
                    break;
                }
            }
        case 1:
            a = (int * owned)&num; // expected-error {{cannot assign a because its type is owned}}
            break;
        case 4:
            for (int i = 0; i < 10; i++)
                break;
        case 5:
            break;
        default:
            break;
    }
} // expected-error {{a's memory will leak at the end of scope}}

void func6(int n) {
    int num = 5;
    int * owned a;
    switch (n) {
        case 1:
            a = (int * owned)&num;
            for (int i = 0; i < 10; i++)
                break;
        case 2:
            a = (int * owned)&num; // expected-error {{cannot assign a because its type is owned}}
            break;
        default:
            break;
    }
} // expected-error {{a's memory will leak at the end of scope}}

void func7(int n) {
    int num = 5;
    int * owned a = (int * owned)&num;
    int * owned b;
    switch (n) {
        case 0 : {
            if (num > 0)
                b = a;

            if (num < 5)
                b = a; // expected-error {{cannot assign b because its type is owned}} expected-error {{a cannot be accessed, because it is uninitialized or moved}}
            break;
        }
        case 1:
            b = a;
            {
                b = a; // expected-error {{cannot assign b because its type is owned}} expected-error {{cannot read a, because it is moved at line: 152}}
                break;
            }
        case 4:
            b = a;
            for (int i = 0; i < 10; i++)
                break;
        case 5:
            b = (int * owned)&num; // expected-error {{cannot assign b because its type is owned}}
        default: {
            break;
        }
    }
} // expected-error {{a's memory will leak at the end of scope}} expected-error {{b's memory will leak at the end of scope}}

void func8(int n) {
    int num = 5;
