// RUN: %clang_cc1 -verify %s

void func1(int n) {
    int num = 5;
    int * owned a = (int * owned)&num;
    int * owned b;
    switch (n) {
        case 0:
            break;
        case 1:
            b = a;
            break;
        case 4:
            b = a;
            break;
        case 5:
            break;
        default:
            break;
    }
    b = (int * owned)&num; // expected-error {{cannot assign b because its type is owned}}
} // expected-error {{a's memory will leak at the end of scope}} expected-error {{b's memory will leak at the end of scope}}

