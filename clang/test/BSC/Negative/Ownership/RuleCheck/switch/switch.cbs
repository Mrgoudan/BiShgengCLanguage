} // expected-error {{b's memory will leak at the end of scope}}

void func9(int n) {
    int num = 5;
    int * owned a = (int * owned)&num;
    int * owned b;
    switch (n) {
        case 0: {
            b = a;
            for (int i = 0; i < 10; i++)
                break;
            break;
        }
        case 1: {
            b = a;
            break;
        }
        case 4: {
            b = a;
            for (int i = 0; i < 10; i++)
                break;
        }
        case 5: {
            b = a; // expected-error {{cannot assign b because its type is owned}} expected-error {{a cannot be accessed, because it is uninitialized or moved}}
            break;
        }
        default: {
            break;
        }
    }
} // expected-error {{a's memory will leak at the end of scope}} expected-error {{b's memory will leak at the end of scope}}