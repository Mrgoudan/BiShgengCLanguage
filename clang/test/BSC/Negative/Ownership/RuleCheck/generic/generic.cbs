// %RUN: %clang_cc1 -verify %s

T* owned malloc_owned<T>(T value);
void free_owned<T>(T * owned p);
void free_owned_new(void * owned p);

typedef struct A {
	int * owned a;
} A;

A * owned source(int x) {
	int * owned i = malloc_owned<int>(2);
	A b = { .a = i };
	A * owned p = malloc_owned<A>(b);
	return p;
}

void sink(A * owned p) {
	free_owned(p);
}

void new_sink(A * owned p) {
	free_owned_new((void * owned)p);
}

int main(int argc, char* argv[]) {
	A * owned a = source(2);
	if (argc == 1)	{
		return 0; // expected-error {{a's memory will leak at the end of scope}}
	}
	sink(a);
	return 0;
}
