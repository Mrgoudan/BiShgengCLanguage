typedef Invalid = int *_Owned _Borrow; // expected-error {{cannot combine '_Owned' and '_Borrow' qualifiers on the same type}}


void demo() {
    InvalidPtr p = nullptr;
}
void demo1() {
    Invalid p = nullptr;
}