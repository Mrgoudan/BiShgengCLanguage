typedef Invalid = int *owned _Borrow; // expected-error {{cannot combine 'owned' and '_Borrow' qualifiers on the same type}}


void demo() {
    InvalidPtr p = nullptr;
}
void demo1() {
    Invalid p = nullptr;
}