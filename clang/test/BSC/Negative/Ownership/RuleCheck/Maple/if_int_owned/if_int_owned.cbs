// RUN: %clang_cc1 -verify %s

void free(void * p);

owned long test() {
    long b = 0;
    long owned a;
    a = (long owned)b;
    return a;
}

int main() {
    const long owned a = test();
    if (a != 0) {
        free((void *)(long)a);
        return 1;
    }
    return 0; // expected-error {{a's memory will leak at the end of scope}}
}