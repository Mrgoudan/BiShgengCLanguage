// RUN: %clang_cc1 -verify %s
// expected-no-diagnostics

// Test that _Owned qualifiers are allowed on template type parameters.
// Like C++ const qualifier, both "T _Owned" and "_Owned T" apply _Owned to the complete type T.
//
// When T = int*, both forms produce: int* _Owned (_Owned pointer to int)
// NOT: _Owned int* (pointer to _Owned int)
//
// The _Owned qualifier is applied to whatever type T is instantiated with.
// Validity is checked at instantiation time:
// - If T is instantiated with a pointer type (e.g., int*), then "_Owned T" = "int* _Owned" is valid
// - If T is instantiated with a non-pointer type (e.g., int), semantic errors occur at usage
//
// This follows C++'s behavior where "const T" with T=int* gives "int* const", not "const int*"
_Owned T Func_1<T>(T t)
{
    T _Owned tmp = t;
    return tmp;
}

void consume_owned(int* _Owned p) {
    int* p2 = __move_to_raw(p);
    return;
}

void test() {
    int a = 10;
    int* _Owned p1 = __take_from_raw(&a);
    consume_owned(p1);
    return;
}


void test2() {
    int a = 10;
    int* _Owned p1 = Func_1<int* _Owned>(__take_from_raw(&a));
    consume_owned(p1);
    return;
}

typedef int* _Owned ownedIntPtr;

void test3() {
    int a = 10;
    int* _Owned p1 = Func_1<ownedIntPtr>(__take_from_raw(&a));
    consume_owned(p1);
    return;
}

int main() {
    test();
    test2();
    test3();
    return 0;
}