// RUN: %clang_cc1 -ast-dump -verify %s

int myadd(int* a, int* b) {
    return *a + *b;
}


typedef int (*FTP)(int*);
typedef int (*FTPO)(int* _Owned);

void test() {
    FTP ftp1 = myadd;   
    FTPO ftpo1 = myadd; //expected-error {{cannot cast 'int (int *, int *)' to 'FTPO' (aka 'int (*)(int *_Owned)')}}
}
