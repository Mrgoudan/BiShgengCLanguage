// RUN: %clang_cc1 -verify %s 

_Safe void safe_free(void * _Owned p);

int *_Owned _Nullable init();
void tinker(int *_Borrow);

void call_function_after_free(){
  int *_Owned _Nullable p = init();
  if (p != nullptr) {
    safe_free((void *_Owned) p);
    tinker(&_Mut *p); // expected-error {{use of moved value: `p`}}
  }
}

void use_binary_assignment_operator_after_free() {
  int *_Owned _Nullable p = init();
  if (p != nullptr) {
    safe_free((void *_Owned) p);
    *p += 1; // expected-error {{use of moved value: `p`}}
    *p -= 1; // expected-error {{use of moved value: `p`}}
    *p *= 1; // expected-error {{use of moved value: `p`}}
    *p /= 1; // expected-error {{use of moved value: `p`}}
    *p %= 1; // expected-error {{use of moved value: `p`}}
    *p >>= 1; // expected-error {{use of moved value: `p`}}
    *p <<= 1; // expected-error {{use of moved value: `p`}}
    *p &= 1; // expected-error {{use of moved value: `p`}}
    *p |= 1; // expected-error {{use of moved value: `p`}}
    *p ^= 1; // expected-error {{use of moved value: `p`}}
  }
}

void use_increment_decrement_operator_after_free(){
  int *_Owned _Nullable p = init();
  if (p != nullptr) {
    safe_free((void *_Owned) p);
    ++*p; // expected-error {{use of moved value: `p`}}
    --*p; // expected-error {{use of moved value: `p`}}
    (*p)++; // expected-error {{use of moved value: `p`}}
    (*p)--; // expected-error {{use of moved value: `p`}}
  }
}

typedef struct {
  int value;
} Data;

Data *_Owned _Nullable init_data();
void read_data(Data *_Borrow);

int assign_to_field_after_free() {
  Data *_Owned _Nullable p = init_data();
  if (p != nullptr) {
    read_data(&_Mut *p);
    safe_free((void *_Owned)p);
    p->value += 1; // expected-error {{assign to part of moved value: `p`}}
    p->value -= 1; // expected-error {{assign to part of moved value: `p`}}
    p->value *= 1; // expected-error {{assign to part of moved value: `p`}}
    p->value /= 1; // expected-error {{assign to part of moved value: `p`}}
    p->value %= 1; // expected-error {{assign to part of moved value: `p`}}
    p->value >>=1; // expected-error {{assign to part of moved value: `p`}}
    p->value <<=1; // expected-error {{assign to part of moved value: `p`}}
    p->value &= 1; // expected-error {{assign to part of moved value: `p`}}
    p->value |= 1; // expected-error {{assign to part of moved value: `p`}}
    p->value ^= 1; // expected-error {{assign to part of moved value: `p`}}
    ++p->value; // expected-error {{assign to part of moved value: `p`}}
    --p->value; // expected-error {{assign to part of moved value: `p`}}
    (p->value)++; // expected-error {{assign to part of moved value: `p`}}
    (p->value)--; // expected-error {{assign to part of moved value: `p`}}
    tinker(&_Mut p->value); // expected-error {{use of moved value: `p.value`}}
  }
  _Unsafe {
    return p->value; // expected-error {{use of moved value: `p.value`}}
  }
}
