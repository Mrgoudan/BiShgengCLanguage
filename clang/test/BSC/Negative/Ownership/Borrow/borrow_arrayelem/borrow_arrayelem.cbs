// RUN: %clang_cc1 -ast-dump -verify %s

_Safe void t1(void) {
  int a[10] = {0};
  int * _Borrow _ArrayElem p1 = &_Mut a[0];
  int * _Borrow _ArrayElem p2 = p1 + 3; // expected-note {{`*p1` is borrowed here}}
  p1[1] = 5; // expected-error {{cannot assign to `*p1` because it is borrowed}}
  p2[0] = 5;
}

_Safe void t2(void) {
  int a[10] = {0};
  int * _Borrow _ArrayElem p1 = &_Mut a[0]; // expected-note {{first mut borrow occurs here}}
  int * _Borrow _ArrayElem p2 = &_Mut a[0]; // expected-error {{cannot borrow `a[]` as mutable more than once at a time}}
  p1[1] = 5;
  p2[0] = 5;
}

_Safe void t3(void) {
  int a[10] = {0};
  int * _Borrow _ArrayElem p = &_Mut a[0]; // expected-note {{`a[]` is borrowed here}}
  a[0] = 5; // expected-error {{cannot assign to `a[]` because it is borrowed}}
  p[0] = 5;
}

_Safe int t4(void) {
  int arr[3] = {10, 20, 30};
  int *_Borrow _ArrayElem a = &_Mut arr[0]; // expected-note {{first mut borrow occurs here}}
  a[1] = 99;
  int *_Borrow b = &_Mut arr[1]; // expected-error {{cannot borrow `arr[]` as mutable more than once at a time}}
  *b = 100;
  a[1] = 200;
  return *b + a[1];
}


_Safe void cf_freeze_after_reborrow(void) {
  int a[6] = {0};
  int * _Borrow _ArrayElem p1 = &_Mut a[0];
  int * _Borrow _ArrayElem p2;
  int flag = 1;
  if (flag) {
    p2 = p1 + 2; // expected-note {{`*p1` is borrowed here}}
  } else {
    p2 = p1 + 4;
  }
  *p1 = 1; // expected-error {{cannot assign to `*p1` because it is borrowed}}
  p2[0] = 2;
}

_Safe void cf_direct_write_while_borrowed(void) {
  int a[4] = {0};
  int * _Borrow _ArrayElem p = &_Mut a[0]; // expected-note {{`a[]` is borrowed here}}
  for (int i = 0; i < 4; ++i) {
    if (i == 2)
      a[i] = 9; // expected-error {{cannot assign to `a[]` because it is borrowed}}
    p[i] = i;
  }
}

_Safe void explicit_reborrow_star_p_freeze(void) {
  int a[2] = {0};
  int * _Borrow _ArrayElem p = &_Mut a[0];
  int * _Borrow q = &_Mut *p; // expected-note {{`*p` is borrowed here}}
  *p = 5; // expected-error {{cannot assign to `*p` because it is borrowed}}
  p[1] = 6;
  *q = 7;
}

_Safe void cf_for_freeze(void) {
  int a[6] = {0};
  int * _Borrow _ArrayElem p1 = &_Mut a[0];
  int * _Borrow _ArrayElem p2;
  for (int i = 1; i <= 3; ++i) {
    p2 = p1 + i; // expected-note {{`*p1` is borrowed here}}
  }
  *p1 = 1; // expected-error {{cannot assign to `*p1` because it is borrowed}}
  p2[0] = 2;
}

_Safe void elem_assign_while_frozen(void) {
  int a[3] = {1, 2, 3};
  int * _Borrow _ArrayElem p1 = a;
  int * _Borrow _ArrayElem p2 = p1 + 1; // expected-note {{`*p1` is borrowed here}}
  p1[0] = 5; // expected-error {{cannot assign to `*p1` because it is borrowed}}
  p2[0] = 30;
}

_Safe void star_p_assign_while_frozen(void) {
  int a[2] = {10, 20};
  int * _Borrow _ArrayElem p1 = &_Mut a[0];
  int * _Borrow _ArrayElem p2 = p1 + 1; // expected-note {{`*p1` is borrowed here}}
  *p1 = 11; // expected-error {{cannot assign to `*p1` because it is borrowed}}
  p2[0] = 30;
}

_Safe void subscript_index_borrow_use(void) {
  int dummy = 0;
  int a[4] = {0};
  int * _Borrow _ArrayElem p1 = a;
  int * _Borrow p2 = &_Mut dummy; // expected-note 2 {{`dummy` is borrowed here}}
  dummy += 1; // expected-error {{cannot assign to `dummy` because it is borrowed}} // expected-error {{cannot use `dummy` because it was mutably borrowed}}
  p1[*p2] = 2;
}

_Safe void multi_reborrow_from_frozen_base(void) {
  int a[4] = {0};
  int * _Borrow _ArrayElem p1 = &_Mut a[0];
  int * _Borrow _ArrayElem p2 = p1 + 1; // expected-note {{`*p1` is borrowed here}} // expected-note {{first mut borrow occurs here}}
  int * _Borrow _ArrayElem p3 = p1 + 2; // expected-error {{cannot use `p1` because it was mutably borrowed}} // expected-error {{cannot borrow `*p1` as mutable more than once at a time}}
  p2[0] = 1;
  p3[0] = 2;
}

_Safe void arrayelem_handle_copy_while_reborrowed(void) {
  int a[4] = {0};
  int * _Borrow _ArrayElem p1 = &_Mut a[0];
  int * _Borrow _ArrayElem p2 = p1 + 1; // expected-note {{`*p1` is borrowed here}} // expected-note {{first mut borrow occurs here}}
  int * _Borrow _ArrayElem p3 = p1; // expected-error {{cannot use `p1` because it was mutably borrowed}} // expected-error {{cannot borrow `*p1` as mutable more than once at a time}}
  p2[0] = 1;
  p3[0] = 2;
}

// Arithmetic reborrow must still conflict with an earlier explicit `&_Mut *p1`
// loan. A blanket skip of CheckRead/CheckMutBorrow on arithmetic-reborrow
// assignments would miss this.
_Safe void arithmetic_reborrow_while_star_p_borrowed(void) {
  int a[4] = {0};
  int * _Borrow _ArrayElem p1 = &_Mut a[0];
  int * _Borrow q = &_Mut *p1; // expected-note {{`*p1` is borrowed here}} // expected-note {{first mut borrow occurs here}}
  int * _Borrow _ArrayElem p2 = p1 + 1; // expected-error {{cannot use `p1` because it was mutably borrowed}} // expected-error {{cannot borrow `*p1` as mutable more than once at a time}}
  p2[0] = 1;
  *q = 2;
}
