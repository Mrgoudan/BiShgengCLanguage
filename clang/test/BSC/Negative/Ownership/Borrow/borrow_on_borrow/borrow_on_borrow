// RUN: %clang_cc1 -ast-dump -verify %s
struct R {
   int num;
   int * borrow p1;
};

void test() {
  int a = 1;
  int b = 1;
  int *borrow p1 = &mut a; // legal
  const int *borrow p2 = &const b; // legal
  int *borrow * borrow b1 = &mut p1; // expected-error {{'&mut' on a 'borrow' quialifier type is not allowed}}
  const int *borrow const * borrow b2 = &const p2; // expected-error {{'&const' on a 'borrow' quialifier type is not allowed}}
  int *borrow const * borrow b1 = &const p1; // expected-error {{'&const' on a 'borrow' quialifier type is not allowed}}
  const int * borrow * borrow b1 = &mut p2; // expected-error {{'&mut' on a 'borrow' quialifier type is not allowed}}

  &mut p1; // expected-error {{'&mut' on a 'borrow' quialifier type is not allowed}}
  &const p1; // expected-error {{'&const' on a 'borrow' quialifier type is not allowed}}
  &mut p2; // expected-error {{'&mut' on a 'borrow' quialifier type is not allowed}}
  &const p2; // expected-error {{'&const' on a 'borrow' quialifier type is not allowed}}
  &p1; // legal
  &p2; // legal

  struct R r = { 1, &mut a };
  struct R * borrow pr = &mut r; // expected-error {{'&mut' on a 'borrow' quialifier type is not allowed}}
  const struct R * borrow pr = &const r; // expected-error {{'&const' on a 'borrow' quialifier type is not allowed}}
  &const r.p1; // expected-error {{'&const' on a 'borrow' quialifier type is not allowed}}
  &mut r.p1; // expected-error {{'&mut' on a 'borrow' quialifier type is not allowed}}
}