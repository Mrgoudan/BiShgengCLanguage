// RUN: %clang_cc1 -verify %s

// Test that actual multiple mutable borrows (where we propagate borrow references,
// not just read scalar values) are still correctly rejected.
// This ensures the fix for scalar reads doesn't break legitimate error detection.

typedef struct Data {
  int value;
} DATA_S;

// This should not fail
void test_actual_multiple_borrows() {
  DATA_S data = {42};
  DATA_S *borrow p1 = &mut data;
  DATA_S *borrow p2 = &mut data;
}

// This should fail: using both borrows simultaneously
void use_two_mut_borrows(DATA_S *borrow a, DATA_S *borrow b) {
  a->value = 1;
  b->value = 2;
}

void test_simultaneous_use() {
  DATA_S data = {42};
  use_two_mut_borrows(&mut data, &mut data); // expected-error {{cannot borrow `data` as mutable more than once at a time}}
                                               // expected-note@-1 {{first mut borrow occurs here}}
}

// This should fail: keeping borrow alive while creating another
void test_overlapping_lifetimes() {
  DATA_S data = {42};
  DATA_S *borrow p1 = &mut data; // expected-note {{first mut borrow occurs here}}
  DATA_S *borrow p2 = &mut data; // expected-error {{cannot borrow `data` as mutable more than once at a time}}
  p1->value = 10;
  p2->value = 20;
}
