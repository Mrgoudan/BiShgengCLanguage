// RUN: %clang_cc1 -xbsc -fsyntax-only -verify %s

struct Simple {
    int *_Borrow p;
};

struct Pair<T, U> {
    T *_Owned first;
    U *_Borrow second;
};

struct Container<T> {
    T element;
};

struct Nested {
    struct Simple s;
};

void test_crash() {
    struct Simple s; // expected-error {{variable declarations of _Borrow qualified must be initialized}}
    struct Pair<int, char> p; // expected-error {{variable declarations of _Borrow qualified must be initialized}}
    struct Nested n; // expected-error {{variable declarations of _Borrow qualified must be initialized}}
    struct Container<struct Simple> c; // expected-error {{variable declarations of _Borrow qualified must be initialized}}
    struct Container<struct Pair<int, int>> cp; // expected-error {{variable declarations of _Borrow qualified must be initialized}}
}