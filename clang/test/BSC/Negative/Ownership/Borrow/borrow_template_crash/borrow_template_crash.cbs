// RUN: %clang_cc1 -xbsc -fsyntax-only -verify %s
// expected-no-diagnostics

struct Simple {
    int *_Borrow p;
};

struct Pair<T, U> {
    T *_Owned first;
    U *_Borrow second;
};

struct Container<T> {
    T element;
};

struct Nested {
    struct Simple s;
};

void test_crash() {
    struct Simple s;
    struct Pair<int, char> p;
    struct Nested n;
    struct Container<struct Simple> c;
    struct Container<struct Pair<int, int>> cp;
}