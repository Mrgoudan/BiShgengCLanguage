// RUN: %clang_cc1 -verify %s

trait T {
  static int f(This* this);
};

int int::f(int* this) {
  return *this;
}

impl trait T for int;

int main() {
  int a = 1;
  int* t = &a;
  trait T* borrow p = &mut *t; // expected-note {{previous borrow is here}}
  a = 2;
  t = &a; // expected-error {{Can not modify 't' because be borrowed}}
  p->f();
  return 0;
}