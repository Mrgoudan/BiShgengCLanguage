// RUN: %clang_cc1 -fsyntax-only -verify %s

union U {};
struct S1;  // expected-note{{forward declaration of 'struct S1'}}
struct S2 { struct S1 s1; };  // expected-error{{field has incomplete type 'struct S1'}}
struct S3 { struct S2 s2; };
struct S1 { struct S3 s3; union U u; };

struct S4;  // expected-note{{forward declaration of 'struct S4'}}
struct S5 { struct S4 s4; }; // expected-error{{field has incomplete type 'struct S4'}}
struct S4 { struct S5 s5; };  

_Safe struct S1 unsafeReturnFunc(void) {} 

_Safe void unsafeParamFunc(struct S1 s1) {} 

_Safe struct S4 safeReturnFunc(void) {}

_Safe void safeParamFunc(struct S4 s4) {}