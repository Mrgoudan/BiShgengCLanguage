// RUN: %clang_cc1 -ast-dump -verify %s

_Safe void read_by_value(int);
_Safe void read_by_borrow(const int *_Borrow);

_Safe void non_lexical_lifetime(int x) {
    int *_Borrow ref = &_Mut x;
    const int *_Borrow cref = ref; // expected-note {{`*ref` is borrowed here}}
    ++*ref; // expected-error {{cannot assign to `*ref` because it is borrowed}}
    read_by_value(*cref); 
}

_Safe void non_lexical_lifetime_limitation(int x) {
    int *_Borrow ref = &_Mut x; // expected-note {{`x` is borrowed here}}
    // explicitly define an immutable reference
    const int *_Borrow cref = ref;
    // ref does not expire here, even without any modification
    read_by_value(x); // expected-error {{cannot use `x` because it was mutably borrowed}}
    read_by_value(*cref);
}

// re-_Borrow in function arguments
_Safe void accept_immutable(const int *_Borrow); // expected-note 2 {{passing argument to parameter here}}
_Safe void accept_mutable(int *_Borrow); // expected-note 3 {{passing argument to parameter here}}

// re-_Borrow when return value
_Safe int *ret_raw(void);
_Safe const int *_Borrow ret_immutable(const int *_Borrow);
_Safe int *_Owned ret_own(void);

_Safe void raw2immutable(int *ptr) {
    const int *_Borrow cref = ptr; // expected-error {{conversion from type 'int *' to 'const int *_Borrow' is forbidden in the safe zone}}
    accept_immutable(ptr); // expected-error {{conversion from type 'int *' to 'const int *_Borrow' is forbidden in the safe zone}}
    const int *_Borrow cref2 = ret_raw(); // expected-error {{conversion from type 'int *' to 'const int *_Borrow' is forbidden in the safe zone}}
}

_Safe int *_Owned own2immutable(int *_Owned ptr) {
    const int *_Borrow cref = ptr; // expected-error {{conversion from type 'int *_Owned' to 'const int *_Borrow' is forbidden in the safe zone}}
    accept_immutable(ptr); // expected-error {{conversion from type 'int *_Owned' to 'const int *_Borrow' is forbidden in the safe zone}}
    const int *_Borrow cref2 = ret_own(); // expected-error {{conversion from type 'int *_Owned' to 'const int *_Borrow' is forbidden in the safe zone}}
    return ptr;
}

_Safe void immutable2mutable(const int *_Borrow cref) {
    int *_Borrow ref = cref; // expected-error {{conversion from type 'const int *_Borrow' to 'int *_Borrow' is forbidden in the safe zone}}
    accept_mutable(cref); // expected-error {{conversion from type 'const int *_Borrow' to 'int *_Borrow' is forbidden in the safe zone}}
    int dummy = 0;
    int *_Borrow ref2 = ret_immutable(&_Const dummy); // expected-error {{conversion from type 'const int *_Borrow' to 'int *_Borrow' is forbidden in the safe zone}}
}

_Safe void raw2mutable(int *ptr) {
    int *_Borrow ref = ptr; // expected-error {{conversion from type 'int *' to 'int *_Borrow' is forbidden in the safe zone}}
    accept_mutable(ptr); // expected-error {{conversion from type 'int *' to 'int *_Borrow' is forbidden in the safe zone}}
    int *_Borrow ref2 = ret_raw(); // expected-error {{conversion from type 'int *' to 'int *_Borrow' is forbidden in the safe zone}}
}

_Safe int *_Owned own2mutable(int *_Owned ptr) {
    int *_Borrow ref = ptr; // expected-error {{conversion from type 'int *_Owned' to 'int *_Borrow' is forbidden in the safe zone}}
    accept_mutable(ptr); // expected-error {{conversion from type 'int *_Owned' to 'int *_Borrow' is forbidden in the safe zone}}
    int *_Borrow ref2 = ret_own(); // expected-error {{conversion from type 'int *_Owned' to 'int *_Borrow' is forbidden in the safe zone}}
    return ptr;
}
