// RUN: %clang_cc1 -fsyntax-only -verify %s

int main(void) {
  int a = 0;
  int *b = &a;
  _Safe {
    ++a;          // ok: ++ on integers is allowed
    --a;          // ok: -- on integers is allowed
    int c = *b;   // expected-error {{'*' operator is forbidden in the safe zone}}
    int d = b[0];
    int x = 0;
    const int *_Borrow cb = &_Const x;
    int y = *cb;
    int *_Borrow mb = &_Mut x; // expected-note {{pointer 'mb' declared here}}
    int z = ++*mb; // expected-error {{conversion from type 'void' to 'int' is forbidden in the safe zone}} expected-note {{prefix/postfix '++' and '--' in safe zone produce void; use only for side effect}}
    int w = *mb++; // expected-error {{'++' is not supported on 'int *_Borrow'}} expected-note {{declare 'mb' as a raw pointer for pointer arithmetic}}
    int *_Borrow plain_iv = &_Mut x; // expected-note {{pointer 'plain_iv' declared here}}
    ++plain_iv; // expected-error {{'++' is not supported on 'int *_Borrow'}} expected-note {{declare 'plain_iv' as a raw pointer for pointer arithmetic}}
    int pair[2] = {3, 4};
    int *_Borrow _ArrayElem ap = &_Mut pair[0];
    ++ap;
    ap--;
    int * p = &x; // expected-error {{'&' operator is forbidden in the safe zone}}
  }
  return 0;
}