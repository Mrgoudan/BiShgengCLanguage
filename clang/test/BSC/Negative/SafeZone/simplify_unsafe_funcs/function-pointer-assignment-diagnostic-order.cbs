// RUN: %clang_cc1 -fsyntax-only -verify -x bsc %s

_Safe void take_owned(int * _Owned p);
_Safe void take_borrow(char * _Borrow p);

void test_owned_diag_order(void) {
  _Safe void (*dst)(int * _Borrow) = 0;
  dst = take_owned; // expected-warning {{incompatible function pointer types assigning to '_Safe void (*)(int *_Borrow)' from '_Safe void (int *_Owned)'}}
}

void test_borrow_diag_order(void) {
  _Safe void (*dst)(const char * _Borrow) = 0;
  dst = take_borrow; // expected-warning {{incompatible function pointer types assigning to '_Safe void (*)(const char *_Borrow)' from '_Safe void (char *_Borrow)'}}
}
