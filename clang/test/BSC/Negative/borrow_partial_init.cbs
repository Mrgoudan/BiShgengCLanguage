// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

// Test cases for _Borrow-qualified field initialization requirements
// Borrow-qualified fields must always be initialized

struct SimpleBorrow {
    int *_Borrow p;
};

void test_simple_borrow() {
    int x = 0;

    struct SimpleBorrow s1;

    struct SimpleBorrow s2 = {};

    // OK: fully initialized
    struct SimpleBorrow s3 = {.p = &_Mut x};

    // OK: positional initialization
    struct SimpleBorrow s4 = {&_Mut x};
}

struct Inner {
    int *_Borrow p;
};

struct Outer {
    int a;
    struct Inner inner;
};

void test_nested_borrow() {
    int x = 0;

    struct Outer o1;

    struct Outer o2 = {.a = 0};

    struct Outer o3 = {0};

    struct Outer o4 = {.a = 1, .inner = {}};

    // OK: fully initialized
    struct Outer o5 = {.a = 0, .inner = {.p = &_Mut x}};

    // OK: positional initialization
    struct Outer o6 = {0, {&_Mut x}};
}

struct Level3 {
    int *_Borrow p;
};

struct Level2 {
    int b;
    struct Level3 l3;
};

struct Level1 {
    int a;
    struct Level2 l2;
};

void test_deep_nesting() {
    int x = 0;

    struct Level1 v1;

    struct Level1 v2 = {.a = 0};

    struct Level1 v3 = {.a = 0, .l2 = {.b = 1}};

    struct Level1 v4 = {0, {0}};

    struct Level1 v5 = {0, {0, {}}};

    // OK: fully initialized
    struct Level1 v6 = {.a = 0, .l2 = {.b = 1, .l3 = {.p = &_Mut x}}};

    // OK: positional initialization
    struct Level1 v7 = {0, {1, {&_Mut x}}};
}

struct MultipleBorrow {
    int *_Borrow p1;
    int *_Borrow p2;
    int regular;
};

void test_multiple_borrow() {
    int x = 0, y = 0;

    struct MultipleBorrow m1;

    struct MultipleBorrow m2 = {.p1 = &_Mut x};

    struct MultipleBorrow m3 = {.p1 = &_Mut x, .regular = 0};

    // OK: all _Borrow fields initialized
    struct MultipleBorrow m4 = {.p1 = &_Mut x, .p2 = &_Mut y};

    // OK: all fields initialized
    struct MultipleBorrow m5 = {.p1 = &_Mut x, .p2 = &_Mut y, .regular = 0};

    // OK: positional
    struct MultipleBorrow m6 = {&_Mut x, &_Mut y, 0};

    struct MultipleBorrow m7 = {.regular = 0};
}

struct ConstBorrow {
    const int *_Borrow p;
};

void test_const_borrow() {
    int x = 0;

    struct ConstBorrow c1;

    struct ConstBorrow c2 = {};

    // OK: initialized with const _Borrow
    struct ConstBorrow c3 = {.p = &_Const x};
}


struct Mixed {
    int a;
    int *_Borrow p;
    int b;
};

void test_mixed() {
    int x = 0;

    struct Mixed m1;

    struct Mixed m2 = {.a = 1};

    struct Mixed m3 = {.a = 1, .b = 2};

    // OK: _Borrow field initialized
    struct Mixed m5 = {.a = 1, .p = &_Mut x};

    // OK: all fields initialized
    struct Mixed m6 = {.a = 1, .p = &_Mut x, .b = 2};

    // OK: positional with _Borrow
    struct Mixed m7 = {1, &_Mut x, 2};
}

struct ArrayTest {
    int *_Borrow p;
};

void test_array() {
    int x = 0, y = 0;

    // Arrays with _Borrow-qualified struct elements
    // Each element must have its _Borrow fields initialized

    // OK: all elements fully initialized
    struct ArrayTest arr4[2] = {{&_Mut x}, {&_Mut y}};
}

struct Complex {
    int *_Borrow p1;
    struct {
        int *_Borrow p2;
        int data;
    } nested;
    int *_Borrow p3;
};

void test_complex() {
    int x = 0, y = 0, z = 0;

    struct Complex c1;

    struct Complex c2 = {.p1 = &_Mut x};

    struct Complex c3 = {.p1 = &_Mut x, .p3 = &_Mut z};

    struct Complex c4 = {.p1 = &_Mut x, .nested = {.data = 0}};

    // OK: all _Borrow fields initialized
    struct Complex c5 = {.p1 = &_Mut x, .nested = {.p2 = &_Mut y}, .p3 = &_Mut z};

    // OK: with data field too
    struct Complex c6 = {.p1 = &_Mut x, .nested = {.p2 = &_Mut y, .data = 0}, .p3 = &_Mut z};
}
