// RUN: %clang_cc1 -fsyntax-only -verify %s

_Trait F {
  int foo(This* this);
};

int get(_Trait F* f) {
  return 1;
};

int int::foo(int* this) {
  return 0;
}

_Impl _Trait F for int;

int main() {
  int a = 1;
  int b = get(a); // expected-error {{expected a pointer type which has implemented '_Trait F', found 'int'}}
                  // TODO:
  return 0;
}
