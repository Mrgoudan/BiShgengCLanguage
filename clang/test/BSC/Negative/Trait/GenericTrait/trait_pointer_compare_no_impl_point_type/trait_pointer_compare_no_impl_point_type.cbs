// RUN: %clang_cc1 -fsyntax-only -verify %s

_Trait Future<T> {
    T poll(This* this);
};

int int::poll(int* this) {
    return *this;
}

_Impl _Trait Future<int> for int;

int main() {
    int a = 1;
    _Trait Future<int> *f = &a;
    double b = 1.0;
    double *x = &b;
    if (x == f) {  // expected-warning {{expected a pointer type which has implemented '_Trait Future<int>', found 'double *'}}
        return 1;
    }
   
    return 0;
}
