// RUN: %clang_cc1 -verify %s
// Using `&_Const` or `&_Mut` to convert a raw ptr to _Borrow ptr is disallowed

_Safe void explicit_reborrow(int* ptr) {
    const int *_Borrow _Nullable cbp = &_Const *ptr; // expected-error {{'*' operator is forbidden in the safe zone}}
    int *_Borrow _Nullable mbp = &_Mut *ptr; // expected-error {{'*' operator is forbidden in the safe zone}}
}

void explicit_reborrow2(void) {
    int *ptr = nullptr;
    _Safe {
        const int *_Borrow _Nullable cbp = &_Const *ptr; // expected-error {{'*' operator is forbidden in the safe zone}}
        int *_Borrow _Nullable mbp = &_Mut *ptr; // expected-error {{'*' operator is forbidden in the safe zone}}
    }
}
