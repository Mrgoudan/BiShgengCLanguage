// RUN: %clang_cc1 -fsyntax-only -verify %s

// Test __assume_initialized: negative cases — use before call,
// use on wrong path. Only allowed in _Unsafe zones.

_Safe void use_int(int x);

struct Pair { int a; int b; };
_Safe void use_pair(struct Pair p);

// Use before call → error.
_Safe void test_use_before(void) {
    int x;
    use_int(x); // expected-error {{use of uninitialized value: `x`}}
    _Unsafe { __assume_initialized(&x); }
}

// Use on wrong path: builtin only on one branch → error at merge.
_Safe void test_branch_one(int cond) {
    int x;
    if (cond) {
        _Unsafe { __assume_initialized(&x); }
    }
    use_int(x); // expected-error {{use of possibly uninitialized value: `x`}}
}

// Without the builtin: the error fires as usual.
_Safe void test_no_builtin(void) {
    int y;
    use_int(y); // expected-error {{use of uninitialized value: `y`}}
}

// Struct without builtin → error.
_Safe void test_struct_no_builtin(void) {
    struct Pair s;
    use_pair(s); // expected-error {{use of uninitialized value: `s`}}
}

// Array: decay (no &) doesn't mark as initialized.
_Safe void test_array_decay(void) {
    int arr[3];
    _Unsafe { __assume_initialized(arr); } // expected-error {{__assume_initialized requires '&' expression as argument}}
    use_int(arr[0]);
}

// --- Array-subscript rejection ---------------------------------------------
// The init analysis tracks state at (local, [FieldIndex...]) granularity —
// it cannot represent "element i of some array". Any array subscript in the
// address-of path is rejected; users must assert the enclosing array whole.

struct Sub { int a[2]; };
struct Outer { struct Sub s[2]; };
struct WithArr { int arr[3]; };

// Subscript on a plain array: reject.
_Safe void test_reject_arr_element(void) {
    int arr[3];
    _Unsafe { __assume_initialized(&arr[0]); } // expected-error {{__assume_initialized argument cannot contain an array subscript}} expected-note {{the init analysis tracks arrays as whole units}}
}

// Subscript on a struct's array field: reject.
_Safe void test_reject_field_element(void) {
    struct WithArr w;
    _Unsafe { __assume_initialized(&w.arr[0]); } // expected-error {{__assume_initialized argument cannot contain an array subscript}} expected-note {{the init analysis tracks arrays as whole units}}
}

// Subscript in the middle of the path: reject even though leaf is a Field
// (the path segment "s[0].a" is not representable).
_Safe void test_reject_mid_subscript(void) {
    struct Outer ss1;
    _Unsafe { __assume_initialized(&ss1.s[0].a); } // expected-error {{__assume_initialized argument cannot contain an array subscript}} expected-note {{the init analysis tracks arrays as whole units}}
}

// Two subscripts deep: reject.
_Safe void test_reject_two_subscripts(void) {
    struct Outer ss1;
    _Unsafe { __assume_initialized(&ss1.s[0].a[0]); } // expected-error {{__assume_initialized argument cannot contain an array subscript}} expected-note {{the init analysis tracks arrays as whole units}}
}

// Subscript through an ensure_init pointer: reject (same rule).
_Safe void test_reject_ensure_init_subscript(
    struct WithArr *__attribute__((ensure_init)) out) {
    _Unsafe { __assume_initialized(&out->arr[0]); } // expected-error {{__assume_initialized argument cannot contain an array subscript}} expected-note {{the init analysis tracks arrays as whole units}}
}

// --- Non-addressing-path rejection -----------------------------------------
// The argument must be a static addressing path: '&' applied to a chain of
// member accesses (.f / ->f) and dereferences (*p) rooted at a DeclRefExpr.
// __assume_initialized is a pure analyzer hint and codegen emits nothing, so
// any other expression shape (call, ternary, compound literal, ++, comma,
// ...) would be silently dropped at runtime.

struct Inner { int x; };
struct Inner *side_effect(void);

// Function call in the address-of path: reject.
_Safe void test_reject_call(void) {
    _Unsafe { __assume_initialized(&side_effect()->x); } // expected-error {{unsupported __assume_initialized argument}} expected-note {{the argument must be '&' applied to a variable}}
}

// Pre/post-increment in the address-of path: reject.
_Safe void test_reject_increment(struct Inner *__attribute__((ensure_init)) p) {
    _Unsafe { __assume_initialized(&(++p)->x); } // expected-error {{unsupported __assume_initialized argument}} expected-note {{the argument must be '&' applied to a variable}}
}

// Comma expression in the address-of path: reject.
_Safe void test_reject_comma(struct Inner *__attribute__((ensure_init)) q) {
    _Unsafe { __assume_initialized(&(side_effect(), q)->x); } // expected-error {{unsupported __assume_initialized argument}} expected-note {{the argument must be '&' applied to a variable}}
}

// Ternary selecting between two pointers: still rejected (no side effect, but
// not a static addressing path the analyzer can lower to a single Place).
_Safe void test_reject_ternary(int cond,
                                struct Inner *__attribute__((ensure_init)) p,
                                struct Inner *__attribute__((ensure_init)) q) {
    _Unsafe { __assume_initialized(&(cond ? p : q)->x); } // expected-error {{unsupported __assume_initialized argument}} expected-note {{the argument must be '&' applied to a variable}}
}

// Compound literal: addressable and side-effect-free, but not rooted at a
// named local — reject.
_Safe void test_reject_compound_literal(void) {
    _Unsafe { __assume_initialized(&((struct Inner){0}).x); } // expected-error {{unsupported __assume_initialized argument}} expected-note {{the argument must be '&' applied to a variable}}
}
