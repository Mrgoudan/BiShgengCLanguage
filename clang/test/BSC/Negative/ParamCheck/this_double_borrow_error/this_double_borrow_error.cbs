// RUN: %clang_cc1 -fsyntax-only -verify %s

#include <float.h>
#include <limits.h>

_Owned struct S {
    double *_Borrow a3; // contain _Borrow 
_Public:
    int a1;
    char a2;

    // Case 1: *_Borrow this
    int foo(const S *_Borrow this, int b1, char b2, double *_Borrow b3) { // expected-error {{type of 'const _Owned struct S' cannot be qualified by '_Borrow'(even indirectly), 'const _Owned struct S' contains '_Borrow' type}}
        if(this->a1 == b1 && this->a2 == b2 && *this->a3 == *b3) {
            return 0;
        }
        return 1;
    }

    // Case 2: * this
    int bar(const S * this) {
        return 0;
    }
};

int main() {
    return 0;
}