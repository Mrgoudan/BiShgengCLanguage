// RUN: %clang_cc1 -verify %s

_Owned struct A {
    int a = 0; // expected-error {{expected ';' at end of declaration list}}
};

_Owned struct B {
    static int a = 0; // expected-error {{expected ';' at end of declaration list}}
};

_Owned struct C {
    int a() = 0; // expected-error {{expected ';' at end of declaration list}}
};

_Owned struct D {
    int a{0}; // expected-error {{function definition does not declare parameters}}
};

_Owned struct E {
    E(); // expected-error {{expected member name or ';' after declaration specifiers}}
};
