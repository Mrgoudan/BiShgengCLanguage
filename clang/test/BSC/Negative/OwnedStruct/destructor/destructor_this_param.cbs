// RUN: %clang_cc1 -verify %s

_Owned struct A;
int f(A this);
_Owned struct A {  
  ~A(A this){
    f(this); // expected-error {{'this' cannot be moved in destructor}}
  }
};                       
int f(A this){ A a = this ;return 1;} 
                  
_Owned struct B {  
  _Public:
  ~B(B this){
    B a = this; // expected-error {{'this' cannot be moved in destructor}}
  }
};  
    