// RUN: %clang_cc1 -verify %s

 _Owned struct A {
  _Public:
   int a;
};

int foo(int x) {
    return x;
}
int main() {
   A a ={.a=1};
   a.a+=2;
   a.a = 3;
   foo(a.a);
   return foo(a.a);     // expected-error {{memory leak because temporary variable 'a' is _Owned or indirect _Owned type, please fix it}}
}
