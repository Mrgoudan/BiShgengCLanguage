// RUN: %clang_cc1  -verify %s

struct S<T> {};
void S<int>::foo(This* this) {}  // expected-error {{extended type of a BSC member function cannot be an instantiated type}}

_Trait F {};
_Impl _Trait F for S<T>; // expected-error {{use of undeclared identifier 'T'}}
_Impl _Trait F for S<int>; // expected-error {{cannot _Impl _Trait for an instantiated type}}

void struct S<T>::foo1(This* this) {} // expected-note {{previous definition is here}}

void S<T>::foo1(This* this) {} // expected-error {{redefinition of 'foo1'}}