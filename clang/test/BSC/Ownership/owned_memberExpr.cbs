// RUN: %clang_cc1 -ast-dump -verify %s
// expected-no-diagnostics

struct Base {
    int num;
};

struct A {
    int b;
    owned int* c;
    owned struct Base base;
};

int owned foo(owned int* a) {
    int owned x = 10;
    return x;
}

void test2() {
    struct A owned a;
    int res = a.b;                  //unlike const, a.b's QualType is int(not owned int)
    owned int res2 = foo(a.c);      //a.c's QualType is owned int*(not owned int* owned)
    int res3 = a.base.num;
}