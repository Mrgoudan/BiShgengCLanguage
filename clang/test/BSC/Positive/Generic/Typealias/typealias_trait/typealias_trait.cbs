// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics
trait F {
    int foo(This* this);
};
typedef MyF = trait F;

int int::foo(This* this) {
    return *this;
}
impl MyF for int;

int main() {
    int a = 5;
    MyF* f = &a;
    f->foo();
    return 0;
}