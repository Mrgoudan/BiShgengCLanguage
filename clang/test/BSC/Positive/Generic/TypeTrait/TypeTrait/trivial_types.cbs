// RUN: %clang %s -g -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include "bsc_type_traits.hbs"
#include "complex_structs.hbs"

int test_is_trivial_data() {
    _Static_assert(is_trivial_data<void>() == false, "fail");
    _Static_assert(is_trivial_data<void *>() == false, "fail");
    _Static_assert(is_trivial_data<int>() == true, "fail");
    _Static_assert(is_trivial_data<int *>() == false, "fail");
    _Static_assert(is_trivial_data<int *_Owned>() == false, "fail");
    _Static_assert(is_trivial_data<const void *_Borrow>() == false, "fail");
    _Static_assert(is_trivial_data<void *_Borrow>() == false, "fail");
    _Static_assert(is_trivial_data<int *_Borrow>() == false, "fail");

    _Static_assert(is_trivial_data<MyInt>() == true, "fail");
    _Static_assert(is_trivial_data<Arr1>() == true, "fail");
    _Static_assert(is_trivial_data<Arr2>() == true, "fail");
    _Static_assert(is_trivial_data<SEmpty>() == true, "fail");
    _Static_assert(is_trivial_data<SInt>() == true, "fail");
    _Static_assert(is_trivial_data<OSInt>() == false, "fail");
    _Static_assert(is_trivial_data<SOInt>() == false, "fail");
    _Static_assert(is_trivial_data<SOSInt>() == false, "fail");
    _Static_assert(is_trivial_data<SSOInt>() == false, "fail");
    _Static_assert(is_trivial_data<SOSOInt>() == false, "fail");
    _Static_assert(is_trivial_data<SDupSInt>() == true, "fail");
    _Static_assert(is_trivial_data<SSInt>() == true, "fail");
    _Static_assert(is_trivial_data<SInt[]>() == true, "fail");
    _Static_assert(is_trivial_data<SInt[3]>() == true, "fail");
    _Static_assert(is_trivial_data<OwnedInt>() == false, "fail");
    _Static_assert(is_trivial_data<MutBorrowInt>() == false, "fail");
    _Static_assert(is_trivial_data<ImmutBorrowInt>() == false, "fail");
    _Static_assert(is_trivial_data<ArrB1>() == false, "fail");
    _Static_assert(is_trivial_data<ArrB2>() == false, "fail");
    _Static_assert(is_trivial_data<Ano>() == true, "fail");
    _Static_assert(is_trivial_data<Enum>() == true, "fail");
    _Static_assert(is_trivial_data<Union>() == true, "fail");

    _Static_assert(is_trivial_data<struct TS<int>>() == true, "fail");
    _Static_assert(is_trivial_data<struct TS<int*>>() == false, "fail");

    _Static_assert(is_trivial_data<XS>() == true, "fail");
    _Static_assert(is_trivial_data<XS0>() == true, "fail");
    _Static_assert(is_trivial_data<XS12>() == true, "fail");
    _Static_assert(is_trivial_data<XO0>() == false, "fail");
    _Static_assert(is_trivial_data<XO12>() == false, "fail");
    _Static_assert(is_trivial_data<XSP0>() == false, "fail");
    _Static_assert(is_trivial_data<XSP12>() == false, "fail");
    _Static_assert(is_trivial_data<XSO0>() == false, "fail");
    _Static_assert(is_trivial_data<XSO12>() == false, "fail");
    _Static_assert(is_trivial_data<SMix>() == false, "fail");
    return 0;
}

int main() {
    test_is_trivial_data();
    return 0;
}
