// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include "bsc_type_traits.hbs"
#include "complex_structs.hbs"

int test_is_move_semantic() {
    _Static_assert(is_move_semantic<void>() == false, "fail");
    _Static_assert(is_move_semantic<void *>() == false, "fail");
    _Static_assert(is_move_semantic<int>() == false, "fail");
    _Static_assert(is_move_semantic<int *>() == false, "fail");
    _Static_assert(is_move_semantic<int *_Owned>() == true, "fail");
    _Static_assert(is_move_semantic<const void *_Borrow>() == false, "fail");
    _Static_assert(is_move_semantic<void *_Borrow>() == false, "fail");
    _Static_assert(is_move_semantic<int *_Borrow>() == false, "fail");

    _Static_assert(is_move_semantic<MyInt>() == false, "fail");
    _Static_assert(is_move_semantic<Arr1>() == false, "fail");
    _Static_assert(is_move_semantic<Arr2>() == false, "fail");
    _Static_assert(is_move_semantic<SEmpty>() == false, "fail");
    _Static_assert(is_move_semantic<SInt>() == false, "fail");
    _Static_assert(is_move_semantic<OSInt>() == true, "fail");
    _Static_assert(is_move_semantic<SOInt>() == true, "fail");
    _Static_assert(is_move_semantic<SOSInt>() == true, "fail");
    _Static_assert(is_move_semantic<SSOInt>() == true, "fail");
    _Static_assert(is_move_semantic<SOSOInt>() == true, "fail");
    _Static_assert(is_move_semantic<SDupSInt>() == false, "fail");
    _Static_assert(is_move_semantic<SSInt>() == false, "fail");
    _Static_assert(is_move_semantic<SInt[]>() == false, "fail");
    _Static_assert(is_move_semantic<SInt[3]>() == false, "fail");
    _Static_assert(is_move_semantic<OwnedInt>() == true, "fail");
    _Static_assert(is_move_semantic<MutBorrowInt>() == false, "fail");
    _Static_assert(is_move_semantic<ImmutBorrowInt>() == false, "fail");
    _Static_assert(is_move_semantic<ArrB1>() == false, "fail");
    _Static_assert(is_move_semantic<ArrB2>() == false, "fail");
    _Static_assert(is_move_semantic<Ano>() == false, "fail");
    _Static_assert(is_move_semantic<Enum>() == false, "fail");
    _Static_assert(is_move_semantic<Union>() == false, "fail");

    _Static_assert(is_move_semantic<struct TS<int>>() == false, "fail");
    _Static_assert(is_move_semantic<struct TS<int*>>() == false, "fail");

    _Static_assert(is_move_semantic<XS>() == false, "fail");
    _Static_assert(is_move_semantic<XS0>() == false, "fail");
    _Static_assert(is_move_semantic<XS12>() == false, "fail");
    _Static_assert(is_move_semantic<XO0>() == true, "fail");
    _Static_assert(is_move_semantic<XO12>() == true, "fail");
    _Static_assert(is_move_semantic<XSP0>() == false, "fail");
    _Static_assert(is_move_semantic<XSP12>() == false, "fail");
    _Static_assert(is_move_semantic<XSO0>() == true, "fail");
    _Static_assert(is_move_semantic<XSO12>() == true, "fail");
    _Static_assert(is_move_semantic<SMix>() == true, "fail");

    return 0;
}

int main() {
    test_is_move_semantic();
    return 0;
}
