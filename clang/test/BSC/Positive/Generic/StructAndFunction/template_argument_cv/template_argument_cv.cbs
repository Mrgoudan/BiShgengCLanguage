// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

struct S1 { };
typedef struct S1 S;

void const_generic_test<T>(void) {
  _Static_assert(__is_same(T, const S) == 1, "fail");
}

void volatile_generic_test<T>(void) {
  _Static_assert(__is_same(T, volatile S) == 1, "fail");
}

int main() {
  const_generic_test<const S>();
  volatile_generic_test<volatile S>();
  return 0;
}
