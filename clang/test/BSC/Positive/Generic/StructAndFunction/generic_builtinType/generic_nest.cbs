// CHECK-NEXT:     conversion_longlong_long(a2, a1);
// CHECK-NEXT:     conversion_long_longdouble(a1, a4);
// CHECK-NEXT:     conversion_longlong_double(a2, a3);
// CHECK-NEXT:     conversion_unsignedlong_longdouble(a5, a4);
// CHECK-NEXT:     conversion_unsignedlonglong_double(a6, a3);
// CHECK-NEXT:     conversion_const_int_int(1, 2);
// CHECK-NEXT:     conversion_int_const_int(1, 2);
// CHECK-NEXT: }
