// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

// Test that _Borrow qualifier on template type parameters is allowed
// The _Borrow validation should be deferred until template instantiation

_Safe T2 _Borrow cast<T1, T2>(T1 _Borrow p) {
  return _Unsafe((T2 _Borrow)(T2)(T1)p);
}

void foo(int *_Borrow p) {
  int *_Borrow q = cast<int *, int *>(p);
}

// Test with function returning _Borrow-qualified template type
_Safe T _Borrow identity<T>(T _Borrow p) {
  return p;
}

// Test with multiple template parameters
_Safe T2 _Borrow convert<T1, T2, T3>(T1 _Borrow a, T3 _Borrow b) {
  return _Unsafe((T2 _Borrow)(T2)(T1)a);
}

_Safe int main(void) {
  int x = 42;
  int * _Borrow ptr = &_Mut x;

  // Test cast function - T1 and T2 are int*, _Borrow is added by function signature
  int *_Borrow p1 = cast<int *, int *>(ptr);
  if (*p1 != 42) {
    return 1;
  }

  // Test identity function - T is int*, _Borrow is added by function signature
  int *_Borrow p2 = identity<int *>(ptr);
  if (*p2 != 42) {
    return 2;
  }

  // Test convert function - template params are int*, _Borrow is added by function signature
  int *_Borrow p3 = convert<int *, int *, int *>(ptr, ptr);
  if (*p3 != 42) {
    return 3;
  }

  return 0;
}
