// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

// Test that borrow qualifier on template type parameters is allowed
// The borrow validation should be deferred until template instantiation

_Safe T2 borrow cast<T1, T2>(T1 borrow p) {
  return _Unsafe((T2 borrow)(T2)(T1)p);
}

void foo(int *borrow p) {
  int *borrow q = cast<int *, int *>(p);
}

// Test with function returning borrow-qualified template type
_Safe T borrow identity<T>(T borrow p) {
  return p;
}

// Test with multiple template parameters
_Safe T2 borrow convert<T1, T2, T3>(T1 borrow a, T3 borrow b) {
  return _Unsafe((T2 borrow)(T2)(T1)a);
}

_Safe int main(void) {
  int x = 42;
  int * borrow ptr = &mut x;

  // Test cast function - T1 and T2 are int*, borrow is added by function signature
  int *borrow p1 = cast<int *, int *>(ptr);
  if (*p1 != 42) {
    return 1;
  }

  // Test identity function - T is int*, borrow is added by function signature
  int *borrow p2 = identity<int *>(ptr);
  if (*p2 != 42) {
    return 2;
  }

  // Test convert function - template params are int*, borrow is added by function signature
  int *borrow p3 = convert<int *, int *, int *>(ptr, ptr);
  if (*p3 != 42) {
    return 3;
  }

  return 0;
}
