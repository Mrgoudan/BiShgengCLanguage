// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %S/../../../../../../../lib/Headers/bsc_include/future.hbs -o %T/future.h
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include "future.hbs"
#include <stdlib.h>

_Async int read(int a) {
  return 0;
}

typedef unsigned int UINT32;
_Async UINT32 f() {
    _Await read(1);
    return 0;
}

_Trait Future<unsigned int>* f_wrapper() {
    _Trait Future<unsigned int>* a = f();
    return a;
}

_Trait Future<unsigned int>* (*CallBack)() = f_wrapper;
_Async UINT32 g() {
    UINT32 i = 0;
    i = _Await CallBack();
    return i;
}

_Async unsigned int q() {
    unsigned int i = 0;
    i = _Await CallBack();
    return i;
}

_Async UINT32 h() {
    UINT32 i = 0;
    i = _Await q();
    return i;
}

int main() {
    _Trait Future<unsigned int>* this = g();
    this->poll();
    this->free();
    return 0;
}