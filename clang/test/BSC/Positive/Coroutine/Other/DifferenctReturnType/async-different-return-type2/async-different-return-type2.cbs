// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %S/../../../../../../../lib/Headers/bsc_include/future.hbs -o %T/future.h
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include "future.hbs"
#include <stdlib.h>
#include <stdbool.h>

_Async int read(int a) {
  return 0;
}

_Async bool int::g();

_Async int int::f() {
    _Await int::g();
    return 0;
}

_Async bool int::g() {
    _Trait Future<int>* a = read(1);
    _Await a;
    return false;
}

int main() {
  _Trait Future<int>* this = int::f();
  this->poll();
  this->free();
  return 0;
}