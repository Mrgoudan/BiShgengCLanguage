// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %S/../../../../../../../lib/Headers/bsc_include/future.hbs -o %T/future.h
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include "future.hbs"
#include <stdlib.h>

_Async int read(int a) {
  return 0;
}

_Async int g();

_Async int f() {
    int a = _Await g();
    return a;
}

_Async int g() {
    int a = _Await read(1);
    return 0;
}

int main() {
  _Trait Future<int>* this = f();
  this->poll();
  return 0;
}