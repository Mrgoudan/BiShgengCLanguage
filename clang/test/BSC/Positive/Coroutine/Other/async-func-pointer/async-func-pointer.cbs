// expected-no-diagnostics

#include "../../future.hbs"
#include <stdlib.h>

typedef struct __FatPointer<int> (*pollFunc) (); // triger point 1, do not change

typedef struct EQueueFunc {
    pollFunc func;
} EQueueFunc;


async void f() { // triger point 2, do not change
    EQueueFunc f;
    await f.func();
}

int main() {
  return 0;
}