// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %S/../../future.hbs -o %T/../../future.h
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include "../../future.hbs"
#include <stdlib.h>

async int f() { 
    return 0;
}

async int g() {
  return await f();
}

int main() {
  struct __FatPointer<int> a = g();
  a.vtable->poll(a.data);
  a.vtable->free(a.data);
  return 0;
}