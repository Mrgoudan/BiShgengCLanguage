// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %S/../../../../../../../../lib/Headers/bsc_include/future.hbs -o %T/future.h
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include "future.hbs"
#include <stdlib.h>

_Async int read(int a) {
  return 0;
}

_Async int f(int start) {
  unsigned int x = 3;
  unsigned int y = 4;
  int z;
  z = x & y;
  z = x | y;
  z = x ^ y;
  z = ~y;
  z = x << y;
  z = x >> y;
  int a = _Await read(1);
  int result = _Await read(1);
  return result;
}

int main() {
  _Trait Future<int>* this = f(1);
  this->poll();
  return 0;
}