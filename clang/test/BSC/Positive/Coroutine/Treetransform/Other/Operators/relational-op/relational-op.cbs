#include "../../../../async-func-read.hbs"

async int f(int start) {
  int x = 3;
  int y = 4;
  int z;
  z = x == y;
  z = x != y;
  z = x > y;
  z = x < y;
  z = x >= y;
  z = x <= y;
  int a = await read(1);
  int result = await read(1);
  return result;
}

int main() {
  struct _Futuref this = {}; 
  struct _Futuref::poll(&this);
  return 0;
}