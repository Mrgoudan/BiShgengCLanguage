#include "../../../../async-func-read.hbs"

struct Addr
{
    int a;
    char str[10];
};

async int f(int start) {
    static long myLong = 100000L;
    static unsigned int myUnsignedInt = 10U;
    static float myFloat = 3.14f;
    static double myDouble = 3.14159;
    static struct Addr addr = {1, "hello"};
    
    int result = await read(2);
    return result + 5 + start;
}

int main() {
  struct _Futuref this = {}; 
  struct _Futuref::poll(&this);
  return 0;
}