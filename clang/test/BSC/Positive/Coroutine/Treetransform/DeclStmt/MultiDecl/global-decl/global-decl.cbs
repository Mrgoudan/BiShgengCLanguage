// expected-no-diagnostics

#include "../../../../future.hbs"
#include <stdlib.h>

async int read(int a) {
  return 0;
}

int g = 5;

async int f(int start) {
  g = 6;
  int result = await read(1);
  return result + g;
}

int main() {
    struct _Futuref this = {}; 
    struct _Futuref::poll(&this);
    return 0;
}