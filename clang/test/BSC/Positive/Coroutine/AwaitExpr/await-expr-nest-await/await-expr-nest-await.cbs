// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %S/../../future.hbs -o %T/../../future.h
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include "../../future.hbs"
#include <stdlib.h>

async int read(int a) {
  return 0;
}

async int f(int start) { 
  int result = await read(await read(start));
  return result;
}

int main() {
  struct __FatPointer<int> this = f(1);
  this.vtable->poll(this.data);
  this.vtable->free(this.data); 
  return 0;
}