// RUN: %clang %s %S/scheduler.cbs %S/noise.cbs -o %test.output -lpthread
// RUN: %test.output
// RUN: %clang -rewrite-bsc %S/../../../../../../lib/Headers/bsc_include/future.hbs -o %T/future.h
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang -rewrite-bsc %S/scheduler.cbs -o %T/scheduler.c
// RUN: %clang -rewrite-bsc %S/noise.cbs -o %T/noise.c
// RUN: %clang -rewrite-bsc %S/scheduler.hbs -o %T/scheduler.h
// RUN: %clang -rewrite-bsc %S/noise.hbs -o %T/noise.h
// RUN: %clang -rewrite-bsc %S/queue.hbs -o %T/queue.h
// RUN: %clang %t-rw.c %T/scheduler.c %T/noise.c -o %t-rw.output -lpthread
// RUN: %t-rw.output
// expected-no-diagnostics

#include <stdio.h>
#include <stdlib.h>
#include <sys/socket.h>
#include <arpa/inet.h>
#include <string.h>
#include <unistd.h>
#include <pthread.h>
#include <time.h>
#include "scheduler.hbs"

#define ROW 50
#define COL 50
#define PORT 9999
#define BUFFER_SIZE 1024
_Bool g_isClientClosed = false;

NOISE g_noise;

typedef struct FileWriter {
    FILE *file;
    char *buffer;
    _Bool isWrited;
}FileWriter;

FileWriter fileWriter(FILE *file, char *buffer) {
    struct FileWriter fw;
    fw.file = file;
    fw.buffer = buffer;
    fw.isWrited = false;
    return fw;
}

struct PollResult<struct Void> FileWriter::poll(FileWriter *this) {
    if (this->isWrited) {
        this->isWrited = false;
        struct Void res = {};
        return struct PollResult<struct Void>::completed(res);
    } else {
        //TODO: Change to asynchronous IO
        if (fprintf(this->file,  "%s", this->buffer) < 0) {
            perror("file writer failed");
        }
        this->isWrited = true;
        return struct PollResult<struct Void>::pending();
    }
}

void FileWriter::free(FileWriter *this) {}

impl trait Future<struct Void> for FileWriter;


async void server(int port) {
    int server_socket, client_socket;
    struct sockaddr_in client_address;
    int client_address_length = sizeof(client_address);
    char buffer[BUFFER_SIZE] = {0};
    char message[] = "The server has received\n";
    server_socket = socket(AF_INET, SOCK_STREAM, 0);
    if (server_socket == -1) {
        perror("socket creation failed");
        exit(EXIT_FAILURE);
    }

    struct sockaddr_in server_address;
    server_address.sin_family = AF_INET;
    server_address.sin_addr.s_addr = INADDR_ANY;
    server_address.sin_port = htons(port);

    if (bind(server_socket, (struct sockaddr *)&server_address, sizeof(server_address)) < 0) {
        perror("bind failed");
        exit(EXIT_FAILURE);
    }

    if (listen(server_socket, 3) < 0) {
        perror("listen failed");
        exit(EXIT_FAILURE);
    }

    if ((client_socket = accept(server_socket, (struct sockaddr *)&client_address, (socklen_t *)&client_address_length)) < 0) {
        perror("accept failed");
        exit(EXIT_FAILURE);
    }
    FILE *file = fopen("./server.txt", "w");
    if (file == NULL) {
        perror("error opening file\n");
        fclose(file);
    }
    while (true) {
        read(client_socket, buffer, 1024);
        await fileWriter(file, buffer);
        send(client_socket, message, strlen(message), 0);
        if (g_isClientClosed) {
            close(server_socket);
            close(client_socket);
            break;
        }
    }
    struct Scheduler::destroy();
}

async void createMatrix(int matrix[ROW][COL]) {
    int i, j, k = 0;

    srand((unsigned)time(NULL));
    for (i = 0; i < ROW; i++) {
        for (j = 0; j < COL; j++) {
            matrix[i][j] = rand() %10;
        }
    }
}

async void multiMatrix(int matrix1[ROW][COL], int matrix2[ROW][COL], int result[ROW][COL]) {
    for (int i = 0; i < ROW; i++) {
        for (int j = 0; j < COL; j++) {
            int sum = 0;
            for (int k = 0; k < COL; k++) {
                sum += matrix1[i][k] * matrix2[k][j];
            }
            result[i][j] = sum;
        }
    }
}

async void client(int port) {
    char str[COL + 2];
    int matrix1[ROW][COL];
    int matrix2[ROW][COL];
    int result[ROW][COL];
    char buffer[BUFFER_SIZE] = {0};
    int client_socket = socket(AF_INET, SOCK_STREAM, 0);
    if (client_socket == -1) {
        perror("socket creation failed");
        exit(EXIT_FAILURE);
    }

    struct sockaddr_in server_address;
    server_address.sin_family = AF_INET;
    server_address.sin_port = htons(port);
    if (inet_pton(AF_INET, "127.0.0.1", &server_address.sin_addr) <= 0) {
        perror("invalid address");
        exit(EXIT_FAILURE);
    }

    while (connect(client_socket, (struct sockaddr *)&server_address, sizeof(server_address)) < 0) {
    }

    await createMatrix(matrix1);
    await createMatrix(matrix2);
    await multiMatrix(matrix1, matrix2, result);
    int k = 0;
    for (int i = 0; i < ROW; i++) {
        for (int j = 0; j < COL; j++) {
            k += sprintf(&str[k], "%d ", result[i][j]);
        }
        str[k++] = '\0';
        send(client_socket, str, strlen(str), 0);
        read(client_socket, buffer, BUFFER_SIZE);
        k = 0;
    }

    close(client_socket);
    g_isClientClosed = true;
}

int main() {
    g_noise.init();
    uint64_t start, end;
    start = read_tsc();
    struct Scheduler::init(4);
    end = read_tsc();
    g_noise.initCost = end - start;

    struct Scheduler::spawn(server(PORT));
    struct Scheduler::spawn(client(PORT));

    struct Scheduler::run();


    // 协程基础设施
    printf("scheduler init cost: %lu\n", g_noise.initCost); // 初始化调度器
    printf("scheduler creat async task cost: %lu\n", g_noise.createTaskCost / g_noise.createTaskCount); // 创建异步任务
    printf("scheduler free cost: %lu\n", g_noise.freeCost / g_noise.freeCount); // 销毁异步任务
    printf("scheduler push cost: %lu\n", g_noise.pushCost / g_noise.pushCount); // 放入队列
    printf("scheduler pop cost: %lu\n", g_noise.popCost / g_noise.popCount); // 从队列中取出

    // 调度策略
    printf("scheduler get task cost: %lu\n", (g_noise.getTaskCost / g_noise.getTaskCount) - (g_noise.popCost / g_noise.popCount)); // 选择任务

    return 0;
}



