  p = safe_malloc<int>(4);
  if (nullptr == p) {
    printf ("nullptr equals q\n");
  } else {
    printf ("nullptr not equals q\n");
    safe_free<int>(p);
  }
  if (nullptr >= p) {
    int b =1;
  }
}

int main() {
  test();
  nullptr_equals();
}

// CHECK: nullptr equals nullptr
// CHECK-NEXT: nullptr equals q
