// RUN: %clang -cc1 %s
// expected-no-diagnostics

_Safe void explicit_reborrow(int *_Borrow _Nullable ptr) {
    const int *_Borrow _Nullable cbp = &_Const *ptr;
    int *_Borrow _Nullable mbp = &_Mut *ptr;
}

_Safe void explicit_reborrow2(void) {
    int *_Borrow _Nullable ptr = nullptr;
    const int *_Borrow _Nullable cbp = &_Const *ptr;
    int *_Borrow _Nullable mbp = &_Mut *ptr;
}

_Safe int *_Owned _Nullable explicit_reborrow3(int *_Owned _Nullable ptr) {
    const int *_Borrow _Nullable cbp = &_Const *ptr;
    int *_Borrow _Nullable mbp = &_Mut *ptr;
    return ptr;
}

_Safe int *_Owned _Nullable explicit_reborrow4(void) {
    int *_Owned _Nullable ptr = nullptr;
    const int *_Borrow _Nullable cbp = &_Const *ptr;
    int *_Borrow _Nullable mbp = &_Mut *ptr;
    return ptr;
}

