// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

typedef struct {
  int *p;
} S1;

typedef struct {
  int *_Owned _Nullable p;
} S2;

typedef struct {
  int *_Borrow _Nullable p;
} S3;

typedef struct {
  int *p;
  int *_Borrow _Nullable q;
} S4;

// S1 raw pointer field initialization accepts nullptr.
void init_s1_field(void) {
  S1 s = {nullptr};
}

// S1 raw pointer field assignment accepts nullptr.
void assign_s1_field(void) {
  S1 s;
  s = (S1){nullptr};
  s.p = nullptr;
}

void take_s1_struct(S1 s) {}

// S1 raw pointer field arguments accept nullptr.
void call_s1_struct(void) {
  take_s1_struct((S1){nullptr});
}

// S1 raw pointer field returns accept nullptr.
S1 return_s1_struct(void) {
  return (S1){nullptr};
}

// S2 _Owned nullable field initialization accepts nullptr.
void init_s2_field(void) {
  S2 s = {nullptr};
  __move_to_raw(s.p);
}

// S2 _Owned nullable field assignment accepts nullptr.
void assign_s2_field(void) {
  S2 s = {nullptr};
  s = (S2){nullptr};
  __move_to_raw(s.p);
}

void take_s2_struct(S2 s) {
  __move_to_raw(s.p);
}

// S2 _Owned nullable field arguments accept nullptr.
void call_s2_struct(void) {
  take_s2_struct((S2){nullptr});
}

// S2 _Owned nullable field returns accept nullptr.
S2 return_s2_struct(void) {
  return (S2){nullptr};
}

