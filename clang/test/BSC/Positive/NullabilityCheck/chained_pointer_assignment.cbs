// RUN: %clang_cc1 -nullability-check=all -verify %s
// expected-no-diagnostics

_Safe void safe_free(void *owned p);

void test1() {
    int *p1, *p2;
    p1 = p2 = nullptr;
    if (p1 != nullptr) {
        int *p3 = (int *_Nonnull)p1;
    }
    if (p2 != nullptr) {
        int *p4 = (int *_Nonnull)p2;
    }
}

void test2() {
    int *p1, *p2;
    p1 = p2 = nullptr;
    if (p1 != nullptr) {
        int *owned p3 = (int *owned)p1;
        safe_free((void *owned)p3);
    }
    if (p2 != nullptr) {
        int *owned p4 = (int *owned)p2;
        safe_free((void *owned)p4);
    }
}

void test3() {
    int *p1, *p2;
    p1 = p2 = nullptr;
    if (p1 != nullptr) {
        int *_Borrow p3 = (int *_Borrow)p1;
    }
    if (p2 != nullptr) {
        int *_Borrow p4 = (int *_Borrow)p2;
    }
}
