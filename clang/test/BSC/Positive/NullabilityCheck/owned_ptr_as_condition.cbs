// RUN: %clang_cc1 -ast-dump -verify %s
// expected-no-diagnostics

_Safe void consume(int *_Owned _Nullable);

_Safe void strict_consume(int *_Owned _Nonnull);

struct Foo {
    int *_Owned _Nullable p;
};

_Safe void reference(int *_Owned _Nullable p) {
    if (p != nullptr) {
        int x = *p;
        strict_consume(p);
    }
}

_Safe void reference_not(int *_Owned _Nullable p, int x) {
    if (p == nullptr) {
        ++x;
    } else {
        x = *p;
        strict_consume(p);
    }
}

_Safe void basic(int *_Owned _Nullable p) {
    if (p) {
        int x = *p;
        strict_consume(p);
    }
}

_Safe void logical_not(int *_Owned _Nullable p, int x) {
    if (!p) {
        ++x;
    } else {
        x = *p;
        strict_consume(p);
    }
}

_Safe void member(struct Foo foo) {
    if (foo.p) {
        int x = *(foo.p);
        strict_consume(foo.p);
    }
} 

_Safe void member_not(struct Foo foo, int x) {
    if (!foo.p) {
        ++x;
    } else {
        x = *(foo.p);
        strict_consume(foo.p);
    }
}

_Safe void ternary(int *_Owned _Nullable p, int x) {
    x = (nullptr != p) ? (*p = 1) : 0;
    x = (nullptr != p) ? (*p += 1) : 0;
    x = (p != nullptr) ? (*p = 1) : 0;
    x = (p != nullptr) ? (*p += 1) : 0;
    x = (nullptr == p) ? 0 : (*p = 1);
    x = (nullptr == p) ? 0 : (*p += 1);
    x = (p == nullptr) ? 0 : (*p = 1);
    x = (p == nullptr) ? 0 : (*p += 1);
    
    x = p ? (*p = 1) : 0;
    x = p ? (*p += 1) : 0;
    x = p ? (*p = 1) : 0;
    x = p ? (*p += 1) : 0;
    x = !p ? 0 : (*p = 1);
    x = !p ? 0 : (*p += 1);
    x = !p ? 0 : (*p = 1);
    x = !p ? 0 : (*p += 1);
    consume(p);
}

_Safe void ternary_borrow(int *_Borrow _Nullable p, int x) {
    x = (nullptr != p) ? (*p = 1) : 0;
    x = (nullptr != p) ? (*p += 1) : 0;
    x = (p != nullptr) ? (*p = 1) : 0;
    x = (p != nullptr) ? (*p += 1) : 0;
    x = (nullptr == p) ? 0 : (*p = 1);
    x = (nullptr == p) ? 0 : (*p += 1);
    x = (p == nullptr) ? 0 : (*p = 1);
    x = (p == nullptr) ? 0 : (*p += 1);
    
    x = p ? (*p = 1) : 0;
    x = p ? (*p += 1) : 0;
    x = p ? (*p = 1) : 0;
    x = p ? (*p += 1) : 0;
    x = !p ? 0 : (*p = 1);
    x = !p ? 0 : (*p += 1);
    x = !p ? 0 : (*p = 1);
    x = !p ? 0 : (*p += 1);
}
