// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

T* _Owned safe_malloc<T>(T value) {
  T * p = (T *) malloc( sizeof(T) );
  *p = value;
  return __take_from_raw(p);
}

void safe_free<T>(T* _Owned p) {
  free( __move_to_raw(p) );
}

_Safe int foo(int *_Borrow x) { return *x; }
typedef struct S {
  int *_Owned p;
} S;

int main(void) {
  int *_Owned ptr = safe_malloc(0);
  int x = foo(&_Mut * ptr);
  safe_free((void *_Owned)(ptr));
  S s = {.p = safe_malloc(1)};
  S *_Owned pp = safe_malloc(s);
  safe_free((void *_Owned)(pp->p));
  safe_free((void *_Owned)(pp));
  return 0;
}
