// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

#define NULL ((void*)0)

struct K<T> {
    T a;
};

void struct K<T>::foo1(const This *_Borrow this) {
    struct K<T> ret = *this;    
}

void struct K<T>::foo2(This *_Borrow this) {
    struct K<T> ret = *this;
}

struct M<T> {
    struct K<T>*_Borrow a;
};

void struct M<T>::foo3(This *this) {
    struct K<T> ret = *(this->a);
}

void foo<T>(struct K<T> *_Borrow p) {
    struct K<T> ret = *p;
    T *a = (T*)ret.a;    
}

typedef struct BinaryTrieNode {
    struct BinaryTrieNode *zero;
    struct BinaryTrieNode *one;
} BinTrieNode;

void BinTrieDestroy(BinTrieNode **root)
{
    if (*root == NULL) {
        return;
    }
}

int main() {
    struct K<int> k = { .a = 5 };
    k.foo1();
    k.foo2();

    struct M<int> m = { .a = &_Mut k };
    m.foo3();
    return 0;
}

void test_mutable_pointer_borrow_assign(void) {
  const int * tmp = (const int*)0;
  const int v = 0;
  const int ** _Borrow p = &_Mut tmp;
  *p = &v;  // Legal: const int * is not const-qualified on the pointer level
}
