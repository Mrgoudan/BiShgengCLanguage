// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

// For now, this case should pass all the syntax & sema check.
// TODO: enable CFG-based lifetime analysis in borrow checker, report error when
// violating borrowing rules.

#include <stdlib.h>

/**
 1. We cannot have two refs(mut&immut, or mut&mut) to a same object at same time
 2. borrower's lifetime cannot extend the owner's

 TODO
 1. if-else, for, while ...
 2. struct, its fields
 3. Safezone
 */
void use_mut(int *borrow p) {}
void use_immut(const int *borrow p) {}

// Error
void test0() {
  int local = 42;
  int *borrow p1 = &mut local;
  const int *borrow p2 = &const local;
  use_mut(p1); // Error: p1( &mut ) and p2( &const ) borrow a same obj
  use_immut(p2);
}

// OK, Nonlexical Lifetime(NLL)
void test1() {
  int *oriPtr = malloc(sizeof(int));
  *oriPtr = 42;
  // we have two ref: immut, mut ref to p1
  int *borrow p1 = &mut * oriPtr; // This is unsafe! Only legal in unsafe zone.
  const int *borrow p2 = &const * oriPtr;
  // Above is OK, p1 is dead first, then p2 is created
}

// Error
void test2() {
  int *oriPtr = malloc(sizeof(int));
  *oriPtr = 42;
  // we have two ref: immut, mut ref to p1
  int *borrow p1 = &mut * oriPtr;
  const int *borrow p2 = &const * oriPtr;
  // Above is not OK, both p1 and p2 are alive
  // because they are used after. This differs from test1 due to NLL.
  use_mut(p1);
  use_immut(p2);
}

void consume(int *owned p) { free((void *)p); }

// OK, obj is a owned pointer
void test3() {
  int *owned oriPtr = (int *owned)malloc(sizeof(int));
  // we have two ref: immut, mut ref to p1
  const int *borrow p1 = &const * oriPtr;
  const int *borrow p2 = &const * oriPtr;
  // Above is OK, p1 and p2 are immut borrow.
  use_immut(p1);
  use_immut(p2);
  consume(oriPtr); // Ok, oriPtr outlives p1, p2
}

// Error: obj is a owned pointer and it dies before its borrowers.
void test4() {
  int *owned oriPtr = (int *owned)malloc(sizeof(int));
  // we have two ref: immut, mut ref to p1
  const int *borrow p1 = &const * oriPtr;
  const int *borrow p2 = &const * oriPtr;
  // Above is bad, both p1 and p2 are alive
  // because they are used after
  consume(oriPtr); // Error, oriPtr dies before p1, p2
  use_immut(p1);
  use_immut(p2);
}

int main() {
  test0();
  test1();
  test2();
  test3();
  test4();
  return 0;
}
