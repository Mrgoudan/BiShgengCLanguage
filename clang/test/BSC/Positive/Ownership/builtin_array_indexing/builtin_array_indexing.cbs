// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

void foo(int *_Borrow p, int *_Borrow q) {
    // an builtin array consisting of borrowed pointers
    int *_Borrow arr[2] = {p, q};
    int *_Borrow p2 = arr[0];
    *p2 = 1;
}

int main() {
    int x = 0;
    int y = 1;
    int *_Borrow px = &mut x;
    int *_Borrow py = &mut y;
    foo(px, py);
    return 0;
}