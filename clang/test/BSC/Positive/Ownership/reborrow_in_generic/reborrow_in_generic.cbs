// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

void use(int *_Borrow p) {
    *p = 2;
}

void use_immut(const int *_Borrow p) {
    int x = *p;
}

void test1<T>() {
  int a = 1;
  int *_Borrow p = &mut a;
  int *_Borrow q = &mut *p;
  use(q);
}

void test2<T>() {
    int a = 1;
    int *_Borrow p = &mut a;
    const int *_Borrow q = &const *p;
    use_immut(q);
}

int main() {
  test1<int>();
  test2<int>();
  return 0;
}
