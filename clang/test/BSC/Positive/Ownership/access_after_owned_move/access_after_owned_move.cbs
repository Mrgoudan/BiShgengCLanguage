// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

void *malloc(unsigned long size);
void free(void *ptr);

T* _Owned safe_malloc<T>(T value) {
  T * p = (T *) malloc(sizeof(T));
  *p = value;
  return (T* _Owned)p;
}

void safe_free(void* _Owned p) {
  free((void*)p);
}

struct S1 {
  int a[2];
  int *_Owned p3;
};

void test_array_access_after_owned_move() {
  struct S1 s1 = {};
  struct S1 *_Owned p1 = safe_malloc(s1);
  int *_Owned tmp = p1->p3;
  safe_free((void *_Owned)tmp);
  p1->a[0] = 0;
  safe_free((void *_Owned)p1);
}

struct S2 {
  int arr[10];
  int *_Owned ptr;
};

void test_multiple_array_indices() {
  struct S2 s2 = {};
  struct S2 *_Owned p2 = safe_malloc(s2);
  int *_Owned inner = p2->ptr;
  safe_free((void *_Owned)inner);
  p2->arr[0] = 1;
  p2->arr[5] = 2;
  p2->arr[9] = 3;
  safe_free((void *_Owned)p2);
}

struct S3 {
  int *_Owned ptr;
  int *_Borrow p2;
};

void test_assign_borrow_after_owned_move() {
  int a = 0;
  int b = 1;
  struct S3 s3 = {.p2 = &_Mut a};
  struct S3 *_Owned p3 = safe_malloc(s3);
  safe_free((void *_Owned)p3->ptr);
  p3->p2 = &_Mut b;
  safe_free((void *_Owned)p3);
}

struct S4 {
  int *_Owned ptr;
  int a;
};

void test_assign_after_owned_move() {
  int a = 0;
  struct S4 s4 = {};
  struct S4 *_Owned p4 = safe_malloc(s4);
  safe_free((void *_Owned)p4->ptr);
  p4->a = 1;
  safe_free((void *_Owned)p4);
}

struct Inner {
  int arr[2];
  int *_Owned p;
};
struct Outer {
  struct Inner i;
};

void test_nested_struct_array_access() {
  struct Inner inner = {.p = safe_malloc(1)};
  struct Outer outer = {.i = inner};
  struct Outer *_Owned p = safe_malloc(outer);
  int *_Owned tmp = p->i.p;
  safe_free((void *_Owned)tmp);
  p->i.arr[0] = 0;
  safe_free((void *_Owned)p);
}

void test_array_read_after_owned_move() {
  struct S1 s1 = {};
  s1.a[0] = 42;
  struct S1 *_Owned p1 = safe_malloc(s1);
  int *_Owned tmp = p1->p3;
  safe_free((void *_Owned)tmp);
  int x = p1->a[0];
  (void)x;
  safe_free((void *_Owned)p1);
}

void test_cast_field_then_array_access() {
  struct S1 s1 = {.p3 = safe_malloc(1)};
  struct S1 *_Owned p1 = safe_malloc(s1);
  safe_free((void *_Owned)p1->p3);
  p1->a[0] = 0;
  safe_free((void *_Owned)p1);
}

int main() {
  test_array_access_after_owned_move();
  test_multiple_array_indices();
  test_assign_borrow_after_owned_move();
  test_assign_after_owned_move();
  test_nested_struct_array_access();
  test_array_read_after_owned_move();
  test_cast_field_then_array_access();
  return 0;
}
