// RUN: %clang_cc1 -ast-dump -verify %s
// expected-no-diagnostics

_Safe void consume(int *_Owned _Nullable);

_Safe int *_Owned _Nullable ternary_condition_is_not_move(int *_Owned _Nullable p) {
    int x = p ? 2 : 3;
    return p;
}

_Safe int *_Owned _Nullable nested_ternary_condition_is_not_move(int *_Owned _Nullable p,
                                                               _Bool b1,
                                                               _Bool b2) {
    int x = b1 ? (b2 ? 1 : (p ? 2 : 3)) : (b2 ? 4 : 5);
    return p;
}

_Safe void ternary_borrow(_Bool flag, int *_Owned  p, int *_Owned  q) {
    int *_Borrow ref = &_Mut*(flag ? p : q);
    consume(p);
    consume(q);
}