// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

void mutable2immutable(int *_Borrow ref) {
    const int *_Borrow cref = ref; 
}

void inplace_reborrow(int x) {
    const int *_Borrow cref = &_Mut x;
}

_Safe void nullable_reborrow(int *_Borrow _Nullable ref) {
    const int *_Borrow _Nullable cref = ref;
}

void accept_immutable(const int *_Borrow cref) {}

int *_Borrow ret_mutable(int *_Borrow x, int *_Borrow y) {
    return *x > *y ? x : y;
}

int main() {
    // assignment
    int x = 0;
    inplace_reborrow(x);
    mutable2immutable(&_Mut x);
    int *_Borrow _Nullable n_ref = &_Mut x;
    nullable_reborrow(n_ref);
    nullable_reborrow(nullptr);
    
    // argument to parameter
    accept_immutable(&_Mut x);
    int *_Borrow ref = &_Mut x;
    accept_immutable(ref);

    // return value
    int y = 2;
    const int *_Borrow cref = ret_mutable(&_Mut x, &_Mut y);    
    return 0;
}