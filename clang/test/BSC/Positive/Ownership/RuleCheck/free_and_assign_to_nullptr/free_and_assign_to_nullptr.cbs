// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

void consume(int *owned p) {
  int *pp = (int *)p;
}

void test1(int *owned p) {
  consume(p);
  (p) = nullptr;
}

void test2(int *owned p) {
  do {
    if (nullptr != p) {
      consume((p));
      (p) = nullptr;
    }
  } while(0);
}

int main() {
  int *owned p = nullptr;
  int *owned q = nullptr;
  test1(p);
  test2(q);
  return 0;
}