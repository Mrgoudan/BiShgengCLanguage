// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

void consume(int *_Owned p) {
  int *pp = (int *)p;
}

void test1(int *_Owned p) {
  consume(p);
  (p) = nullptr;
}

void test2(int *_Owned p) {
  do {
    if (nullptr != p) {
      consume((p));
      (p) = nullptr;
    }
  } while(0);
}

void test3(int *_Owned p) {
  do {
    if (((nullptr)) != ((p))) {
      consume((p));
      ((p)) = nullptr;
    }
  } while(0);
}

int main() {
  int *_Owned p = nullptr;
  int *_Owned q = nullptr;
  int *_Owned r = nullptr;
  test1(p);
  test2(q);
  test3(r);
  return 0;
}