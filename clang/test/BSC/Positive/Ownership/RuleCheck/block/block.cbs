// RUN: %clang_cc1 %s
// expected-no-diagnostics
// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

int * _Owned pmalloc() {
	int a = 1;
	int *_Owned p = __take_from_raw(&a);
	return p;
}

int * _Owned func() {
	int p = 1;
	{
		int * _Owned p = pmalloc();
		return p;
	}
}

int main() {
	
	return 0;
}
