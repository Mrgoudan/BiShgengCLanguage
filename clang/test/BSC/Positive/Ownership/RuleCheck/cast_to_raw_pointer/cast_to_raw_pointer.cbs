// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

typedef struct {
  int a;
} S;

unsigned char *call(unsigned char *p) {
  return p;
}

S *_Owned test1(void *_Owned p) {
  void *raw = __move_to_raw(p);
  return __take_from_raw((S *)((unsigned char *)raw + 5));
}

S *_Owned test2(void *_Owned p) {
  void *raw = __move_to_raw(p);
  return __take_from_raw((S *)raw);
}

S *_Owned test3(void *_Owned p) {
  void *raw = __move_to_raw(p);
  return __take_from_raw((S *)raw);
}

S *_Owned test4(void *_Owned p) {
  return (S *_Owned)p;
}

S *_Owned test5(void *_Owned p) {
  void *raw = __move_to_raw(p);
  return __take_from_raw((S *)(call((unsigned char *)raw + 5) + 6));
}

int test6(void *_Owned p) {
  void *raw = __move_to_raw(p);
  return (int)*call((unsigned char *)raw + 5) + 10;
}

S *_Owned test7(void *_Owned p) {
  void *raw = __move_to_raw(p);
  return __take_from_raw((S *)((unsigned char *)raw - 5));
}

int main(void) {
  return 0;
}