// RUN: %clang_cc1 -verify %s 
// expected-no-diagnostics

int *global_ptr1;
int **global_ptr2;
int *global_ptr_arr1[2];
int *global_ptr_arr2[2][2];

void test() {
    int *borrow borrow_ptr1 = (int *borrow)global_ptr1;
    int **borrow borrow_ptr2 = (int **borrow)global_ptr2;
    int *borrow borrow_ptr_arr1[2] = {(int *borrow)global_ptr_arr1[0], (int *borrow)global_ptr_arr1[1]};
    int *(*borrow borrow_ptr_arr2)[2][2] = &mut global_ptr_arr2;

    *borrow_ptr1 = 1;
    **borrow_ptr2 = 1;
    *borrow_ptr_arr1[1] = 1;
    *(*borrow_ptr_arr2)[1][1] = 1;
}

int main() {
    test();
}