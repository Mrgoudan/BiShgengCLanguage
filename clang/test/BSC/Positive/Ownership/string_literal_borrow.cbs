// RUN: %clang_cc1 -ast-dump -verify %s
// expected-no-diagnostics
// Test automatic &_Const * insertion for string literals to const char * _Borrow

void foo_const(const char * _Borrow stra) {}

void test_auto_insert() {
  // Automatic insertion: foo_const("hello") becomes foo_const(&_Const * "hello")
  foo_const("hello");  
}

void test_explicit_const() {
  // Explicit &_Const * should also work
  foo_const(&_Const * "hello");  
}

void test_auto_insert_init() {
  // Automatic insertion for variable initialization
  const char* _Borrow a = "hellowprld.";  
  const char* _Borrow b = "test";  
  const char* _Borrow c = "another string";  
}

int main() {
  test_auto_insert();
  test_explicit_const();
  test_auto_insert_init();
  return 0;
}
