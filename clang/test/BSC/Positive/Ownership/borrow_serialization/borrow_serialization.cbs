// CHECK-NEXT: UnaryOperator 0x{{[^ ]*}} <col:29, col:30> 'int *' prefix '&' cannot overflow
// CHECK-NEXT: DeclRefExpr 0x{{[^ ]*}} <col:30> 'int' lvalue Var 0x{{[^ ]*}} 'x' 'int'
