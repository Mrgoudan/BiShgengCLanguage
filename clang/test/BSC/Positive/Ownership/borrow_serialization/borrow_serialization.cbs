// CHECK-NEXT: CStyleCastExpr 0x{{[^ ]*}} <col:{{[0-9]+}}, col:{{[0-9]+}}> 'int *_Owned' <NoOp>
// CHECK-NEXT: UnaryOperator 0x{{[^ ]*}} <col:{{[0-9]+}}, col:{{[0-9]+}}> 'int *' prefix '&' cannot overflow
// CHECK-NEXT: DeclRefExpr 0x{{[^ ]*}} <col:{{[0-9]+}}> 'int' lvalue Var 0x{{[^ ]*}} 'x1' 'int'
// CHECK-NEXT: DeclStmt 0x{{[^ ]*}} <line:[[@LINE-52]]:3, col:{{[0-9]+}}>
// CHECK-NEXT: VarDecl 0x{{[^ ]*}} <col:{{[0-9]+}}, col:{{[0-9]+}}> col:{{[0-9]+}} b6 'const int *_Borrow' cinit
// CHECK-NEXT: ImplicitCastExpr 0x{{[^ ]*}} <col:{{[0-9]+}}> 'int *_Borrow' <LValueToRValue>
