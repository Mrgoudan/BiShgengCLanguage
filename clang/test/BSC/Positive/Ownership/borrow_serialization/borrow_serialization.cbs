// CHECK-NEXT: VarDecl 0x{{[^ ]*}} <col:5, col:27> col:18 used p 'int *borrow' cinit
// CHECK-NEXT: UnaryOperator 0x{{[^ ]*}} <col:22, col:27> 'int *borrow' prefix '&' cannot overflow
// CHECK-NEXT: DeclRefExpr 0x{{[^ ]*}} <col:27> 'int' lvalue Var 0x{{[^ ]*}} 'x' 'int'
// CHECK-NEXT: DeclStmt 0x{{[^ ]*}} <line:[[@LINE-29]]:5, col:31>
// CHECK-NEXT: VarDecl 0x{{[^ ]*}} <col:5, col:30> col:20 p1 'float *borrow' cinit
// CHECK-NEXT: UnaryOperator 0x{{[^ ]*}} <col:25, col:30> 'float *borrow' prefix '&' cannot overflow
// CHECK-NEXT: DeclRefExpr 0x{{[^ ]*}} <col:30> 'float' lvalue Var 0x{{[^ ]*}} 'y' 'float'
// CHECK-NEXT: DeclStmt 0x{{[^ ]*}} <line:[[@LINE-32]]:5, col:37>
// CHECK-NEXT: VarDecl 0x{{[^ ]*}} <col:5, col:36> col:24 p2 'const int *borrow' cinit
// CHECK-NEXT: UnaryOperator 0x{{[^ ]*}} <col:29, col:36> 'const int *borrow' prefix '&' cannot overflow
// CHECK-NEXT: DeclRefExpr 0x{{[^ ]*}} <col:36> 'int' lvalue Var 0x{{[^ ]*}} 'x' 'int'
