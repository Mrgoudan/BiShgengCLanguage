// CHECK-NEXT: CStyleCastExpr 0x{{[^ ]*}} <col:28, col:49> 'const int *borrow' <NoOp>
// CHECK-NEXT: UnaryOperator 0x{{[^ ]*}} <col:48, col:49> 'int *' prefix '&' cannot overflow
