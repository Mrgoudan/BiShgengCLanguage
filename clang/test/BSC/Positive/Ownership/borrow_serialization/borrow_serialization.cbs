// CHECK-NEXT: VarDecl 0x{{[^ ]*}} <col:3, col:26> col:16 used p 'int *_Borrow' cinit
// CHECK-NEXT: UnaryOperator 0x{{[^ ]*}} <col:20, col:26> 'int *_Borrow' prefix '&' cannot overflow
// CHECK-NEXT: DeclRefExpr 0x{{[^ ]*}} <col:26> 'int' lvalue Var 0x{{[^ ]*}} 'x' 'int'
