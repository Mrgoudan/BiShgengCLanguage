// CHECK-NEXT: VarDecl 0x{{[^ ]*}} <col:3, col:29> col:18 p1 'float *_Borrow' cinit
// CHECK-NEXT: UnaryOperator 0x{{[^ ]*}} <col:23, col:29> 'float *_Borrow' prefix '&' cannot overflow
