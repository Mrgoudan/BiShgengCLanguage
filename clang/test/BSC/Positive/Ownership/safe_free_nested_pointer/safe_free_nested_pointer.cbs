// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

T* _Owned safe_malloc<T>(T value) {
  T * p = (T *) malloc( sizeof(T) );
  *p = value;
  return __take_from_raw(p);
}

void safe_free<T>(T* _Owned p) {
  free( __move_to_raw(p) );
}

void test_double_pointer_ok() {
  int* _Owned inner = safe_malloc(1);
  int* _Owned * _Owned outer = safe_malloc(inner);
  int* _Owned * _Owned * _Owned ultraout = safe_malloc(outer);
  safe_free((void *_Owned)**ultraout);
  safe_free((void *_Owned)*ultraout);
  safe_free((void *_Owned)ultraout);
}
int main(){
  test_double_pointer_ok();
  return 0;
}