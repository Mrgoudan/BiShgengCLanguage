// RUN: %clang_cc1 -verify %s
// expected-no-diagnostics

void consume(const int *_Owned);
void test_move_to_raw_strips_pointer_cv_restrict(
    int *_Owned const volatile restrict p,
    const int *_Owned const volatile restrict cp) {
  _Static_assert(__is_same(typeof(__move_to_raw(p)), int *), "fail");
  _Static_assert(__is_same(typeof(__move_to_raw(cp)), const int *), "fail");
  consume(p);
  consume(cp);
}

void test_take_from_raw_strips_pointer_cv_restrict(
    int *const volatile restrict p,
    const int *const volatile restrict cp) {
  _Static_assert(__is_same(typeof(__take_from_raw(p)), int *_Owned), "fail");
  _Static_assert(__is_same(typeof(__take_from_raw(cp)), const int *_Owned),
                 "fail");
}
