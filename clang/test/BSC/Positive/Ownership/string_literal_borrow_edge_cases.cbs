// RUN: %clang_cc1 -ast-dump -verify %s
// expected-no-diagnostics

// Test edge cases for string literal borrow auto-insertion

// Test 1: Parenthesized string literals
void test_parens() {
  const char* borrow a = ("hello");
  const char* borrow b = (("world"));
}

// Test 2: Struct field initialization
struct Config {
  const char* borrow name;
  const char* borrow desc;
};

void test_struct_init() {
  struct Config cfg1 = { "app", "description" };
  struct Config cfg2 = { .name = "test", .desc = "test desc" };
}

// Test 3: Array of borrow pointers
void test_array() {
  const char* borrow arr[] = { "one", "two", "three" };
}

// Test 4: Assignment after initialization
void test_assignment() {
  const char* borrow p = "init";
  p = "assigned";
}

// Test 5: Reassignment
void test_reassignment() {
  const char* borrow msg = "first";
  msg = "second";
  msg = "third";
}

// Test 6: Conditional expression
void test_conditional(int flag) {
  const char* borrow msg = flag ? "yes" : "no";
}

// Test 7: Nested struct initialization
struct Nested {
  struct Config cfg;
};

void test_nested() {
  struct Nested n = { { "name", "desc" } };
}

// Test 8: Compound literal
void test_compound() {
  struct Config* cfg = &(struct Config){ "name", "desc" };
}

// Test 9: Multiple levels of const
void test_const_levels() {
  const char* borrow p1 = "test1";
  const char* const borrow p2 = "test2";
}

// Test 10: Function return
const char* borrow get_message(int* borrow b) {
  return "hello";
}

// Test 11: Nested ternary
void test_ternary(int x) {
  const char* borrow result = (x > 0) ? "positive" : (x < 0) ? "negative" : "zero";
}

// Test 12: Multiple variables in one declaration
void test_multiple_vars() {
  const char* borrow p1 = "first", *borrow p2 = "second";
}

// Test 13: Pointer to pointer
void test_ptr_to_ptr() {
  const char* borrow p = "test";
  const char* borrow * pp = &p;
}

int main() {
  test_parens();
  test_struct_init();
  test_array();
  test_assignment();
  test_reassignment();
  test_conditional(1);
  test_nested();
  test_compound();
  test_const_levels();
  int *borrow b = nullptr;
  get_message(b);
  test_ternary(5);
  test_multiple_vars();
  test_ptr_to_ptr();
  return 0;
}
