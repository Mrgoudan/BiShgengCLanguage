// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

// Test that _Owned qualifiers are allowed on template type parameters
// Validity is checked at template instantiation time

// Test 1: owned_cast pattern - template function with _Owned qualified parameters
static inline _Safe T2 _Owned owned_cast<T1,T2>(T1 _Owned p);

// Test 2: Template function with _Owned return type
T _Owned func1<T>();

// Test 3: Template function with _Owned parameter
void func2<T>(T _Owned p);

// Test 4: Template function with multiple _Owned parameters
void func3<T1, T2>(T1 _Owned a, T2 _Owned b);

// Test 5: Mixed _Owned and non-owned 
T1 _Owned func4<T1, T2>(T1 _Owned input, T2 regular);
