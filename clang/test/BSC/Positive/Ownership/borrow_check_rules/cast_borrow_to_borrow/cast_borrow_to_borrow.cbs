// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

int *_Borrow return_and_take_nonnull(int *_Borrow a) {
  return a;
}

int main(void) {
  int a = 10; 
  int *_Borrow p = &mut a;
  return_and_take_nonnull((int *_Borrow)p);
  return 0;
}