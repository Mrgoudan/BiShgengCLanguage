// expected-no-diagnostics

int *borrow return_and_take_nonnull(int *borrow a) {
  return a;
}

int main(void) {
  int a = 10; 
  int *borrow p = &mut a;
  return_and_take_nonnull((int *borrow)p);
  return 0;
}