// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

void bsc_strcpy_s(char* borrow strDest, int destMax, const char* borrow strSrc) {
  *strDest = *strSrc;
}

int main(){
  char db[10] = {0};
  bsc_strcpy_s(&mut *db, 5, &const *"DB1");
  return 0;
}
