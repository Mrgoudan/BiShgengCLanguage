// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include <stdlib.h>

void safe_free(void *_Owned ptr) {
  free(__move_to_raw(ptr));
}

void test1(int *_Owned p) {
  int *_Borrow p1 = (int *_Borrow)(int *)((&_Mut *p));
  *p1 = 2;
  safe_free((void *_Owned)p);
}

// Use after free, but as expected.
// Borrow checker should not track that p1 borrows *p
void test2(int *_Owned p) {
  int *_Borrow p1 = (int *_Borrow)(int *)(&_Mut *p);
  safe_free((void *_Owned)p);
  *p1 = 2;
}

void test3(double *_Owned p) {
  int *_Borrow p1 = ((int *_Borrow)((int *)(double *)(&_Mut *p)));
  *p1 = 2;
  safe_free((void *_Owned)p);
}

int main(void) {
  int *_Owned p = __take_from_raw((int *)malloc(sizeof(int)));
  test1(p);
  return 0;
}