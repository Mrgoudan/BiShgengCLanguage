// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

typedef struct {
  int a;
} S;

static S *g = 0;

void memory_set(void *_Borrow p) {
}

void foo() {
  memory_set((void *_Borrow)(void *)g);
  memory_set((void *_Borrow)(void *)&*g);
}

int main(void) {
  foo();
  return 0;
}
