// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

// Test that multiple sequential reads of scalar fields through mutable borrows
// are allowed, since each read only borrows momentarily to copy the value.
// This tests the fix for incorrect ActionAssign classification of scalar
// assignments accessed through _Borrow derefs.

typedef struct System {
  unsigned short usYear;
  unsigned char ucMonth;
  unsigned char ucDate;
  unsigned int uiMillSec;
} SYSTEM_S;

typedef struct Date {
  unsigned short uwYear;
  unsigned char uwMonth;
  unsigned char ucDate;
} DATE_T;

// Macro that performs multiple sequential reads from the same source
#define GET(pstGmtTime, pDate, pulMillSecs) \
  do { \
    (pDate)->uwYear = (pstGmtTime)->usYear; \
    (pDate)->uwMonth = (pstGmtTime)->ucMonth; \
    (pDate)->ucDate = (pstGmtTime)->ucDate; \
    *(pulMillSecs) = (pstGmtTime)->uiMillSec; \
  } while (0)

// This function should compile without "cannot _Borrow as mutable more than once" errors
void GmTmGet(DATE_T *_Borrow pDate, unsigned int *_Borrow puiMillSecs) {
  SYSTEM_S stGmtTime = {2024, 1, 15, 1000};
  GET(&_Mut stGmtTime, pDate, puiMillSecs);
}

// Direct version without macro - should also work
void DirectRead(DATE_T *_Borrow pDate, unsigned int *_Borrow puiMillSecs) {
  SYSTEM_S stGmtTime = {2024, 1, 15, 1000};

  // Each _Borrow is independent and ends immediately after reading the scalar value
  SYSTEM_S *_Borrow tmp0 = &_Mut stGmtTime;
  pDate->uwYear = tmp0->usYear;

  SYSTEM_S *_Borrow tmp1 = &_Mut stGmtTime;
  pDate->uwMonth = tmp1->ucMonth;

  SYSTEM_S *_Borrow tmp2 = &_Mut stGmtTime;
  pDate->ucDate = tmp2->ucDate;

  SYSTEM_S *_Borrow tmp3 = &_Mut stGmtTime;
  *puiMillSecs = tmp3->uiMillSec;
}

int main() {
  DATE_T date;
  unsigned int millisecs;

  GmTmGet(&_Mut date, &_Mut millisecs);
  DirectRead(&_Mut date, &_Mut millisecs);

  return 0;
}
