// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

void foo(const char *_Borrow p) {}

void test1(void) {
  foo(__FUNCTION__);
  foo(__func__);
  foo(__PRETTY_FUNCTION__);
}

void test2(void) {
  foo(&_Const *__FUNCTION__);
  foo(&_Const *__func__);
  foo(&_Const *__PRETTY_FUNCTION__);
}

void test3(void) {
  const char *p1 = __FUNCTION__;
  foo(&_Const *p1);
  const char *p2 = __func__;
  foo(&_Const *p2);
  const char *p3 = __PRETTY_FUNCTION__;
  foo(&_Const *p3);
}

void test4(void) {
  char *p1 = __FUNCTION__;
  foo(&_Const *p1);
  char *p2 = __func__;
  foo(&_Const *p2);
  char *p3 = __PRETTY_FUNCTION__;
  foo(&_Const *p3);
}

void test5(void) {
  const char *_Borrow p1 = __FUNCTION__;
  foo(p1);
  const char *_Borrow p2 = __func__;
  foo(p2);
  const char *_Borrow p3 = __PRETTY_FUNCTION__;
  foo(p3);
}

const char *_Borrow test6(int *_Borrow dummy) {
  const char *_Borrow p = __FUNCTION__;
  return p;
}

const char *_Borrow test7(int *_Borrow dummy) {
  return &_Const *__FUNCTION__;
}

int main(void) {
  test1();
  test2();
  test3();
  test4();
  test5();
  const char *_Borrow p1 = test6(&_Mut (int){0});
  const char *_Borrow p2 = test7(&_Mut (int){0});
  return 0;
}
