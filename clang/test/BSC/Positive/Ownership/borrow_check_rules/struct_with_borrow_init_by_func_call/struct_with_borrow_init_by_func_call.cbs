// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

struct S {
    int *borrow p;
};

struct S struct S::new(int *borrow p) {
    struct S s = { .p = p };
    return s;
}
void use(struct S s) {}

int main() {
    int a = 5;
    int b = 10;
    struct S s = struct S::new(&mut a);
    use(s);
    s = struct S::new(&mut b);
    use(s);
    return 0;
}