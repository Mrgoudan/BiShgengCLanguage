// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics
#include <stdlib.h>
void use_mut(int *borrow p) {}

void test1() {
  int *a = (int *)malloc(sizeof(int));
  int *borrow p = &mut * a;
  free(a);  // We assume the virtual target of naked pointer live longer than all local variables
  use_mut(p);
}

void test2(int* a) {
  int *borrow p = &mut * a;
  free(a);
  use_mut(p);
}

void test3(int *borrow p) { // We assume the virtual target of borrow parameter live longer than all local variables
  int *borrow p1 = &mut * p;
  use_mut(p1);
}

int main() {
  int local = 5;
  int *a = (int *)malloc(sizeof(int));
  test1();
  test2(a);
  test3(&mut local);
  return 0;
}