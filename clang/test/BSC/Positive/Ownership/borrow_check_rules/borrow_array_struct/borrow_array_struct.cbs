// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

struct T {
  int * _Borrow _Nullable p;
};

_Safe void foo1(void) {
  struct T ptrarray[10] = {{.p=nullptr}};
  int a = 0;
  ptrarray[2].p = &_Mut a;
}

typedef struct {
  int len;
  int *ptr;
  int cap;
} vec;

int vec::length(const vec *_Borrow this);
void vec::push(vec *_Borrow this, int);

void test(vec v) {
  for (int i = 0; i < v.length(); i++) {
    v.push(2);
  }
}

int main() {
  foo1();
  return 0;
}
