// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

void foo(int *borrow a, int size) {
    *a = 2;
}

void test1() {
  int a = 1;
  foo(&mut a, sizeof(a));
}

void test2() {
  int a = 1;
  int x = sizeof(a);
  foo(&mut a, x);
}

void test3() {
  int a = 1;
  int *borrow p = &mut a;
  int x = sizeof(a);
  *p = 2;
}

int main() {
  test1();
  test2();
  test3();
  return 0;
}