	VOS_LIST_HEAD_S *pstListNodeTemp = 0;
	  VOS_LIST_FOR_EACH_ITEM_SAFE(pstListNode, pstListNodeTemp, &g_stMessageMemory.stMemList)
	{
		if (g_stMessageMemory.uiMemSize == 0) {
			break;
		}
		MESSAGE_MEMORY_LIST_NODE_S *pstMemFree = VOS_LIST_ENTRY(pstListNode, MESSAGE_MEMORY_LIST_NODE_S, stNode);

