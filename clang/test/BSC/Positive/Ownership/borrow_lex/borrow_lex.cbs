// RUN: %clang_cc1 -ast-dump -verify %s
// expected-no-diagnostics

void test() {
    int x = 0;
    int* xp = &x;
    float y = 1.0;
    float* yp = &y;
    int *_Borrow p1 = &mut x;            // legal
    int *_Borrow p2 = & mut x;
    int *_Borrow p3 = &mut *xp;          // legal
    int *_Borrow p4 = & mut *xp;
    const float * _Borrow p5 = &const y;   // legal
    const float * _Borrow p6 = & const y;
    const float * _Borrow p7 = &const *yp; // legal
    const float * _Borrow p8 = & const *yp;
}
