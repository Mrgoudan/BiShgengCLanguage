// RUN: %clang_cc1 -ast-dump -verify %s
// expected-no-diagnostics

void test() {
    int x = 0;
    int* xp = &x;
    float y = 1.0;
    float* yp = &y;
    int *_Borrow p1 = &_Mut x;            // legal
    int *_Borrow p2 = & _Mut x;
    int *_Borrow p3 = &_Mut *xp;          // legal
    int *_Borrow p4 = & _Mut *xp;
    const float * _Borrow p5 = &_Const y;   // legal
    const float * _Borrow p6 = & _Const y;
    const float * _Borrow p7 = &_Const *yp; // legal
    const float * _Borrow p8 = & _Const *yp;
}
