// RUN: %clang_cc1 -verify %s
// expected-no-diagnostics

_Safe void test_int(int *_Borrow p1, const int *_Borrow p2) {
  void * _Borrow v1 = p1;
  void * _Borrow v2 = (void * _Borrow)p1;
  const void * _Borrow c1 = p2;
  const void * _Borrow c2 = (const void * _Borrow)p2;
}

