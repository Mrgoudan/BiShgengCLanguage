// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

struct S<T> {
    int a;
    T *_Borrow b;
};

T *_Borrow test<T>(struct S<T> s) {
    return s.b;
}

int main(void) {
    int a = 2;
    struct S<int> s = { 1, &_Mut a };
    int *_Borrow p = test<int>(s);
    *p = 3;
    if (a == 3) return 0;
    return 1;
}