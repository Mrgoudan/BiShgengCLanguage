// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

// Umbrella IJP3AP F98: lowering a brace-less switch body must not reject valid
// programs. A brace-less body that initializes before the read, a single
// non-block statement, a brace-less default, nested brace-less switches, and
// plain braced switches (fallthrough / default) all stay clean.

_Safe void braceless_init_before_use(int x) {
    int a;
    switch (x) case 1: { a = 5; int y = a; (void)y; }
}

_Safe int braceless_single_stmt(int x) {
    switch (x) case 1: return 1;
    return 0;
}

_Safe void braceless_default_init(int x) {
    int a;
    switch (x) default: { a = 7; int y = a; (void)y; }
}

_Safe void braceless_two_labels_init(int x) {
    int a;
    switch (x) case 1: case 2: { a = 3; int y = a; (void)y; }
}

_Safe int braceless_nested_init(int x, int z) {
    int a = 0;
    switch (x) case 1: switch (z) case 2: { int y = a; (void)y; }
    return a;
}

_Safe int braced_switch_preserved(int x) {
    int a = 0;
    switch (x) {
      case 1:
      case 2: a = 1; break;
      default: a = 2;
    }
    return a;
}

_Safe void braceless_empty(int x) {
    switch (x) case 1: ;
}
