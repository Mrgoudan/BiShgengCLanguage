// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

// ==========================================================================
// Design: ensure_init_if_ret(VALUE) — callee side, positive tests (no errors)
// ==========================================================================

// Basic: init on return-0 path, skip on non-0.
int try_init(int *__attribute__((ensure_init_if_ret(0))) out) {
    *out = 42;
    return 0;
}

// Multi-branch: all return-0 paths initialize *out.
int try_init_branch(int cond, int *__attribute__((ensure_init_if_ret(0))) out) {
    if (cond) {
        *out = 1;
        return 0;
    }
    return -1;  // non-0: no obligation
}

// Non-0 return paths are unconstrained.
int try_init_complex(int a, int b, int *__attribute__((ensure_init_if_ret(0))) out) {
    if (a && b) {
        *out = a + b;
        return 0;
    }
    if (a) {
        return 1;   // no obligation
    }
    return 2;       // no obligation
}

// Bool variant.
_Bool try_read(_Bool cond, int *__attribute__((ensure_init_if_ret(1))) out) {
    if (cond) {
        *out = 99;
        return 1;
    }
    return 0;
}

// ensure_init_if_ret(0): obligation on the 0-return path.
_Bool provide_default(int *__attribute__((ensure_init_if_ret(0))) out) {
    *out = 0;
    return 0;
}

// Delegation: passing ensure_init_if_ret param to another ensure_init_if_ret function.
int inner_init(int *__attribute__((ensure_init_if_ret(0))) out);

int outer_init(int *__attribute__((ensure_init_if_ret(0))) out) {
    return inner_init(out);  // delegates the obligation
}

// Two params with different cond values: *a needed on ret==1,
// *b needed on ret==0. Each branch initialises only the param that
// branch's return actually obligates.
int mixed_cond_ok(int branch,
                  int *__attribute__((ensure_init_if_ret(1))) a,
                  int *__attribute__((ensure_init_if_ret(0))) b) {
    if (branch) {
        *a = 1;
        return 1;        // *a init, *b unconstrained
    }
    *b = 2;
    return 0;            // *b init, *a unconstrained
}
