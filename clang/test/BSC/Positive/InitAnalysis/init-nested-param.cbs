// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

// Test: struct parameters have all nested fields initialized.
// Accessing nested fields of parameters should not error.

struct Inner { int a; int b; };
struct Outer { struct Inner inner; int c; };

_Safe int test_param_nested(struct Outer o) {
    return o.inner.a + o.inner.b + o.c; // no error: params are initialized
}
