// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: FileCheck --input-file=%t-rw.c %s
// expected-no-diagnostics
#pragma GCC diagnostic push
#pragma GCC diagnostic ignored "-Ereturn-nullable"
_Safe int *_Borrow foo1(int *_Borrow _Nullable a) {
    return a;             // cannot return nullable pointer type
}
#pragma GCC diagnostic pop

// CHECK:      int * foo1(int * a) {
// CHECK-NEXT:     return a;
// CHECK-NEXT: }
// CHECK-EMPTY:
