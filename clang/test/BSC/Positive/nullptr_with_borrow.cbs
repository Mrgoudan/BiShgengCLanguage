// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

// Test nullptr with BSC _Borrow qualifiers

// nullptr with _Borrow in function parameters
void take_borrow(int * _Borrow p) {
  (void)p;
}

void test_nullptr_borrow_args(void) {
  take_borrow((int * _Borrow)nullptr);
  take_borrow(nullptr);
}

// nullptr with const _Borrow
void take_const_borrow(const int * _Borrow p) {
  (void)p;
}

void test_nullptr_const_borrow(void) {
  take_const_borrow((const int * _Borrow)nullptr);
  take_const_borrow(nullptr);
}

// nullptr _Borrow in function return (requires _Borrow parameter)
int * _Borrow return_borrow_nullptr(int * _Borrow dummy) {
  (void)dummy;
  return (int * _Borrow)nullptr;
}

void * _Borrow return_void_borrow_nullptr(void * _Borrow dummy) {
  (void)dummy;
  return (void * _Borrow)nullptr;
}

// Struct with _Borrow pointers initialized to nullptr
struct BorrowPointers {
  int * _Borrow bp;
  void * _Borrow vb;
};

void test_struct_borrow_nullptr(void) {
  struct BorrowPointers sb = {
    (int * _Borrow)nullptr,
    (void * _Borrow)nullptr
  };
  (void)sb;
}

// nullptr _Borrow in conditional
void test_borrow_conditional(int condition) {
  int * _Borrow p = condition ? (int * _Borrow)nullptr : nullptr;
  (void)p;
}

// nullptr with multiple _Borrow pointers
void take_multiple_borrow(int * _Borrow p1, void * _Borrow p2, char * _Borrow p3) {
  (void)p1;
  (void)p2;
  (void)p3;
}

void test_multiple_borrow_nullptr(void) {
  take_multiple_borrow(
    (int * _Borrow)nullptr,
    (void * _Borrow)nullptr,
    (char * _Borrow)nullptr
  );
}
