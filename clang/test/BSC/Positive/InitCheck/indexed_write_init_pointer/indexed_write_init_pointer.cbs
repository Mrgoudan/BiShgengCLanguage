// RUN: %clang_cc1 -verify %s
// expected-no-diagnostics

// The dest-side Index check must not reject writes through an initialized
// pointer field, nor element writes into a real array (which loads no pointer).

struct S { int *_Borrow _ArrayElem p; };

_Safe void init_pointer_field(int c) {
  int arr[10] = {0};
  struct S s;
  s.p = &_Mut arr[0];
  s.p[c] = 5;
}

_Safe void real_array_element(int i) {
  int arr[10] = {0};
  arr[i] = 5;
}
