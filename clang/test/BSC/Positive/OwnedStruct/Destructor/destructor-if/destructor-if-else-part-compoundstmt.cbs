// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

int g_flag = 0x2;
_Owned struct S {
_Public:
    ~S(S this) {
        g_flag--;
    }
};
int foo() {
  if (1) {
    S s1 = {};
  }
  else if (0) {
    S s1 = {};
  }
  return 0;
}

int goo() {
  if (0) {
    S s1 = {};
  } else if (0) {
    S s1 = {};
  } else {
    S s1 = {};
  }
  
  return 0;
}
int main() {
    foo();
    goo();
    return g_flag;
}