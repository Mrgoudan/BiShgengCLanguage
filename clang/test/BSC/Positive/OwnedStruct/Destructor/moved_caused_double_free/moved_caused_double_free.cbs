// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: FileCheck --input-file=%t-rw.c %s
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// RUN: gcc %t-rw.c -o %t-rw.output
// expected-no-diagnostics
owned struct C {};

owned struct A {
public:
    int* y;
    C x;
};

int main() {
    int m = 5;
    C c1 = {};
    A a1 = { .y = &m, .x = c1 };
    return 0;
}

//CHECK:      struct C;
//CHECK-NEXT: struct A;
//CHECK-NEXT: struct C {
//CHECK-NEXT: };
//CHECK-EMPTY: 
//CHECK-NEXT: struct A {
//CHECK-NEXT:     int *y;
//CHECK-NEXT:      struct C x;
//CHECK-NEXT: };
//CHECK-EMPTY: 
//CHECK-NEXT: void struct_C_D( struct C this);
//CHECK-EMPTY: 
//CHECK-NEXT: void struct_A_D( struct A this);
//CHECK-EMPTY: 
//CHECK-NEXT: int main(void) {
//CHECK-NEXT:     int m = 5;
//CHECK-NEXT:      struct C c1 = {};
//CHECK-NEXT:     _Bool c1_is_moved = 0;
//CHECK-NEXT:      struct A a1 = {.y = &m, .x = c1};
//CHECK-NEXT:     _Bool a1_is_moved = 0;
//CHECK-NEXT:     c1_is_moved = 1;
//CHECK-NEXT:     if (!a1_is_moved)
//CHECK-NEXT:         struct_A_D(a1);
//CHECK-NEXT:     if (!c1_is_moved)
//CHECK-NEXT:         struct_C_D(c1);
//CHECK-NEXT:     return 0;
//CHECK-NEXT: }
//CHECK-EMPTY: 
//CHECK-NEXT: void struct_C_D( struct C this) {
//CHECK-NEXT: }
//CHECK-EMPTY: 
//CHECK-NEXT: void struct_A_D( struct A this) {
//CHECK-NEXT:     struct_C_D(this.x);
//CHECK-NEXT: }
