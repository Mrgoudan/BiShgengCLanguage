// RUN: %t-rw.output

_Owned struct B<T> {
    ~B(B<T> this) {

    }
};
_Owned struct A<T> {
public:
    B<int> buf;
~A(A<T> this) {
    }
};

int main() {
A<int> m = {};
return 0;
}

