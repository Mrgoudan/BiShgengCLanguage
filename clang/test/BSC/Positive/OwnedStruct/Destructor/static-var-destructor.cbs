// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
int y  = 0;
_Owned struct B{
    ~B(B this){
       y=y+2;
    }
};
_Owned struct A {
public:
  ~A( A this) {
    y++;
  }
};

_Owned struct C<T> {
    ~C( C<T> this) {
    y++;
  }
};

int main() {
  static C<int> c = {};
  static B b ={};
  A a ={};
  return y-1;
}