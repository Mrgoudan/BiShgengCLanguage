// RUN: %clang %s -o %test.output
// RUN: %test.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

owned struct C {
    public:
    int f(C* this) { return this->a; } 
    int a;
    int g(C* this) { return this->f(); }
};

int main() {
   C c = {3};
   int ret = c.f() -3;
   return ret;
}