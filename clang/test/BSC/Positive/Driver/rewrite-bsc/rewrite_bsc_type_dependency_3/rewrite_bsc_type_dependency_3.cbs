// CHECK-NEXT:   struct _BSC_ListNode_struct_Vec_int *tail;
// CHECK-NEXT:   int len;
// CHECK-NEXT: };
// CHECK-EMPTY:
// CHECK-NEXT: struct RawVec_int {
// CHECK-NEXT:   int *ptr;
// CHECK-NEXT:   int cap;
// CHECK-NEXT: };
// CHECK-EMPTY:
