// CHECK-NEXT:    int a1_1 = foo1_n5();
// CHECK-NEXT:    int a2 = foo2_5();
// CHECK-NEXT:    int a3_0 = foo3_5();
// CHECK-NEXT:    int a3_1 = foo3_n5();
// CHECK-NEXT:    int a4_0 = foo4_int_5();
// CHECK-NEXT:    int a4_1 = foo4_int_n5();
