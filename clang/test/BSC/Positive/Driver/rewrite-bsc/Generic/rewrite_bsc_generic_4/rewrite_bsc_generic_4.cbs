// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: FileCheck --input-file=%t-rw.c %s
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

struct Block
{
    int a;
};

void test<T>(T a)
{
  int c = 1;
}

int main() {
  int b1 = 2;
  struct Block bb;
  test<struct Block>(bb);
}


// CHECK:struct Block {
// CHECK-NEXT:    int a;
// CHECK-NEXT:};


// CHECK:void __attribute__((weak)) test_struct_Block(struct Block a)   {
// CHECK-NEXT:      int c = 1;
// CHECK-NEXT:  }


// CHECK:int main(void) {
// CHECK-NEXT:  int b1 = 2;
// CHECK-NEXT:  struct Block bb;
// CHECK-NEXT:  test_struct_Block(bb);
// CHECK-NEXT:}
