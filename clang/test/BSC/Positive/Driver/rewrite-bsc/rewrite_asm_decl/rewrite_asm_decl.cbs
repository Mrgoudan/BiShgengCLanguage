// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: FileCheck --input-file=%t-rw.c %s
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

void swap_contexts();
__asm__ (
    "swap_contexts:;"
    "ret;"
);

int main() {
  swap_contexts();
  return 0;
}


// CHECK: void swap_contexts(void);
// CHECK-EMPTY:
// CHECK-NEXT: __asm ("swap_contexts:;ret;");
// CHECK-EMPTY:
// CHECK-NEXT: int main(void) {
// CHECK-NEXT:     swap_contexts();
// CHECK-NEXT:     return 0;
// CHECK-NEXT: }
