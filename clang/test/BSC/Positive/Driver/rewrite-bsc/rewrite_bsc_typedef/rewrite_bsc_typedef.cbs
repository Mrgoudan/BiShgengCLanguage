// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: FileCheck --input-file=%t-rw.c %s
// RUN: %clang %t-rw.c -I %S -o %t-rw.output
// RUN: %t-rw.output


struct S<T> {};
typedef struct {
  struct S<int> a;
}MyStruct;

typedef union {
  int a;
}MyUnion;

typedef enum {
  X1,
  X2
}MyEnum;

int main() {
  return 0;
}



// CHECK: struct S_int {
// CHECK-NEXT:};
// CHECK-EMPTY:
// CHECK-NEXT:struct MyStruct {
// CHECK-NEXT:    struct S_int a;
// CHECK-NEXT:};
// CHECK-EMPTY:
// CHECK-NEXT:typedef struct MyStruct MyStruct;
// CHECK-EMPTY:
// CHECK-NEXT:typedef union {
// CHECK-NEXT:  int a;
// CHECK-NEXT:}MyUnion;
// CHECK-EMPTY:
// CHECK-NEXT:typedef enum {
// CHECK-NEXT:  X1,
// CHECK-NEXT:  X2
// CHECK-NEXT:}MyEnum;
// CHECK-EMPTY:
// CHECK-NEXT:int main() {
// CHECK-NEXT:    return 0;
// CHECK-NEXT:}
