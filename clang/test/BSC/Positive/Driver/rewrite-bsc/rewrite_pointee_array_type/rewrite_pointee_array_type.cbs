// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: FileCheck --input-file=%t-rw.c %s
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

struct T<T1, T2, T3> {
  T1 (*a[2])[5];
  T2 (**b)[2];
  T3 (*c)[5];
};

struct S { 
  int a;
};

struct M { 
  int a;
};

struct N {
  int a;
};

void test(T<struct S, struct M, struct N> t) {
}

int main() {
    T<struct S, struct M, struct N> t;
    test(t);
    return 0;
}

