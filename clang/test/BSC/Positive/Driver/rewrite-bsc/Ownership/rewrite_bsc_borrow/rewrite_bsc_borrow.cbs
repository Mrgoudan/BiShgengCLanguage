// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: FileCheck --input-file=%t-rw.c %s
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

struct R {
    int * borrow p1;
    const int * borrow p2;
};

void int::foo(This * borrow this) {}

typedef int * borrow myInt;
typedef int* borrow (*PF2)(struct R);

void test() {
    int x = 0;
    float y = 1.0;
    int * borrow p = &mut x;
    float * borrow p1 = &mut y;
    const int * borrow p2 = &const x;
    myInt p3 = p;
    const int * borrow p4= (const int * borrow)&x;

    int * owned p5 = (int * owned)&x;
    const int * borrow b6 = &const *p3;
    int * borrow p7 = &mut *(&x);
    p7 = &mut *p;
    int * p8 = (int *)p5;
}

int main() {
    return 0;
}

// CHECK: struct R {
// CHECK-NEXT:     int * p1;
// CHECK-NEXT:     const int * p2;
// CHECK-NEXT: };
// CHECK-EMPTY:
// CHECK-NEXT: typedef int * myInt;
// CHECK-EMPTY:
// CHECK-NEXT: typedef int * (*PF2)(struct R);
// CHECK-EMPTY:
// CHECK-NEXT: void int_foo(int * this) {
// CHECK-NEXT: }
// CHECK-EMPTY:
// CHECK-NEXT: void test(void) {
// CHECK-NEXT:     int x = 0;
// CHECK-NEXT:     float y = 1.;
// CHECK-NEXT:     int * p = &x;
// CHECK-NEXT:     float * p1 = &y;
// CHECK-NEXT:     const int * p2 = &x;
// CHECK-NEXT:     int * p3 = p;
// CHECK-NEXT:     const int * p4 = (const int *)&x;
// CHECK-NEXT:     int * p5 = (int *)&x;
// CHECK-NEXT:     const int * b6 = &*p3;
// CHECK-NEXT:     int * p7 = &*(&x);
// CHECK-NEXT:     p7 = &*p;
// CHECK-NEXT:     int *p8 = (int *)p5;
// CHECK-NEXT: }
