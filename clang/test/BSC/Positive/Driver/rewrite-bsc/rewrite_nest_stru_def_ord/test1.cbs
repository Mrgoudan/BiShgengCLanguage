struct out{
    struct A a;
    struct B b;
    struct C c;
    struct D d;
    struct E e;
    struct F f ;
    struct G g;
    struct H h;
    struct I i;
    struct J j;
    struct K k;
    struct L l;
    struct M m;
};

int main(){
    struct out o = {};
    return 0;
}
