// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: FileCheck --input-file=%t-rw.c %s
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

//test1
const int( * const q)(int const a,const float b,const int c , const int d);

//test2
const int( * const p)(const int* owned const a,const float b,const int c , const int d);

//test3
int add(int a, int b) { return a + b; }
int sub(int a, int b) { return a - b; }
int mul(int a, int b) { return a * b; }
int (*ops[])(int const a, int const b) = { add, sub, mul };

//test4
typedef int myint;
typedef Myfloat = float;
const myint( * const qs)(myint const a,const Myfloat b,const myint c , const myint d);

int main(){
    return 0;
}
