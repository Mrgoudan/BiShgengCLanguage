// RUN: %clang_cc1 -verify %s
// expected-no-diagnostics

// Test that nullptr can be used with parentheses for owned and _Borrow pointers

// Owned pointer tests
int *owned foo_owned() {
  return (nullptr);
}

int *owned bar_owned() {
  return nullptr;
}
int *_Borrow foo_borrow(int * _Borrow a) {
  return (nullptr);
}

int *_Borrow bar_borrow(int * _Borrow a) {
  return nullptr;
}

void test_owned_nullptr() {
  int *owned p1 = nullptr;
  int *owned p2 = (nullptr);
  int *owned p3 = ((nullptr));  // Double parentheses also work
}

// Borrow pointer tests
void test_borrow_nullptr() {
  int *_Borrow b1 = nullptr;
  int *_Borrow b2 = (nullptr);
  int *_Borrow b3 = ((nullptr));  // Double parentheses also work
}

// Test assignment
void test_assignment() {
  int *owned o = nullptr;
  o = (nullptr);
  o = ((nullptr));

  int *_Borrow b = nullptr;
  b = (nullptr);
  b = ((nullptr));
}
