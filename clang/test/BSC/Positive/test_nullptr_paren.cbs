// RUN: %clang_cc1 -verify %s
// expected-no-diagnostics

// Test that nullptr can be used with parentheses for owned and borrow pointers

// Owned pointer tests
int *owned foo_owned() {
  return (nullptr);
}

int *owned bar_owned() {
  return nullptr;
}
int *borrow foo_borrow(int * borrow a) {
  return (nullptr);
}

int *borrow bar_borrow(int * borrow a) {
  return nullptr;
}

void test_owned_nullptr() {
  int *owned p1 = nullptr;
  int *owned p2 = (nullptr);
  int *owned p3 = ((nullptr));  // Double parentheses also work
}

// Borrow pointer tests
void test_borrow_nullptr() {
  int *borrow b1 = nullptr;
  int *borrow b2 = (nullptr);
  int *borrow b3 = ((nullptr));  // Double parentheses also work
}

// Test assignment
void test_assignment() {
  int *owned o = nullptr;
  o = (nullptr);
  o = ((nullptr));

  int *borrow b = nullptr;
  b = (nullptr);
  b = ((nullptr));
}
