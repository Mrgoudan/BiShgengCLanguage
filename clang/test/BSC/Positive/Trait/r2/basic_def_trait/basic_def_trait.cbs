// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: FileCheck --input-file=%t-rw.c %s
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

#include <stdio.h>

trait TR {
  void sayHi(This* this);
  int getAns(This* this, int x);
};

void int::sayHi(int* this) {
  printf("Hi\n");
}

int int::getAns(int* this, int x) {
  return x;
}

impl trait TR for int;

int main() {
  int x = 42;
  x.sayHi();
  int y = x.getAns(2023);
  printf("y: %d\n", y);
  return 0;
}

// CHECK: struct __Trait_TR_Vtable {
// CHECK-NEXT: void (*sayHi)(void *);
// CHECK-NEXT: int (*getAns)(void *, int);
// CHECK-NEXT: };

// CHECK: struct __Trait_TR {
// CHECK-NEXT: void *data;
// CHECK-NEXT: struct __Trait_TR_Vtable *vtable;
// CHECK-NEXT: ;

// CHECK: void int_sayHi(int *this) {
// CHECK-NEXT: printf("Hi\n");
// CHECK-NEXT: }

// CHECK: int int_getAns(int *this, int x) {
// CHECK-NEXT: return x;
// CHECK-NEXT: }
 
// CHECK: struct __Trait_TR_Vtable __int_trait_TR = {.sayHi = (void (*)(void *))int_sayHi, .getAns = (int (*)(void *, int))int_getAns};

// CHECK: int main(void) {
// CHECK-NEXT: int x = 42;
// CHECK-NEXT: int_sayHi(&x);
// CHECK-NEXT: int y = int_getAns(&x, 2023);
// CHECK-NEXT: printf("y: %d\n", y);
// CHECK-NEXT: return 0;
// CHECK-NEXT: }
