// RUN: %clang %s -o %t.output
// RUN: %t.output
// expected-no-diagnostics

_Trait F {
   void foo(This *this);
};

struct S<T> {
  _Trait F* t;
};

void int::foo(This *this) {}

_Impl _Trait F for int;

_Trait F* get1<T>(_Trait F* t1, _Trait F* t2) {
    return t1;
}

int main()
{
    int a = 1;
    const int *p = &a;
    _Trait F* t1 = p;
    t1 = (_Trait F*)p;
    t1->foo();
    if (t1 != p) {
        return 1;
    }
    struct S<int> s = { p };
    struct S<int> s1 = { .t = p };
    s.t = p;
    _Trait F* p5 = get1<double>((_Trait F*)p, p);
    return 0;
}


