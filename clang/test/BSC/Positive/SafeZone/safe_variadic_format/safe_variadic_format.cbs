// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

typedef __builtin_va_list va_list;
#define va_start(ap, param) __builtin_va_start(ap, param)
#define va_arg(ap, type) __builtin_va_arg(ap, type)
#define va_end(ap) __builtin_va_end(ap)

// Forward declarations for memory functions (no need for actual implementation in syntax-only test)
extern void *malloc(unsigned long);
extern void free(void *);
extern void exit(int);

// Helper functions for memory management
_Safe T *_Owned safe_malloc<T>(T t) {
    _Unsafe {
        T *addr = (T *)malloc(sizeof(T));
        if (!addr) {
            exit(1);
        }
        *addr = t;
        return (T *_Owned)addr;
    }
}

_Safe T *_Owned safe_free<T>(T *_Owned p) {
    _Unsafe {
        free((void *)p);
        T *_Owned null_ptr = (T *_Owned)(void *)0;
        return null_ptr;
    }
}

// Printf-style variadic function with format attribute allowed in safe zone
_Safe int my_safe_printf(const char * _Borrow fmt, ...)__attribute__((format(printf, 1, 2)));

// Declaration and definition
__attribute__((format(printf, 1, 2)))
_Safe int my_safe_printf2(const char * _Borrow fmt, ...) {
    return 0;
}

// Scanf-style variadic function with format attribute allowed in safe zone
__attribute__((format(scanf, 1, 2)))
_Safe int my_safe_scanf(const char * _Borrow fmt, ...);

// Function pointer with format attribute
__attribute__((format(printf, 1, 2)))
_Safe int (*safe_printf_ptr)(const char * _Borrow fmt, ...);

// Multiple format attributes
__attribute__((format(printf, 1, 2)))
__attribute__((format(printf, 1, 2)))
_Safe int multi_format(const char * _Borrow fmt, ...);

// Test calling format-attributed _Safe variadic function from _Safe zone
_Safe void test_caller(void) {
    my_safe_printf(&_Const *"hello %d", 42);
    my_safe_printf2(&_Const *"world %s", "test");
}

// Test passing _Borrow pointers to variadic functions
__attribute__((format(printf, 1, 2)))
_Safe void log_with_borrow(const char * _Borrow fmt, ...);

_Safe void test_with_borrow_ptr(int * _Borrow ptr) {
    // Test: _Borrow pointers can be passed to variadic functions
    log_with_borrow(&_Const *"Value: %d", *ptr);
}

// Test that variadic functions can be declared with _Owned pointer parameters in signature
struct Point {
    int x;
    int y;
};

__attribute__((format(printf, 2, 3)))
_Safe void log_point(const struct Point * _Borrow p, const char * _Borrow fmt, ...);

_Safe void test_point_logging(void) {
    const struct Point pt = {10, 20};
    const struct Point * _Borrow pborrow = &_Const pt;
    log_point(pborrow, &_Const *"Coordinates: %d, %d", pt.x, pt.y);
}

// Test declaration with format attr, definition also with attr
__attribute__((format(printf, 1, 2)))
_Safe void decl_has_attr(const char * _Borrow fmt, ...);

__attribute__((format(printf, 1, 2)))
_Safe void decl_has_attr(const char * _Borrow fmt, ...) {
    return;
}

// Test multiple declarations, all with format attr
__attribute__((format(printf, 1, 2)))
_Safe void multi_decl(const char * _Borrow fmt, ...);

__attribute__((format(printf, 1, 2)))
_Safe void multi_decl(const char * _Borrow fmt, ...);

__attribute__((format(printf, 1, 2)))
_Safe void multi_decl(const char * _Borrow fmt, ...) {
    return;
}

// va_start, va_arg, va_end are allowed in UNSAFE zone
int unsafe_variadic_function(const char * _Borrow fmt, ...) {
    va_list args;
    va_start(args, fmt);
    int val = va_arg(args, int);
    va_end(args);
    return val;
}

// Using variadic operations inside _Unsafe block
__attribute__((format(printf, 1, 2)))
_Safe void test_variadic_in_unsafe_block(const char * _Borrow fmt, ...) {
    _Unsafe {
        va_list args;
        va_start(args, fmt);
        int val = va_arg(args, int);
        va_end(args);
    }
}

__attribute__((format(printf, 1, 2)))
_Safe void test_variadic_in_unsafe_block2(const char * _Borrow fmt, ...);

_Safe void test_variadic_in_unsafe_block2(const char * _Borrow fmt, ...) {
    _Unsafe {
        va_list args;
        va_start(args, fmt);
        int val = va_arg(args, int);
        va_end(args);
    }
}
