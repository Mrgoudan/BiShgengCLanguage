// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

_Safe void test_raw_nullable(void) {
  void * _Nullable ptr = ((nullptr));
  int * _Nullable ip = (nullptr);
  (void)ptr;
  (void)ip;
}

_Safe void test_owned_nullable(void) {
  void * _Owned _Nullable ptr = (nullptr);
  int * _Owned _Nullable ip = (((nullptr)));
  (void)ptr;
  (void)ip;
}

_Safe void test_borrow_nullable(void) {
  int * _Borrow _Nullable bp = ((((nullptr))));
  void * _Borrow _Nullable vbp = (((nullptr)));
  (void)bp;
  (void)vbp;
}

_Safe void test_const_borrow_nullable(void) {
  const int * _Borrow _Nullable cbp = (((nullptr)));
  const void * _Borrow _Nullable cvbp = (nullptr);
  (void)cbp;
  (void)cvbp;
}
