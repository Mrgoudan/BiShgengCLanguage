// RUN: %clang_cc1 -fsyntax-only -verify -xbsc %s

// expected-no-diagnostics

_Owned struct S<T> {
private:
  T *ptr;
public:
  _Unsafe T *pointer(const This *_Borrow this);
};


inline _Unsafe T *S<T>::pointer(const This *_Borrow this) {
  return this->ptr;
}

_Owned struct B<T> {
private:
  T val; 
public:
  _Safe T value(const This *_Borrow this);
};

inline _Safe T B<T>::value(const This *_Borrow this) {
  return this->val;
}

void test(S<int> s,B<int> b) {
  int *p = s.pointer();
  int i = b.value();
}