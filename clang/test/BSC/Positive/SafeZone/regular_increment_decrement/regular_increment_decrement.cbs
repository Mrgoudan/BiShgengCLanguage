// RUN: %clang -c %s
// expected-no-diagnostics

_Safe void read(int i);

_Safe void test_basic(void) {
  int a = 0;
  a++;
  ++a;
  a--;
  --a;
}

_Safe void for_loop(void) {
  int arr[5] = {1, 2, 3, 4, 5};

  // forward for loop
  for (int i = 0; i < 5; i++) {
    read(_Unsafe(arr[i]));
  }
  // backward for loop
  for (int i = 4; i >= 0; i--) {
    read(_Unsafe(arr[i]));
  }

}

_Safe void while_loop(void) {
  int arr[5] = {1, 2, 3, 4, 5};

  // forward while loop
  int j = 0;
  while (j < 5) {
    read(_Unsafe(arr[j]));
    j++;
  }

  // backward while loop
  j = 4;
  while (j >= 0) {
    read(_Unsafe(arr[j]));
    j--;
  }
}

_Safe void do_while_loop(void) {
  int arr[5] = {1, 2, 3, 4, 5};
  // forward do-while loop
  int k = 0;
  do {
    read(_Unsafe(arr[k]));
    ++k;
  } while (k < 5);

  // backward do-while loop
  k = 4;
  do {
    read(_Unsafe(arr[k]));
    --k;
  } while (k >= 0);
}

_Safe void altered_while_loop(void) {
  int arr[5] = {1, 2, 3, 4, 5};
  int i = 5;
  while ((i--, i+1) > 0) {
    read(_Unsafe(arr[i]));
  }

  i = 5;
  while ((--i, i) >= 0) {
    read(_Unsafe(arr[i]));
  }

  i = -1;
  while ((++i, i) < 5) {
    read(_Unsafe(arr[i]));
  }

  i = 0;
  while (i < 5) {
    read(_Unsafe(arr[(i++, i-1)]));
  }

  i = -1;
  while (i < 4) {
    read(_Unsafe(arr[(++i, i)]));
  }

  i = 5;
  while (i > 0) {
    read(_Unsafe(arr[(--i, i)]));
  }

  i = 4;
  while (i >= 0) {
    read(_Unsafe(arr[(i--, i+1)]));
  }
}

_Safe void altered_for_loop(void) {
  int arr[5] = {1, 2, 3, 4, 5};
  for (int j = 5; (j--, j+1) > 0;) {
    read(_Unsafe(arr[j]));
  }

  for (int j = 5; (--j, j) >=0;) {
    read(_Unsafe(arr[j]));
  }

  for (int j = -1; (++j, j) < 5;) {
    read(_Unsafe(arr[j]));
  }

  for (int j = 0; j < 5;) {
    read(_Unsafe(arr[(j++, j-1)]));
  }

  for (int j = -1; j < 4;) {
    read(_Unsafe(arr[(++j, j)]));
  }
}

_Safe void altered_do_while_loop(void) {
  int arr[5] = {1, 2, 3, 4, 5};
  int i = 0;
  do {
    read(_Unsafe(arr[i]));
  } while ((++i, i) < 5);

  i = 5;
  do {
    read(_Unsafe(arr[i-1]));
  } while ((--i, i) > 0);

  i = 4;
  do {
    read(_Unsafe(arr[i]));
  } while ((i--, i+1) > 0);

  i = 0;
  do {
    read(_Unsafe(arr[(i++, i-1)]));
  } while (i < 5);

  i = -1;
  do {
    read(_Unsafe(arr[(++i, i)]));
  } while (i < 4);
}