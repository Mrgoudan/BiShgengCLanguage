// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang_cc1 -triple x86_64-unknown-unknown -ast-dump %s \
// RUN: | FileCheck --strict-whitespace %s
// expected-no-diagnostics

_Owned struct RawVec<T> {
public:
  T a;
  _Safe ~RawVec(This this) {}
};

_Safe int test<T>(void) {
  _Unsafe {
    RawVec<int> rv = { .a = 1};
  }
  return 0;
}

int main() {
  int a = test<int>();
  return 0;
}

// CHECK:      FunctionDecl 0x{{[^ ]*}} <line:13:1, line:18:1> line:13:11 used test 'int (void)' _Safe
// CHECK-NEXT: TemplateArgument type 'int'
// CHECK-NEXT: BuiltinType 0x{{[^ ]*}} 'int'
// CHECK-NEXT: CompoundStmt 0x{{[^ ]*}} <col:25, line:18:1>
// CHECK-NEXT: CompoundStmt 0x{{[^ ]*}} <line:14:11, line:16:3> _Unsafe
// CHECK-NEXT: DeclStmt 0x{{[^ ]*}} <line:15:5, col:31>
// CHECK-NEXT: VarDecl 0x{{[^ ]*}} <col:5, col:30> col:17 used rv '_Owned RawVec<int>':'_Owned struct RawVec<int>' cinit
// CHECK-NEXT: InitListExpr 0x{{[^ ]*}} <col:22, col:30> '_Owned RawVec<int>':'_Owned struct RawVec<int>'
// CHECK-NEXT: IntegerLiteral 0x{{[^ ]*}} <col:29> 'int' 1
