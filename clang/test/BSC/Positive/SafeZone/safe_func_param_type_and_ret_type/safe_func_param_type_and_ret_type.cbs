// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang %s -o %t-rw.c -rewrite-bsc
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output
// expected-no-diagnostics

struct S {
  int *a;
};

struct T {
  struct S s;
};

union U {
  int a;
  struct {
    int b;
  } b;
};

_Safe int *f1(int *a) {
  return a;
}

_Safe struct S f2(struct S s) {
  return s;
}

_Safe struct T f3(struct T t) {
  return t;
}

_Safe struct S *f4(struct S *s) {
  return s;
}

_Safe struct T *f5(struct T *t) {
  return t;
}

_Safe struct S *owned f6(struct S *owned sp) {
  return sp;
}

_Safe struct T *owned f7(struct T *owned tp) {
  return tp;
}

_Safe struct S *_Borrow f8(struct S *_Borrow sp) {
  return sp;
}

_Safe struct T *_Borrow f9(struct T *_Borrow tp) {
  return tp;
}

_Safe union U f10(union U u) {
  return u;
}

_Safe union U *owned f11(union U *owned up) {
  return up;
}

_Safe union U *_Borrow f12(union U *_Borrow up) {
  return up;
}

int main(void) {
  return 0;
}