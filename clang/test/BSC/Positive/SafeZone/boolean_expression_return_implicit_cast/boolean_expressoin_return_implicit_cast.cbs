// RUN: %clang -cc1 %s
// expected-no-diagnostics

_Safe char ret_c(int x) { return x == 0; }
_Safe signed char ret_sc(int x) { return x == 0; }
_Safe unsigned char ret_uc(int x) { return x == 0; }
_Safe short ret_s(int x) { return x == 0; }
_Safe unsigned short ret_us(int x) { return x == 0; }
_Safe int ret_i(int x) { return x == 0; }
_Safe unsigned int ret_ui(int x) { return x == 0; }
_Safe long ret_l(int x) { return x == 0; }
_Safe unsigned long ret_ul(int x) { return x == 0; }
_Safe long long ret_ll(int x) { return x == 0; }
_Safe unsigned long long ret_ull(int x) { return x == 0; }

_Safe char ret_complex_c(int x) { return !x && x > 100 ? x <= 0 || x > -10 : x > 200 && x <= 500; }
_Safe signed char ret_complex_sc(int x) { return !x && x > 100 ? x <= 0 || x > -10 : x > 200 && x <= 500; }
_Safe unsigned char ret_complex_uc(int x) { return !x && x > 100 ? x <= 0 || x > -10 : x > 200 && x <= 500; }
_Safe short ret_complex_s(int x) { return !x && x > 100 ? x <= 0 || x > -10 : x > 200 && x <= 500; }
_Safe unsigned short ret_complex_us(int x) { return !x && x > 100 ? x <= 0 || x > -10 : x > 200 && x <= 500; }
_Safe int ret_complex_i(int x) { return !x && x > 100 ? x <= 0 || x > -10 : x > 200 && x <= 500; }
_Safe unsigned int ret_complex_ui(int x) { return !x && x > 100 ? x <= 0 || x > -10 : x > 200 && x <= 500; }
_Safe long ret_complex_l(int x) { return !x && x > 100 ? x <= 0 || x > -10 : x > 200 && x <= 500; }
_Safe unsigned long ret_complex_ul(int x) { return !x && x > 100 ? x <= 0 || x > -10 : x > 200 && x <= 500; }
_Safe long long ret_complex_ll(int x) { return !x  && x > 100? x <= 0  || x > -10 : x > 200 && x <= 500; }
_Safe unsigned long long ret_complex_ull(int x) { return !x  && x > 100? x <= 0  || x > -10 : x > 200 && x <= 500; }