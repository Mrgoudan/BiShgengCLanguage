// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

// Test that unions can be declared, initialized, and used as function parameters/returns in safe zones

union U {
  int x;
  float y;
};

// Union as parameter type in safe function
safe void test_union_param(union U u) {
  // We can pass union but not access its members
}

// Union as return type in safe function
safe union U test_union_return(void) {
  union U u = {0};
  return u;
}

// Union declaration and initialization in safe zone
safe void test_union_decl(void) {
  // ok: declare union type in safe zone
  union ULocal {
    int a;
    char b;
  };

  // ok: initialize union in safe zone (must be initialized in safe zone)
  union U u1 = {0};
  union U u2 = {0};
  union U u3 = {.x = 5};
  union U u4 = {};

  // ok: assign union (not member access)
  u1 = u2;

  // ok: use union in unsafe expression within safe zone
  int ignored1 = unsafe(u3.x = 10);
  int ignored2 = unsafe(u3.x);
}

// Struct containing union is allowed in safe zone
safe void test_struct_with_union(void) {
  struct S {
    union U u;
    int x;
  };

  struct S s = {0};
  // ok: access struct member that is not a union
  s.x = 5;
}

// Union pointer types in safe zone
safe union U *owned test_union_pointers(union U *owned p2_param, union U *borrow p3_param) {
  // ok: owned pointer to union as parameter and return type
  // ok: borrow pointer to union (from parameter)
  union U *borrow p3 = p3_param;
  return p2_param;
}

// Array of unions in safe zone
safe void test_union_array(void) {
  // ok: initialize array of unions (must be initialized in safe zone)
  union U arr[5] = {};
  union U arr2[3] = {};
}

// Typedef of union in safe zone
typedef union U UType;

safe void test_union_typedef(void) {
  // ok: use typedef
  UType u = {0};
}

// Nested union definitions in safe zone
safe void test_nested_union(void) {
  struct Outer {
    union Inner {
      int x;
      float y;
    } u;
    int z;
  };

  struct Outer o = {0};
  // ok: access non-union member
  o.z = 10;
}

int main(void) {
  union U u = {0};
  safe {
    // ok: pass union to safe function
    test_union_param(u);

    // ok: get union from safe function
    union U u2 = test_union_return();
  }
  return 0;
}
