// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

// Safe zone arithmetic and type conversion rules.

// Rule 1: Arithmetic to _Bool (zero -> 0, non-zero -> 1)
_Safe void rule1_bool(void) {
  int b = 0;
  _Bool c = (_Bool)b;
  c = (_Bool)1;
  c = (_Bool)2;
}

// Rule 2: Larger unsigned integer to smaller unsigned (wrap modulo 2^N)
_Safe void rule2_unsigned(void) {
  unsigned long a = 2;
  unsigned b = (unsigned)a;
  int c = -1;
  unsigned d = (unsigned)c;
  unsigned long e = (unsigned long)c;
}

// Rule 3: Larger integer to smaller signed (truncate in implementation)
_Safe void rule3_signed(void) {
  long a = 2;
  int b = (int)a;
  unsigned c = 4294967295;
  int d = (int)c;
}

// Rule 4: Enum - E2 contains E1 allows explicit cast; enum -> int implicit
_Safe void rule4_enum(void) {
  enum E { ZERO, ONE, TWO };
  enum F { SUN, MON, TUES };
  enum F day = SUN;
  enum E num = (enum E)day;
  num = (enum E)SUN;
  int a = num;
  a = ZERO;
}

// Rule 4b: Ternary with same enum type: allowed (branches promoted to int)
_Safe void rule4_enum_ternary(void) {
  enum E { ZERO, ONE, TWO };
  enum E num = ZERO;
  enum E e1 = ONE;
  enum E e2 = TWO;
  int cond = 1;
  num = cond ? e1 : e2;   // ok
  num = cond ? ZERO : ONE; // ok: enum constants
  num = cond ? e1 : ONE;   // ok: mix of var and constant
  num = cond ? (cond ? e1 : ZERO) : (cond ? e2 : ONE); // ok: mixed ternary, var, and constants
  num = cond ? (e1 = ONE) : ONE; // ok
}

// Rule 5: double -> float explicit allowed; float -> double implicit
_Safe void rule5_float_precision(void) {
  double a = 1.0;
  float b = 0.0f;
  b = (float)a;
  a = b;
}

// Rule 6: int -> double explicit allowed
_Safe void rule6_int_to_float(void) {
  int a = -1;
  double b = (double)a;
}

// Rule 7: Comparison/logical result (0/1) -> integer implicit
_Safe void rule7_comparison_result(void) {
  int a = 0, b = 1, x = 5, y = 10;
  _Bool c = (a == 0) || (b == 0);
  char eq = (x == y);
  unsigned char ne = (x != y);
  short lt = (x < y);
  unsigned short le = (x <= y);
  int gt = (x > y);
  unsigned int ge = (x >= y);
  long land = (x > 0) && (y > 0);
  unsigned long lor = (x == 0) || (y == 0);
  long long llnot = !(x == 0);
  unsigned long long ulleq = (x == y);
  unsigned u_ne = (x != y);
  unsigned u_and = (a != 0) && (b != 0);
  unsigned u_or = (a == 0) || (b == 0);
}

// Rule 8: Compile-time constants - fit in target allows implicit
_Safe void rule8_constants(void) {
  int a = 10l;
  unsigned long b = 2 * 2;
  int e = 2147483647;
  int d = (int)2147483648;
  unsigned int f = 0;
  f = (unsigned int)4294967296;
  unsigned long g = (unsigned long)-1;
  float k = 1.0;
  float l = 1;
}

// Rule 9: Literals and literal-only expression results that fit (implicit allowed)
_Safe void rule9_literals_and_literal_expressions(void) {
  int a = 1;
  int b = 0;
  long c = 1;
  double d = 1;
  float e = 1;
  float f = 1.0f;
  unsigned u = 0;
  unsigned v = 1;
  char ch = 0;
  char ch2 = 127;
  int x = 1 + 2;
  long y = 1 + 2;
  double z = 1 + 2;
  unsigned w = 2 * 2;
  int r = 100 / 10;
  float fl = 1.0f + 2.0f;
}

// Rule 10: Value range analysis - non-const expressions whose range fits in target
_Safe void rule10_value_range_analysis(void) {
  // Bitwise OR with small constants
  unsigned char flag = 0;
  flag = flag | 0x10;   // ok: [0,255] | 0x10 fits in unsigned char
  flag = flag | 0x01;   // ok

  // Bitwise AND narrows range
  unsigned short wide = 0;
  flag = wide & 0xFF;         // ok: AND with 0xFF limits result to [0,255]
  flag = wide & 0x7F;         // ok: AND with 0x7F limits result to [0,127]
  unsigned int w32 = 0;
  flag = w32 & 0xFF;          // ok: AND with 0xFF limits to [0,255]
  unsigned short s = 0;
  s = w32 & 0xFFFF;           // ok: AND with 0xFFFF limits to [0,65535]

  // Bitwise XOR
  unsigned char a = 0;
  unsigned char b = 0;
  flag = a ^ b;               // ok: both [0,255], xor result in [0,255]
  flag = a ^ 0x0F;            // ok: [0,255] ^ 0x0F fits in [0,255]

  // Parenthesized expressions
  flag = (flag | 0x10);       // ok: parenthesized, same range
  flag = ((flag | 0x01));     // ok: nested parens

  // Chained bitwise ops
  flag = (flag | 0x01) & 0xFF;  // ok: OR then AND, result in [0,255]
  flag = (flag ^ 0x0F) & 0xFF;  // ok: XOR then AND
  flag = (flag | 0x10) | 0x20;  // ok: multiple ORs, all fit in [0,255]

  // unsigned short target with wider source
  s = flag | 0x100;           // ok: [0,255] | 0x100 fits in [0,65535]
  s = s | 0x10;               // ok: [0,65535] | 0x10 fits in [0,65535]

  // Signed target with non-negative source that fits
  unsigned char uc = 0;
  signed char sc = 0;
  sc = uc & 0x7F;             // ok: AND with 0x7F gives [0,127], fits in signed char
  short ss = 0;
  ss = uc | 0x10;             // ok: [0,255] | 0x10 fits in short
}

int main(void) {
  rule1_bool();
  rule2_unsigned();
  rule3_signed();
  rule4_enum();
  rule4_enum_ternary();
  rule5_float_precision();
  rule6_int_to_float();
  rule7_comparison_result();
  rule8_constants();
  rule9_literals_and_literal_expressions();
  rule10_value_range_analysis();
  return 0;
}
