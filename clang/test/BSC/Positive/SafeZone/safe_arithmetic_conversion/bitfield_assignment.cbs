// RUN: %clang %s -o %t.output
// RUN: %t.output
// RUN: %clang -rewrite-bsc %s -o %t-rw.c
// RUN: %clang %t-rw.c -o %t-rw.output
// RUN: %t-rw.output

#include <stdlib.h>

struct S {
  unsigned int x : 3;
  signed int y : 5;
  unsigned int z : 1;
  signed int w : 4;
  _Bool b : 1;
  unsigned char uc : 3;
  unsigned short us : 10;
  unsigned char uc_full : 8;
  unsigned short us_full : 16;
};

// Constants that fit within the bitfield width
_Safe void test_constant_fits(void) {
  struct S s;
  s.x = 0;
  s.x = 7;    // max for 3-bit unsigned
  s.y = 0;
  s.y = 15;   // max for 5-bit signed
  s.y = -16;  // min for 5-bit signed
  s.y = -1;   // simple negative fits
  s.z = 0;
  s.z = 1;    // max for 1-bit unsigned

  // signed int : 4 — range [-8, 7]
  s.w = 0;
  s.w = 7;    // max for 4-bit signed
  s.w = -8;   // min for 4-bit signed
  s.w = -1;

  // unsigned char : 3 — range [0, 7]
  s.uc = 0;
  s.uc = 7;   // max for 3-bit unsigned

  // unsigned short : 10 — range [0, 1023]
  s.us = 0;
  s.us = 1023; // max for 10-bit unsigned
}

// _Bool bitfield
_Safe void test_bool_bitfield(void) {
  struct S s;
  s.b = 0;
  s.b = 1;
  unsigned short us = 0x1234;
  s.b = us & 0x1;
}

// Initialization with fitting constants
_Safe void test_init_fits(void) {
  struct S s1 = { 7, 15, 1 };
  struct S s2 = { 0, -16, 0 };
  struct S s3 = { .x = 7, .y = -16, .z = 1 };
  struct S s4 = { .w = 7 };
  struct S s5 = { .w = -8 };
  struct S s6 = { .uc = 7 };
  struct S s7 = { .us = 1023 };
  struct S s8 = { .b = 0 };
  struct S s9 = { .b = 1 };
  (void)s1; (void)s2; (void)s3; (void)s4; (void)s5;
  (void)s6; (void)s7; (void)s8; (void)s9;
}

// Masked expressions should narrow the range and fit
_Safe void test_masked_fits(void) {
  struct S s;
  unsigned int val = 999;
  s.x = val & 0x7u;    // masked to 3 bits, fits unsigned:3
  s.z = val & 0x1u;    // masked to 1 bit, fits unsigned:1
  s.uc = val & 0x7u;   // masked to 3 bits, fits unsigned char:3
  s.us = val & 0x3ffu; // masked to 10 bits, fits unsigned short:10
}

// Variables whose type width matches the bitfield exactly
_Safe void test_exact_width_var(void) {
  struct S s;
  unsigned char c = 5;
  s.uc_full = c;  // unsigned char (8) fits unsigned char:8

  unsigned short sh = 5;
  s.us_full = sh; // unsigned short (16) fits unsigned short:16
}

// Bitwise operators: compiler computes the width of bitwise expressions.
// The "value can be masked to fit" hint is verified by these positive cases.
_Safe void test_bitwise_and_narrows(void) {
  struct S s;
  unsigned int val = 100;
  int ival = -5;

  // & with a mask that fits the bitfield width
  s.x = val & 0x7u;    // width of (val & 0x7u) is 3, fits unsigned:3
  s.x = ival & 0x7;    // width of (ival & 0x7) is 3, non-negative, fits unsigned:3
  s.z = val & 0x1u;    // width of (val & 0x1u) is 1, fits unsigned:1
  s.y = val & 0xf;     // width of (val & 0xf) is 4, non-negative, fits signed:5
  s.w = val & 0x7;     // width of (val & 0x7) is 3, non-negative, fits signed:4
  s.us = val & 0x3ffu; // width of (val & 0x3ffu) is 10, fits unsigned:10
}

_Safe void test_bitwise_or_narrows(void) {
  struct S s;
  unsigned int val = 100;

  // | of two narrow values that fit
  s.x = (val & 0x3u) | (val & 0x4u);  // width 2 | width 3 -> width 3, fits unsigned:3
  s.y = (val & 0x7) | (val & 0x3);    // width 3 | width 2 -> width 3, non-negative, fits signed:5
}

_Safe void test_bitwise_xor_narrows(void) {
  struct S s;
  unsigned int val = 100;

  // ^ of two narrow values that fit
  s.x = (val & 0x3u) ^ (val & 0x4u);  // width 2 ^ width 3 -> width 3, fits unsigned:3
  s.y = (val & 0x7) ^ (val & 0x3);    // width 3 ^ width 2 -> width 3, non-negative, fits signed:5
}

// Bitfield operands in bitwise operations: result assigned to bitfield
_Safe void test_bitfield_operand_and(void) {
  struct S s;
  s.x = 7; s.y = 15; s.z = 1; s.uc = 5; s.us = 100;

  // & of two bitfields: result width is min of operand widths
  s.z = s.x & s.z;     // width min(3,1) = 1, fits unsigned:1
  s.uc = s.x & s.uc;   // width min(3,3) = 3, fits unsigned:3
  s.x = s.us & s.x;    // width min(10,3) = 3, fits unsigned:3

  // & of bitfield with constant mask
  s.z = s.x & 0x1u;    // width min(3,1) = 1, fits unsigned:1
  s.x = s.us & 0x7u;   // width min(10,3) = 3, fits unsigned:3
  s.uc = s.us & 0x7u;  // width min(10,3) = 3, fits unsigned:3
}

_Safe void test_bitfield_operand_or(void) {
  struct S s;
  s.x = 5; s.z = 1; s.uc = 3; s.us = 100;

  // | of two bitfields: result width is max of operand widths
  s.x = s.x | s.z;     // width max(3,1) = 3, fits unsigned:3
  s.uc = s.x | s.uc;   // width max(3,3) = 3, fits unsigned:3
  s.us = s.x | s.us;   // width max(3,10) = 10, fits unsigned:10

  // | of bitfield with constant that fits
  s.x = s.x | 0x2u;    // width max(3,2) = 3, fits unsigned:3
  s.us = s.us | 0x1u;  // width max(10,1) = 10, fits unsigned:10
}

_Safe void test_bitfield_operand_xor(void) {
  struct S s;
  s.x = 5; s.z = 1; s.uc = 3; s.us = 100;

  // ^ of two bitfields: result width is max of operand widths
  s.x = s.x ^ s.z;     // width max(3,1) = 3, fits unsigned:3
  s.uc = s.x ^ s.uc;   // width max(3,3) = 3, fits unsigned:3
  s.us = s.x ^ s.us;   // width max(3,10) = 10, fits unsigned:10

  // ^ of bitfield with constant that fits
  s.x = s.x ^ 0x2u;    // width max(3,2) = 3, fits unsigned:3
  s.us = s.us ^ 0x1u;  // width max(10,1) = 10, fits unsigned:10
}

int main(void) {
  test_constant_fits();
  test_bool_bitfield();
  test_init_fits();
  test_masked_fits();
  test_exact_width_var();
  test_bitwise_and_narrows();
  test_bitwise_or_narrows();
  test_bitwise_xor_narrows();
  test_bitfield_operand_and();
  test_bitfield_operand_or();
  test_bitfield_operand_xor();
  return 0;
}
