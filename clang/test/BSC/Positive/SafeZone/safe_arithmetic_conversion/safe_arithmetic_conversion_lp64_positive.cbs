// RUN: %clang_cc1 -fsyntax-only -verify %s -triple x86_64-pc-linux-gnu
// expected-no-diagnostics

// LP64 (Linux x86_64): int 32-bit; long / long long 64-bit.

_Static_assert(sizeof(int) == 4 && sizeof(long) == 8 && sizeof(long long) == 8,
               "LP64 integer widths");

#define SAFE_ASSIGN(dstTy, srcTy, dname, sname)                              \
  do {                                                                         \
    dstTy dname = 0;                                                           \
    srcTy sname = 0;                                                           \
    dname = sname;                                                             \
  } while (0)

_Safe void signed_pairs_lp64(void) {
  SAFE_ASSIGN(long, int, d_li, s_li);
  SAFE_ASSIGN(long long, int, d_lli, s_lli);
  SAFE_ASSIGN(long long, long, d_lll, s_lll);
  SAFE_ASSIGN(long, long long, d_ll_l, s_ll_l);
}

_Safe void unsigned_pairs_lp64(void) {
  SAFE_ASSIGN(unsigned long, unsigned int, d_li, s_li);
  SAFE_ASSIGN(unsigned long long, unsigned int, d_lli, s_lli);
  SAFE_ASSIGN(unsigned long long, unsigned long, d_lll, s_lll);
  SAFE_ASSIGN(unsigned long, unsigned long long, d_ul_ull, s_ul_ull);
}

#undef SAFE_ASSIGN
