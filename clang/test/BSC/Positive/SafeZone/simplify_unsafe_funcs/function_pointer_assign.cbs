// RUN: %clang_cc1 -fsyntax-only -verify %s

typedef unsigned int (*HOOK)(unsigned int a, unsigned int b, unsigned char * const c);

unsigned int naked(unsigned int a, unsigned int b, unsigned char * const c){
    return 0;
}
_Safe unsigned int naked(unsigned int a, unsigned int b, unsigned char * _Borrow const c);
_Safe void test(void){
         _Unsafe HOOK readhook = naked; // expected-warning {{incompatible function pointer types initializing 'HOOK' (aka 'unsigned int (*)(unsigned int, unsigned int, unsigned char *const)') with an expression of type '_Safe unsigned int (unsigned int, unsigned int, unsigned char *const _Borrow)'}}
}
void test1(void){
          HOOK readhook = naked; // expected-warning {{incompatible function pointer types initializing 'HOOK' (aka 'unsigned int (*)(unsigned int, unsigned int, unsigned char *const)') with an expression of type '_Safe unsigned int (unsigned int, unsigned int, unsigned char *const _Borrow)'}}
}
// Hook typedef has _Borrow on parameter: assigning a heterogeneous _Safe
// function to a non-_Safe function pointer succeeds with a C warning outside
// the safe zone.
typedef unsigned int (*Hook)(unsigned int a, unsigned int b,
                             unsigned short *_Borrow const buff);
unsigned int func(unsigned int a, unsigned int b, unsigned short *const buff) {
    return 0;
}
_Safe unsigned int func(unsigned int a, unsigned int b,
                        unsigned short *_Borrow const buff);
void test2(void) {
    Hook readflash = func; // expected-warning {{incompatible function pointer types initializing 'Hook' (aka 'unsigned int (*)(unsigned int, unsigned int, unsigned short *const _Borrow)') with an expression of type '_Safe unsigned int (unsigned int, unsigned int, unsigned short *const _Borrow)'}}
}

int mian(){
    return 0;
}
