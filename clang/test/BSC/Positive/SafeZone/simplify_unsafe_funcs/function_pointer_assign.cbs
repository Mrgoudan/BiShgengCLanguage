// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

typedef unsigned int (*HOOK)(unsigned int a, unsigned int b, unsigned char * const c);

unsigned int naked(unsigned int a, unsigned int b, unsigned char * const c){
    return 0;
}
_Safe unsigned int naked(unsigned int a, unsigned int b, unsigned char * _Borrow const c);
_Safe void test(void){
         _Unsafe HOOK readhook = naked;
}
_Safe void test1(void){
          HOOK readhook = naked;
}
// Hook typedef has _Borrow on parameter: assigning heterogeneous _Safe function
// to a non-_Safe function pointer must succeed (manual section 9, safe->unsafe allowed).
typedef unsigned int (*Hook)(unsigned int a, unsigned int b,
                             unsigned short *_Borrow const buff);
unsigned int func(unsigned int a, unsigned int b, unsigned short *const buff) {
    return 0;
}
_Safe unsigned int func(unsigned int a, unsigned int b,
                        unsigned short *_Borrow const buff);
_Safe void test2(void) {
    Hook readflash = func;
}

int mian(){
    return 0;
}