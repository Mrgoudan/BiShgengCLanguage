// RUN: %clang_cc1 -fsyntax-only -verify %s
// expected-no-diagnostics

// Comprehensive tests for heterogeneous function declarations with array arguments
// Key: _Unsafe versions have NO _Borrow/_Owned qualifiers, _Safe versions DO

// Test 1: Array with const elements to const void*
_Safe int const_process(const void* _Borrow src, unsigned int size);
int const_process(const void* src, unsigned int size);

_Safe void test1(void) {
    const int arr[20];
    _Unsafe {
        const_process(arr, sizeof(arr));  // Matches _Unsafe: const void* (no _Borrow)
    }
}

// Test 2: String literal to const char* _Borrow in _Safe context
_Safe const char* _Borrow get_message(const char* _Borrow msg);

_Safe void test2(void) {
    get_message("hello world");  // String literal auto-borrows in _Safe context
}

// Test 3: Array to _Owned pointer parameter
_Safe void owned_func(int* _Owned data, int size);
void owned_func(int* data, int size);

_Safe void test3(void) {
    int data[100];
    _Unsafe {
        owned_func(data, 100);  // Matches _Unsafe: int* (no _Owned)
    }
}

// Test 4: Struct member arrays
typedef struct {
    char buffer[128];
    int values[32];
} DataBuffer;

_Safe void process_buffer(void* _Borrow buf, int size);
void process_buffer(void* buf, int size);

_Safe void test4(void) {
    DataBuffer db;
    _Unsafe {
        process_buffer(db.buffer, 128);  // Matches _Unsafe: void* (no _Borrow)
        process_buffer(db.values, 32);
    }
}

// Test 5: Different primitive type arrays
void byte_func(unsigned char* data);
void short_func(short* data);
void int_func(int* data);

_Safe void test5(void) {
    unsigned char bytes[256];
    short shorts[128];
    int ints[64];
    
    _Unsafe {
        byte_func(bytes);    // Array decays to pointer
        short_func(shorts);
        int_func(ints);
    }
}

// Test 6: Nested struct arrays
typedef struct {
    struct {
        int nested[64];
    } inner;
} NestedStruct;

_Safe void nested_func(int* _Borrow data);
void nested_func(int* data);

_Safe void test6(void) {
    NestedStruct ns;
    _Unsafe {
        nested_func(ns.inner.nested);  // Matches _Unsafe: int* (no _Borrow)
    }
}

// Test 7: void* with various qualifiers
void void_raw(void* p);
void owned_raw(void* p);

_Safe void test7(void) {
    int arr1[10];
    int arr2[20];
    
    _Unsafe {
        void_raw(arr1);
        owned_raw(arr2);
    }
}

// Test 8: const arrays
void const_func(const int* p);
void mut_func(int* p);

_Safe void test8(void) {
    const int carr[5] = {1,2,3,4,5};
    int marr[5] = {1,2,3,4,5};
    
    _Unsafe {
        const_func(carr);  // const int[5] -> const int*
        mut_func(marr);    // int[5] -> int*
    }
}

// Test 9: typedef'd types
typedef unsigned int uint32_t;
typedef struct { int x; int y; } Point;

void uint_func(uint32_t* data);
void point_func(Point* points);

_Safe void test9(void) {
    uint32_t numbers[100];
    Point points[50];
    
    _Unsafe {
        uint_func(numbers);
        point_func(points);
    }
}

// Test 10: Large arrays
void large_func(void* data);

_Safe void test10(void) {
    char huge[4096];
    _Unsafe {
        large_func(huge);
    }
}

// Test 11: Multiple array parameters
void multi_array(int* a, char* b, float* c);

_Safe void test11(void) {
    int ints[10];
    char chars[20];
    float floats[30];
    
    _Unsafe {
        multi_array(ints, chars, floats);
    }
}

// Test 12: Multi-dimensional array element
void elem_func(int* data);

_Safe void test12(void) {
    int matrix[10][10];
    _Unsafe {
        elem_func(matrix[0]);  // matrix[0] is int[10]
        elem_func(matrix[5]);
    }
}

// Test 13: String literals with _Safe _Borrow function
_Safe void str_func(const char* _Borrow msg);

_Safe void test13(void) {
    str_func("simple");
    str_func("with\nnewline");
    str_func("longer string for testing");
}

// Test 14: Anonymous arrays
void anon_func(int* data);

_Safe void test14(void) {
    _Unsafe {
        anon_func((int[]){1, 2, 3, 4, 5});  // Compound literal array
    }
}

// Test 15: Arrays with heterogeneous void* functions
_Safe void* _Borrow alloc_safe(void* _Borrow hint, unsigned long size);
void* alloc_unsafe(void* hint, unsigned long size);

_Safe void test15(void) {
    char buffer[128];
    _Unsafe {
        alloc_unsafe(buffer, 256);  // Matches _Unsafe version
    }
}
