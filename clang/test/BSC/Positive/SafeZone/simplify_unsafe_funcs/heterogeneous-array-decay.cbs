// RUN: %clang_cc1 -fsyntax-only -verify %s

// Test 1: printf with borrow and auto-borrow from string literal
#define BSC_ATTR(a, b) __attribute__((format(printf,(a),(b))))
_Safe int printf (const char* borrow __restrict _format,...) BSC_ATTR(1,2);

_Safe void test1(void){
     printf("test string\r\n"); // expected-warning {{format string is not a string literal (potentially insecure)}} expected-note {{treat the string as an argument to avoid this}}
}

// Test 2: Array to void* in _Unsafe context (should select _Unsafe version)
extern void * test(const char * p);
extern _Safe void * test(const char * p);

_Safe void test2(void){
    _Unsafe {
        test(__FUNCTION__);
    }
}

// Test 3: Array decay to void* with heterogeneous declarations
extern int process(void* data);
extern _Safe int process(void* data);

_Safe void test3(void) {
    int arr[10];
    _Unsafe {
        process(arr);  // Should select _Unsafe version (array decays to raw pointer)
    }
}

// Test 4: memset_s with array argument (should select _Unsafe version)
typedef struct{
    unsigned int bits[256];
}bit_stream;

_Safe int memset_s(void* borrow dest, unsigned int sizeMax,int c,unsigned int count);
int memset_s(void*  dest, unsigned int sizeMax,int c,unsigned int count);

bit_stream* stram=nullptr;

_Safe void test4(int n){
    _Unsafe{
        memset_s(stram[n].bits,0,0,0);  // Should select _Unsafe version (array cannot match borrow)
    }
}
