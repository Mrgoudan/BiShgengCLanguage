// RUN: %clang_cc1 -fsyntax-only -verify %s

// Test 1: printf with borrow and auto-borrow from string literal
#define BSC_ATTR(a, b) __attribute__((format(printf,(a),(b))))
safe int printf (const char* borrow __restrict _format,...) BSC_ATTR(1,2);

safe void test1(void){
     printf("test string\r\n"); // expected-warning {{format string is not a string literal (potentially insecure)}} expected-note {{treat the string as an argument to avoid this}}
}

// Test 2: Array to void* in unsafe context (should select unsafe version)
extern void * test(const char * p);
extern safe void * test(const char * p);

safe void test2(void){
    unsafe {
        test(__FUNCTION__);
    }
}

// Test 3: Array decay to void* with heterogeneous declarations
extern int process(void* data);
extern safe int process(void* data);

safe void test3(void) {
    int arr[10];
    unsafe {
        process(arr);  // Should select unsafe version (array decays to raw pointer)
    }
}

// Test 4: memset_s with array argument (should select unsafe version)
typedef struct{
    unsigned int bits[256];
}bit_stream;

safe int memset_s(void* borrow dest, unsigned int sizeMax,int c,unsigned int count);
int memset_s(void*  dest, unsigned int sizeMax,int c,unsigned int count);

bit_stream* stram=nullptr;

safe void test4(int n){
    unsafe{
        memset_s(stram[n].bits,0,0,0);  // Should select unsafe version (array cannot match borrow)
    }
}
